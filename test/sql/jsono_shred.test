# name: test/sql/jsono_shred.test
# description: jsono(value, shredding := spec) — one-pass lossless conditional strip into shredded JSONO
# group: [sql]

require jsono

require json

# Peek the raw residual tape: the four blobs read as a plain jsono with the shreds ignored.
# This is the white-box view of what shredding stripped — distinct from casting a shredded
# value to the plain jsono STRUCT, which losslessly reconstructs by overlaying the shreds.
# Extract the four residual blobs by position (their field names carry the shred-set fingerprint
# suffix) and repack them under the clean names so the result is a plain JSONO value.
statement ok
CREATE MACRO jsono_residual(j) AS struct_pack(
    "jsono" := struct_pack(
        body := struct_extract_at(struct_extract_at(j, 1), 1)));

# jsono(j, shredding := spec) returns the shredded STRUCT: four blob residual + one shred per
# spec path (named by the path, typed by the spec). The read side reconstructs the
# original value, so to_json round-trips losslessly.

# All-string shreds: both strip (a string round-trips through a VARCHAR shred), so the
# residual is empty and the values live only in the shreds.
query I
SELECT to_json(jsono('{"did":"d1","kind":"commit"}', shredding := {'$.kind':'VARCHAR','$.did':'VARCHAR'}));
----
{"did":"d1","kind":"commit"}

query I
SELECT to_json(jsono_residual(jsono('{"did":"d1","kind":"commit"}', shredding := {'$.kind':'VARCHAR','$.did':'VARCHAR'})));
----
{}

# Typed shred: a BIGINT path strips and reconstructs as a JSON number; the residual
# keeps only the non-hot key.
query I
SELECT to_json(jsono('{"extra":"e1","kind":"commit","time_us":1700}', shredding := {'$.kind':'VARCHAR','$.time_us':'BIGINT'}));
----
{"extra":"e1","kind":"commit","time_us":1700}

query I
SELECT to_json(jsono_residual(jsono('{"extra":"e1","kind":"commit","time_us":1700}', shredding := {'$.kind':'VARCHAR','$.time_us':'BIGINT'})));
----
{"extra":"e1"}

query I
SELECT CAST(jsono('{"time_us":1700}', shredding := {'$.time_us':'BIGINT'}) ->> '$.time_us' AS BIGINT);
----
1700

# Heterogeneous: a string in a BIGINT-typed shred does not fit, so it is kept in the
# residual (shred NULL) and the read falls back to the residual. Round-trip is faithful.
query I
SELECT to_json(jsono('{"n":"hello"}', shredding := {'$.n':'BIGINT'}));
----
{"n":"hello"}

query I
SELECT jsono('{"n":"hello"}', shredding := {'$.n':'BIGINT'}) ->> '$.n';
----
hello

# A number in a VARCHAR shred: the shred holds the ->> text for reads, but the value is
# not a string so it is not stripped — the residual keeps the number for a faithful
# round-trip.
query I
SELECT to_json(jsono('{"k":5}', shredding := {'$.k':'VARCHAR'}));
----
{"k":5}

query I
SELECT jsono('{"k":5}', shredding := {'$.k':'VARCHAR'}) ->> '$.k';
----
5

# An explicit JSON null is kept (a null is not a string), so it survives reconstruction.
query I
SELECT to_json(jsono('{"a":null,"b":"x"}', shredding := {'$.a':'VARCHAR'}));
----
{"a":null,"b":"x"}

# Nested paths strip too: a nested string shred leaves its leaf out of the residual and
# is refilled from the shred on reconstruction, so the full value round-trips intact.
query I
SELECT to_json(jsono('{"commit":{"collection":"c1","operation":"create"},"kind":"commit"}', shredding := {'$.kind':'VARCHAR','$.commit.operation':'VARCHAR'}));
----
{"commit":{"collection":"c1","operation":"create"},"kind":"commit"}

# The residual keeps the surrounding object but drops the stripped nested leaf.
query I
SELECT to_json(jsono_residual(jsono('{"commit":{"collection":"c1","operation":"create"},"kind":"commit"}', shredding := {'$.kind':'VARCHAR','$.commit.operation':'VARCHAR'})));
----
{"commit":{"collection":"c1"}}

query I
SELECT jsono('{"commit":{"operation":"create"},"kind":"commit"}', shredding := {'$.kind':'VARCHAR','$.commit.operation':'VARCHAR'}) ->> '$.commit.operation';
----
create

# Deep nesting: a third-level string leaf strips from the residual and round-trips.
query I
SELECT to_json(jsono('{"commit":{"record":{"text":"hi","langs":["en"]},"rev":"r1"}}', shredding := {'$.commit.record.text':'VARCHAR','$.commit.rev':'VARCHAR'}));
----
{"commit":{"record":{"langs":["en"],"text":"hi"},"rev":"r1"}}

query I
SELECT to_json(jsono_residual(jsono('{"commit":{"record":{"text":"hi","langs":["en"]},"rev":"r1"}}', shredding := {'$.commit.record.text':'VARCHAR','$.commit.rev':'VARCHAR'})));
----
{"commit":{"record":{"langs":["en"]}}}

# Stripping the only key of a nested object leaves it empty in the residual; the shred
# refills it on reconstruction.
query I
SELECT to_json(jsono_residual(jsono('{"commit":{"record":{"text":"only"}}}', shredding := {'$.commit.record.text':'VARCHAR'})));
----
{"commit":{"record":{}}}

# A nested non-string value is not lossless through a VARCHAR shred, so it stays in the
# residual (read-accelerated, not stripped).
query I
SELECT to_json(jsono_residual(jsono('{"commit":{"seq":42}}', shredding := {'$.commit.seq':'VARCHAR'})));
----
{"commit":{"seq":42}}

# A row missing the nested parent must not gain a spurious empty object: the all-absent
# shreds contribute nothing, so the value round-trips to exactly its original shape.
query I
SELECT to_json(jsono('{"kind":"account","did":"d2"}', shredding := {'$.kind':'VARCHAR','$.commit.operation':'VARCHAR','$.commit.cid':'VARCHAR'}));
----
{"did":"d2","kind":"account"}

# A json-valued read of a subtree holding a stripped nested leaf must reconstruct, so the
# returned subtree is complete — not the residual's stripped copy.
query I
SELECT jsono('{"commit":{"cid":"X","operation":"create"}}', shredding := {'$.commit.cid':'VARCHAR'}) -> '$.commit';
----
{"cid":"X","operation":"create"}

# A NULL input shreds to NULL.
query I
SELECT to_json(jsono(NULL, shredding := {'$.kind':'VARCHAR'}));
----
NULL

# Multi-row over a table, including a NULL row and a missing hot path.
statement ok
CREATE TABLE docs AS
SELECT * FROM (VALUES
    (1, '{"did":"d1","kind":"commit","time_us":10}'),
    (2, '{"did":"d2","kind":"account"}'),
    (3, NULL)
) AS v(id, doc);

query ITT
SELECT id,
       to_json(jsono(doc, shredding := {'$.kind':'VARCHAR','$.did':'VARCHAR','$.time_us':'BIGINT'})) AS full,
       jsono(doc, shredding := {'$.kind':'VARCHAR','$.did':'VARCHAR','$.time_us':'BIGINT'}) ->> '$.kind' AS kind
FROM docs ORDER BY id;
----
1	{"did":"d1","kind":"commit","time_us":10}	commit
2	{"did":"d2","kind":"account"}	account
3	NULL	NULL

# Secondary form: jsono(<already-jsono>, shredding := spec) shreds a value that is already plain
# jsono (the inner jsono() parses, the outer shreds — equivalent to the text form).
query I
SELECT to_json(jsono(jsono('{"did":"d1","kind":"commit"}'), shredding := {'$.kind':'VARCHAR'}));
----
{"did":"d1","kind":"commit"}

query I
SELECT jsono(jsono('{"k":7}'), shredding := {'$.k':'BIGINT'}) ->> '$.k';
----
7

# shredding is a named argument: a bare positional spec is rejected.
statement error
SELECT jsono('{"a":1}', {'$.a':'BIGINT'});
----
unknown argument

# No JSON key is reserved by the storage layout: keys that collide with layout names (body,
# shreds, "jsono") or old flat field names shred and read back correctly — 'body' through its
# path form (a bare 'body' shred name would duplicate the layout's residual field; see below).
query IIIIII
SELECT to_json(j), j ->> 'jsono_slots', j ->> 'jsono_slots_extra', j ->> 'body', j ->> 'shreds', j ->> 'jsono'
FROM (
  SELECT jsono('{"jsono_slots":"v1","jsono_slots_extra":"v2","body":"v3","shreds":"v4","jsono":"v5"}',
               shredding := {'jsono_slots':'VARCHAR','$.body':'VARCHAR','shreds':'VARCHAR'}) AS j
);
----
{"body":"v3","jsono":"v5","jsono_slots":"v1","jsono_slots_extra":"v2","shreds":"v4"}	v1	v2	v3	v4	v5

# jsono(struct) lifts top-level scalar fields of shred types into shreds directly (no spec):
# scalars of shred types become columns, the rest stays in the residual tape. The type is the same
# one jsono_storage_type builds from the same shreds (asserted by equality, fingerprint and all).
query I
SELECT typeof(jsono({'a': 1::BIGINT, 'name': 'x', 'nested': {'k': 2}}))
     = jsono_storage_type('a BIGINT, "name" VARCHAR');
----
true

# the shreds carry the values and to_json round-trips the whole document (incl nested tape)
query III
SELECT s ->> 'a', s ->> 'name', to_json(s) FROM (
  SELECT jsono({'a': 1::BIGINT, 'name': 'x', 'nested': {'k': 2}}) AS s
);
----
1	x	{"a":1,"name":"x","nested":{"k":2}}

# Same reconstruct path when the only residual key is a non-object container — a list, then a
# JSON subtree. Lifting the lone top-level scalar leaves a single-key residual, which the
# to_json overlay must round-trip whole rather than mis-walking the residual tape.
query II
SELECT s ->> 'k', to_json(s) FROM (
  SELECT jsono({'k': 'c', 'tags': [1::BIGINT, 2::BIGINT]}) AS s
);
----
c	{"k":"c","tags":[1,2]}

query II
SELECT s ->> 'k', to_json(s) FROM (
  SELECT jsono({'k': 'c', 'raw': '{"z":1}'::JSON}) AS s
);
----
c	{"k":"c","raw":{"z":1}}

# the struct constructor lifts only top-level shred-typed scalars. (Here `a` is INTEGER, not a
# shred type, so only the VARCHAR `name` lifts; the residual keeps `a`.)
query I
SELECT typeof(jsono({'a': 1, 'name': 'x'}))
     = jsono_storage_type('"name" VARCHAR');
----
true

# the shredded value still round-trips the whole document through to_json
query I
SELECT to_json(jsono({'a': 1, 'name': 'x'}));
----
{"a":1,"name":"x"}

# Constant reconstruction with every field lifted (empty residual): the constant-folded
# to_json copies the shredded constructor, so the bind-data shreds must survive the copy or
# the shred children are left uninitialized. All keys lift, so the residual is {} and the
# whole document must still rebuild from the shreds.
query I
SELECT to_json(jsono({'name': 'x', 'k': 'y'}));
----
{"k":"y","name":"x"}

query I
SELECT to_json(jsono_residual(jsono({'name': 'x', 'k': 'y'})));
----
{}

# Casting a shredded value to the plain jsono STRUCT is LOSSLESS: it reconstructs the full
# document (overlay the shreds back onto the residual), it does not expose the stripped
# residual (which jsono_residual above shows is {}).
query I
SELECT to_json(jsono({'name': 'x', 'k': 'y'})::STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB))));
----
{"k":"y","name":"x"}

# A nested-path shred round-trips through the reconstruct cast too.
query I
SELECT to_json(jsono('{"commit":{"operation":"create"},"kind":"k"}', shredding := {'$.commit.operation':'VARCHAR','$.kind':'VARCHAR'})::STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB))));
----
{"commit":{"operation":"create"},"kind":"k"}

# Storing a shredded value into a plain jsono STRUCT column preserves the shred data (the
# implicit cast reconstructs); the shreds must not be silently dropped.
statement ok
CREATE TABLE plain_store (params STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB))));

statement ok
INSERT INTO plain_store SELECT jsono({'a': 'x', 'b': 5::BIGINT, 'c': 'y'});

query I
SELECT to_json(params) FROM plain_store;
----
{"a":"x","b":5,"c":"y"}

# A shred cannot be named 'body' (it would duplicate the layout's residual field); the path form
# is a different field name and works. jsono({...}) auto-shred keeps a 'body' field in the
# residual silently for the same reason.
statement error
SELECT jsono('{"body":"x"}', shredding := {'body':'VARCHAR'});
----
shred the JSON key through its path form

query II
SELECT to_json(jsono('{"body":"x","a":"y"}', shredding := {'$.body':'VARCHAR'})),
       jsono('{"body":"x","a":"y"}', shredding := {'$.body':'VARCHAR'}) ->> 'body';
----
{"a":"y","body":"x"}	x

query II
SELECT typeof(jsono({'body': 'x', 'a': 'y'})) LIKE '%body VARCHAR%',
       to_json(jsono({'body': 'x', 'a': 'y'}));
----
false	{"a":"y","body":"x"}

# Reshredding to a smaller or retyped shred set is lossless: dropped shreds fold back into the
# residual (single-pass partial overlay), a retyped shred returns and re-extracts at its new type,
# and a row whose values never left the residual carries no stale manifest from its neighbours.
query I
SELECT to_json(jsono(jsono('{"a":"1","b":"2","c":"3","d":4}', shredding := {'a':'VARCHAR','b':'VARCHAR','c':'VARCHAR'}),
                     shredding := {'a':'VARCHAR'}));
----
{"a":"1","b":"2","c":"3","d":4}

query II
SELECT to_json(jsono(jsono('{"a":7,"b":"x"}', shredding := {'a':'VARCHAR'}), shredding := {'a':'BIGINT'})),
       jsono(jsono('{"a":7,"b":"x"}', shredding := {'a':'VARCHAR'}), shredding := {'a':'BIGINT'})."jsono"."a";
----
{"a":7,"b":"x"}	7

query I
SELECT to_json(jsono(e, shredding := {'a':'VARCHAR'}))::VARCHAR FROM (
  SELECT jsono(j, shredding := {'a':'VARCHAR','b':'VARCHAR'}) AS e
  FROM (VALUES ('{"a":"s1","b":"s2"}'), ('{"a":7,"b":8}'), ('{"x":"noshreds"}')) t(j)
) ORDER BY 1;
----
{"a":"s1","b":"s2"}
{"a":7,"b":8}
{"x":"noshreds"}

query I
SELECT to_json(jsono(jsono('{"p":{"q":"deep"},"r":"top"}', shredding := {'$.p.q':'VARCHAR'}),
                     shredding := {'r':'VARCHAR'}));
----
{"p":{"q":"deep"},"r":"top"}
