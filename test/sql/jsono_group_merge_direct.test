# name: test/sql/jsono_group_merge_direct.test
# description: Direct shredded fold of non-keyed jsono_group_merge — parity with the plain fold
# group: [sql]

require jsono

require json

# The direct accumulator (residual merge + scalar lane state) must produce byte-identical
# results to folding the same documents as plain JSONO. Sequential cases run at threads=1 so the
# order-dependent fold sees a deterministic row order for both variants.

statement ok
SET threads = 1;

# Later rows overwrite earlier fields; explicit null members do not overwrite (IgnoreNulls);
# SQL NULL rows are skipped; duplicate keys inside one row collapse to the last.
statement ok
CREATE TABLE seq(ord INTEGER, doc VARCHAR);

statement ok
INSERT INTO seq VALUES
  (1, '{"a":1,"b":"x","keep":true,"extra":{"e":1}}'),
  (2, NULL),
  (3, '{"a":2,"b":null,"c":3.5}'),
  (4, '{"a":null,"c":4.5,"keep":false,"extra":null}');

query I
SELECT to_json(jsono_group_merge(jsono(doc, shredding := {a:'BIGINT', b:'VARCHAR', c:'DOUBLE', keep:'BOOLEAN'}) ORDER BY ord))
     = to_json(jsono_group_merge(jsono(doc) ORDER BY ord))
FROM seq WHERE doc IS NOT NULL OR ord = 2;
----
true

# Diverted -> fitting -> diverted on one BIGINT shred: the lane must not out-rank a newer
# residual value and vice versa. Also nested-lane parent replaced by a scalar, then by an object.
statement ok
CREATE TABLE tricky(ord INTEGER, doc VARCHAR);

statement ok
INSERT INTO tricky VALUES
  (1, '{"k":"not-a-number","n":{"deep":1},"z":1}'),
  (2, '{"k":5,"n":7}'),
  (3, '{"k":"diverted-again","n":{"deep":9,"other":2}}'),
  (4, '{"z":2}');

query II
SELECT to_json(m1) = to_json(m2), to_json(m1)
FROM (
  SELECT jsono_group_merge(jsono(doc, shredding := {k:'BIGINT', '$.n.deep':'BIGINT'}) ORDER BY ord) AS m1,
         jsono_group_merge(jsono(doc) ORDER BY ord) AS m2
  FROM tricky
);
----
true	{"k":"diverted-again","n":{"deep":9,"other":2},"z":2}

# A non-object row replaces the accumulator wholesale; an object after it starts fresh.
statement ok
CREATE TABLE replaced(ord INTEGER, doc VARCHAR);

statement ok
INSERT INTO replaced VALUES
  (1, '{"a":1,"b":2}'),
  (2, '[1,2,3]'),
  (3, '{"c":3}');

query II
SELECT to_json(m1) = to_json(m2), to_json(m1)
FROM (
  SELECT jsono_group_merge(jsono(doc, shredding := {a:'BIGINT', c:'BIGINT'}) ORDER BY ord) AS m1,
         jsono_group_merge(jsono(doc) ORDER BY ord) AS m2
  FROM replaced
);
----
true	{"c":3}

# A non-object FINAL row wins wholesale (NonObject finalize path through the reshred).
query II
SELECT to_json(m1) = to_json(m2), to_json(m1)
FROM (
  SELECT jsono_group_merge(jsono(doc, shredding := {a:'BIGINT'}) ORDER BY ord) AS m1,
         jsono_group_merge(jsono(doc) ORDER BY ord) AS m2
  FROM (VALUES (1, '{"a":1}'), (2, '"scalar-wins"')) v(ord, doc)
);
----
true	"scalar-wins"

# The UBIGINT lane carries values above the int64 range through fold, divert and re-adoption —
# a value routed through the BIGINT slot would come back distorted.
query II
SELECT to_json(m1) = to_json(m2), to_json(m1)
FROM (
  SELECT jsono_group_merge(jsono(doc, shredding := {big:'UBIGINT'}) ORDER BY ord) AS m1,
         jsono_group_merge(jsono(doc) ORDER BY ord) AS m2
  FROM (VALUES
    (1, '{"big":18446744073709551615}'),
    (2, '{"big":"diverted"}'),
    (3, '{"big":10000000000000000000}')
  ) v(ord, doc)
);
----
true	{"big":10000000000000000000}

# Array shreds: whole-array replacement across rows, absent field keeps the previous array,
# a null member keeps it too (IgnoreNulls).
statement ok
CREATE TABLE arrs(ord INTEGER, doc VARCHAR);

statement ok
INSERT INTO arrs VALUES
  (1, '{"tags":[1,2,3],"items":[{"n":1,"s":"a"},{"n":2,"s":"b"}],"other":1}'),
  (2, '{"tags":[9],"other":2}'),
  (3, '{"items":null,"other":3}');

query II
SELECT to_json(m1) = to_json(m2), to_json(m1)
FROM (
  SELECT jsono_group_merge(jsono(doc, shredding := {tags:'BIGINT[]', items:'STRUCT(n BIGINT, s VARCHAR)[]'}) ORDER BY ord) AS m1,
         jsono_group_merge(jsono(doc) ORDER BY ord) AS m2
  FROM arrs
);
----
true	{"items":[{"n":1,"s":"a"},{"n":2,"s":"b"}],"other":3,"tags":[9]}

# The direct result stays shredded (sticky type) and its manifest reflects what actually
# stripped after the fold.
query I
SELECT typeof(jsono_group_merge(jsono(doc, shredding := {a:'BIGINT', b:'VARCHAR'}))) = jsono_storage_type('a BIGINT, b VARCHAR')
FROM (VALUES ('{"a":1,"b":"x"}')) v(doc);
----
true

query I
SELECT jsono_shred_manifest(jsono_group_merge(jsono(doc, shredding := {a:'BIGINT'})))
FROM (VALUES ('{"a":"diverted"}')) v(doc);
----
[]

# Groups whose every row is NULL finalize to {} with NULL shreds (unchanged contract).
query II
SELECT to_json(m), m.jsono.shreds."a".value IS NULL
FROM (
  SELECT jsono_group_merge(jsono(doc, shredding := {a:'BIGINT'})) AS m
  FROM (VALUES (NULL), (NULL)) v(doc)
);
----
{}	true

# Multi-group ordered parity over a mixed workload: shredded fold equals the plain fold per group,
# and the manifest-carrying result reads back. NOTE: the in-aggregate ORDER BY routes through
# DuckDB's sorted-aggregate wrapper, which replays sorted buffers via SimpleUpdate — the direct
# accumulator's own Combine (DirectFoldState) is NOT on this path; the no-ORDER-BY section below
# covers it.
statement ok
CREATE TABLE mixed AS
  SELECT (i % 37) AS g, i AS ord,
         CASE
           WHEN i % 11 = 0 THEN NULL
           WHEN i % 13 = 0 THEN '"row-' || i || '"'
           WHEN i % 7 = 0 THEN '{"k":"txt' || i || '","n":{"deep":' || i || '},"tags":[' || (i % 5) || ']}'
           ELSE '{"k":' || i || ',"c":' || (i % 200) || '.5,"extra' || (i % 3) || '":' || i || '}'
         END AS doc
  FROM range(20000) t(i);

statement ok
SET threads = 4;

query I
SELECT count(*)
FROM (
  SELECT g,
         to_json(jsono_group_merge(jsono(doc, shredding := {k:'BIGINT', c:'DOUBLE', '$.n.deep':'BIGINT', tags:'BIGINT[]'}) ORDER BY ord)) AS shredded,
         to_json(jsono_group_merge(jsono(doc) ORDER BY ord)) AS plain
  FROM mixed GROUP BY g
)
WHERE shredded IS DISTINCT FROM plain;
----
0

# Parallel Combine over the direct accumulator (no ORDER BY, so DirectFoldState runs — an
# in-aggregate ORDER BY routes through SortedAggregateFunction and never exercises Combine). One
# early row fits the BIGINT lanes (k and the nested $.n.deep); every later row diverts both paths
# into the residual (k as a string, n as a scalar that also breaks the nested path's object
# skeleton). The diverted values win under every legal fold/combine order, so the result is
# deterministic and must equal the plain fold. Guards the Combine bug where a stale source lane was
# adopted over the newer merged residual value.
statement ok
SET threads = 8;

statement ok
CREATE TABLE combine_conflict AS
  SELECT i,
         CASE WHEN i = 0 THEN '{"k":1,"n":{"deep":5}}' ELSE '{"k":"s","n":9}' END AS doc
  FROM range(200000) t(i);

query II
SELECT to_json(m1) = to_json(m2), to_json(m1)
FROM (
  SELECT jsono_group_merge(jsono(doc, shredding := {k:'BIGINT', '$.n.deep':'BIGINT'})) AS m1,
         jsono_group_merge(jsono(doc)) AS m2
  FROM combine_conflict
);
----
true	{"k":"s","n":9}

statement ok
RESET threads;

# A sliding window frame drives the direct accumulator through the window segment tree
# (combine_type PRESERVE_INPUT: DirectFoldState must copy, never consume, the frame partials,
# and Finalize must be re-runnable per frame). The frame order is fixed by ord, so the shredded
# and plain folds see identical sequences.
query I
SELECT count(*)
FROM (
  SELECT to_json(jsono_group_merge(jsono(doc, shredding := {k:'BIGINT', c:'DOUBLE', '$.n.deep':'BIGINT', tags:'BIGINT[]'})) OVER w) AS shredded,
         to_json(jsono_group_merge(jsono(doc)) OVER w) AS plain
  FROM mixed
  WINDOW w AS (PARTITION BY g ORDER BY ord ROWS BETWEEN 50 PRECEDING AND CURRENT ROW)
)
WHERE shredded IS DISTINCT FROM plain;
----
0

# The direct finalize writes residual blobs + manifest natively (no reshred) — the materialized
# result must survive a Parquet round-trip: bare lane reads agree with the authoritative
# reconstruct read (a wrong manifest would either throw or silently NULL the diverted lane).

require parquet

statement ok
CREATE TABLE gm_direct AS
SELECT g, jsono_group_merge(j ORDER BY ord) AS m
FROM (
  SELECT g, ord, jsono(doc, shredding := {k:'BIGINT', '$.n.deep':'BIGINT'}) AS j
  FROM (VALUES
    ('g1', 1, '{"k":1,"n":{"deep":10},"extra":"a"}'),
    ('g1', 2, '{"k":2}'),
    ('g2', 1, '{"k":"diverted","n":5}'),
    ('g2', 2, '{"extra":"b"}')
  ) v(g, ord, doc)
) GROUP BY g;

statement ok
COPY gm_direct TO '__TEST_DIR__/gm_direct.parquet' (FORMAT parquet);

query I
SELECT count(*) FROM read_parquet('__TEST_DIR__/gm_direct.parquet')
WHERE (m->>'$.k') IS DISTINCT FROM (jsono(to_json(m)::VARCHAR)->>'$.k')
   OR (m->>'$.n.deep') IS DISTINCT FROM (jsono(to_json(m)::VARCHAR)->>'$.n.deep');
----
0

query II
SELECT g, to_json(m)::VARCHAR FROM read_parquet('__TEST_DIR__/gm_direct.parquet') ORDER BY g;
----
g1	{"extra":"a","k":2,"n":{"deep":10}}
g2	{"extra":"b","k":"diverted","n":5}

# A non-string scalar (or a container) at a VARCHAR lane is a divert: the value lives only in the
# residual and the direct fold must carry it through typed as-is. This once re-typed the number to
# its `->>` text (the lane held a redundant read copy and shadow-delete dropped the residual value).
query I
SELECT to_json(jsono_group_merge(j))
FROM (VALUES (jsono('{"k":42}', shredding := {k:'VARCHAR'}))) t(j);
----
{"k":42}

query I
SELECT to_json(jsono_group_merge(j))
FROM (VALUES (jsono('{"attrs":{"z":1}}', shredding := {attrs:'VARCHAR'}))) t(j);
----
{"attrs":{"z":1}}

# LWW across divert <-> fit transitions: a later fitting string wins over an earlier divert (lane
# activation shadow-deletes the stale residual value), and a later divert wins over an earlier lane
# (the residual-authoritative finalize prefers the residual).
query I
SELECT to_json(jsono_group_merge(j ORDER BY ord))
FROM (VALUES (1, jsono('{"k":42}', shredding := {k:'VARCHAR'})),
             (2, jsono('{"k":"s"}', shredding := {k:'VARCHAR'}))) t(ord, j);
----
{"k":"s"}

query I
SELECT to_json(jsono_group_merge(j ORDER BY ord))
FROM (VALUES (1, jsono('{"k":"s"}', shredding := {k:'VARCHAR'})),
             (2, jsono('{"k":42}', shredding := {k:'VARCHAR'}))) t(ord, j);
----
{"k":42}

# --- Empty group over shredded input -> SQL NULL (DEFAULT_NULL_HANDLING, direct shredded finalize) ---

# Ungrouped empty group (WHERE false) over shredded input -> SQL NULL, not {} with null shreds.
query I
SELECT jsono_group_merge(j) IS NULL
FROM (VALUES (jsono('{"a":1}', shredding := {a:'BIGINT'}))) t(j) WHERE false;
----
true

# GROUP BY over shredded input: the all-NULL group is NULL, the fed group is not.
query II
SELECT g, jsono_group_merge(j) IS NULL
FROM (VALUES ('x', jsono('{"a":1}', shredding := {a:'BIGINT'})),
             ('y', NULL), ('y', NULL)) t(g, j)
GROUP BY g ORDER BY g;
----
x	false
y	true

# Regression guard: a fed group that strips to {} (a null member under IGNORE NULLS) stays {}, NOT
# NULL — it had input, so the empty object is the legitimate result.
query II
SELECT to_json(jsono_group_merge(j)), jsono_group_merge(j) IS NULL
FROM (VALUES (jsono('{"a":null}', shredding := {a:'BIGINT'}))) t(j);
----
{}	false
