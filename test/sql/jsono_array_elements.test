# name: test/sql/jsono_array_elements.test
# description: jsono_array_elements — a JSON array's elements as self-contained plain JSONO values (LIST<jsono>), unnestable and natively queryable, with path overloads, shredded reconstruct, and NULL/miss semantics
# group: [sql]

require jsono

# to_json renders each unnested element back to JSON for assertion (rides core json's to_json(jsono)).
require json

# ── Root array: each element is a native jsono value (list is 1-indexed) ──

query I
SELECT to_json(jsono_array_elements(jsono('[1,2,3]'))[2]);
----
2

# The whole list round-trips element by element in array order.
query II
WITH a AS (SELECT jsono_array_elements(jsono('[10,20,30]')) AS arr)
SELECT i, to_json(arr[i]) FROM a, range(1, 4) t(i) ORDER BY i;
----
1	10
2	20
3	30

# Nested containers as elements stay whole values (object, array).
query II
WITH a AS (SELECT jsono_array_elements(jsono('[{"a":1},[2,3],"s"]')) AS arr)
SELECT i, to_json(arr[i]) FROM a, range(1, 4) t(i) ORDER BY i;
----
1	{"a":1}
2	[2,3]
3	"s"

# Object keys are canonicalized (sorted) in the emitted element, like any jsono value.
query I
SELECT to_json(jsono_array_elements(jsono('[{"b":2,"a":1}]'))[1]);
----
{"a":1,"b":2}

# ── Scalar element kinds: strings with escapes, ints, doubles, big ints, unicode ──

query II
WITH a AS (SELECT jsono_array_elements(jsono('["a\"b","c\\d","e\nf"]')) AS arr)
SELECT i, to_json(arr[i]) FROM a, range(1, 4) t(i) ORDER BY i;
----
1	"a\"b"
2	"c\\d"
3	"e\nf"

query II
WITH a AS (SELECT jsono_array_elements(jsono('[1,-2,3.5,9223372036854775807,12345678901234567890]')) AS arr)
SELECT i, to_json(arr[i]) FROM a, range(1, 6) t(i) ORDER BY i;
----
1	1
2	-2
3	3.5
4	9223372036854775807
5	12345678901234567890

# Unicode survives the fresh re-emit (multibyte string bytes copied verbatim).
query I
SELECT to_json(jsono_array_elements(jsono('["héllo","日本語","😀"]'))[2]);
----
"日本語"

# JSON-null elements become jsono null documents (a valid element, not a dropped/absent row).
query II
WITH a AS (SELECT jsono_array_elements(jsono('[1,null,2]')) AS arr)
SELECT i, to_json(arr[i]) FROM a, range(1, 4) t(i) ORDER BY i;
----
1	1
2	null
3	2

# ── Deeply nested elements re-emit whole ──

query I
SELECT to_json(jsono_array_elements(jsono('[{"a":{"b":{"c":[1,2,{"d":3}]}}}]'))[1]);
----
{"a":{"b":{"c":[1,2,{"d":3}]}}}

# ── Path overloads (VARCHAR JSONPath, literal key, BIGINT index) ──

query I
SELECT to_json(jsono_array_elements(jsono('{"items":[7,8,9]}'), '$.items')[3]);
----
9

query I
SELECT to_json(jsono_array_elements(jsono('{"items":[7,8,9]}'), 'items')[1]);
----
7

# BIGINT index overload: the value at index 1 is itself an array.
query I
SELECT to_json(jsono_array_elements(jsono('[[1,2],[3,4]]'), 1)[2]);
----
4

# Nested path to a deeper array.
query I
SELECT to_json(jsono_array_elements(jsono('{"a":{"b":["x","y"]}}'), '$.a.b')[2]);
----
"y"

# ── Empty array -> [] (an empty list, NOT SQL NULL) ──

query I
SELECT jsono_array_elements(jsono('[]')) IS NULL;
----
false

query I
SELECT length(jsono_array_elements(jsono('[]')));
----
0

# ── Non-array / json-null / missing path / SQL NULL -> SQL NULL ──

query I
SELECT jsono_array_elements(jsono('{"a":1}')) IS NULL;
----
true

query I
SELECT jsono_array_elements(jsono('42')) IS NULL;
----
true

query I
SELECT jsono_array_elements(jsono('null')) IS NULL;
----
true

query I
SELECT jsono_array_elements(jsono('{"items":[1,2]}'), '$.missing') IS NULL;
----
true

query I
SELECT jsono_array_elements(jsono('{"items":5}'), '$.items') IS NULL;
----
true

query I
SELECT jsono_array_elements(NULL) IS NULL;
----
true

# ── unnest integration: per-element ->> reads a field at native speed ──

query I
SELECT e ->> 'name'
FROM (SELECT unnest(jsono_array_elements(jsono('[{"name":"alice","age":30},{"name":"bob","age":25}]'))) AS e) t
ORDER BY 1;
----
alice
bob

query I
SELECT jsono_type(e)
FROM (SELECT unnest(jsono_array_elements(jsono('[{"k":1},[2],3,"s",null,true]'))) AS e) t
ORDER BY 1;
----
ARRAY
BIGINT
BOOLEAN
NULL
OBJECT
VARCHAR

# ── to_json parity: each element equals jsono_extract at the same index ──

query I
SELECT to_json(jsono_array_elements(jsono('[{"a":1},[2,3],"hi",4.5]'))[3])::VARCHAR
     = jsono_extract(jsono('[{"a":1},[2,3],"hi",4.5]'), 2);
----
true

# Non-null elements match jsono_extract at each index (jsono_extract needs a constant path; a JSON
# null element is excluded because jsono_extract collapses JSON null to SQL NULL, whereas
# jsono_array_elements preserves it as a null document).
query I
WITH a AS (SELECT jsono_array_elements(jsono('[{"a":1},[2,3],"hi",4.5]')) AS arr),
     j AS (SELECT jsono('[{"a":1},[2,3],"hi",4.5]') AS d)
SELECT to_json(arr[1])::VARCHAR = jsono_extract(d, 0)
   AND to_json(arr[2])::VARCHAR = jsono_extract(d, 1)
   AND to_json(arr[3])::VARCHAR = jsono_extract(d, 2)
   AND to_json(arr[4])::VARCHAR = jsono_extract(d, 3)
FROM a, j;
----
true

# ── Element count parity via json_array_length ──

query I
SELECT length(jsono_array_elements(jsono('[1,2,3,4,5]'))) = json_array_length('[1,2,3,4,5]');
----
true

query I
SELECT length(jsono_array_elements(jsono('{"xs":[1,2,3]}'), '$.xs')) = json_array_length('{"xs":[1,2,3]}', '$.xs');
----
true

# ── Multi-row: each row's array is independent; NULL/miss rows interleave ──

statement ok
CREATE TABLE docs AS
SELECT jsono(v) AS j
FROM (VALUES (1, '[1,2]'), (2, '{"not":"array"}'), (3, '[]'), (4, NULL), (5, '[9]')) t(ord, v)
ORDER BY ord;

query II
SELECT rowid, to_json(jsono_array_elements(j)[1])
FROM docs
ORDER BY rowid;
----
0	1
1	NULL
2	NULL
3	NULL
4	9

# ── Shredded input: reconstructs via the validated read-path (scalar + array-shredded path) ──

query I
SELECT to_json(jsono_array_elements(jsono('{"items":[3,6,9]}', shredding := {'f0': 'BIGINT'}), '$.items')[2]);
----
6

# An array-shredded path: the lifted LIST<STRUCT> reconstructs to the same elements as a plain parse.
query II
WITH a AS (
  SELECT jsono_array_elements(
           jsono('{"items":[{"name":"a","cat":"x"},{"name":"b","cat":"y"}]}',
                 shredding := {'$.items': 'STRUCT(name VARCHAR, cat VARCHAR)[]'}),
           '$.items') AS arr)
SELECT i, to_json(arr[i]) FROM a, range(1, 3) t(i) ORDER BY i;
----
1	{"cat":"x","name":"a"}
2	{"cat":"y","name":"b"}

# ── Bind errors ──

statement error
SELECT jsono_array_elements(42);
----
argument must be JSONO

statement error
SELECT jsono_array_elements(jsono('[1]'), '$[*]');
----
invalid path
