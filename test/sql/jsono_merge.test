# name: test/sql/jsono_merge.test
# description: jsono_merge_patch cursor fast-path and jsono_group_merge edge cases
# group: [sql]

require jsono

# Shred-aware merge reconstructs through to_json, which rides core json's to_json(ANY).
require json

# The 2-argument object/object jsono_merge_patch takes a cursor fast-path that
# walks the sorted-key views straight into the builder (no OwnedValue DOM). These
# cases lock the behaviors that path must match ApplyMergePatch (RFC 7396,
# DeleteNulls) on; the >2-arg and non-object cases exercise the DOM fallback.

# Array values are replaced wholesale (not deep-merged) and copied verbatim, so
# null array elements are preserved. The target-only key "b" survives untouched.
query I
SELECT to_json(jsono_merge_patch(jsono('{"a":[1,2],"b":1}'), jsono('{"a":[3,null,4]}')));
----
{"a":[3,null,4],"b":1}

# Everything inside an array is verbatim: an object nested in an array keeps its
# null member.
query I
SELECT to_json(jsono_merge_patch(jsono('{}'), jsono('{"items":[{"x":1,"y":null}]}')));
----
{"items":[{"x":1,"y":null}]}

# Target nulls are values, not deletions (RFC 7396): the base's nested y:null and
# top-level b:null survive because the patch does not mention them.
query I
SELECT to_json(jsono_merge_patch(jsono('{"a":{"x":1,"y":null},"b":null}'), jsono('{"c":2}')));
----
{"a":{"x":1,"y":null},"b":null,"c":2}

# A patch null deletes the key it names, but a patch object value is merged onto an
# absent/empty target and so drops its own null members.
query I
SELECT to_json(jsono_merge_patch(jsono('{}'), jsono('{"obj":{"p":1,"q":null}}')));
----
{"obj":{"p":1}}

# A non-object patch replaces the target wholesale (DOM fallback).
query I
SELECT to_json(jsono_merge_patch(jsono('{"a":1}'), jsono('5')));
----
5

# A non-object base is replaced by a fresh object before the patch applies.
query I
SELECT to_json(jsono_merge_patch(jsono('5'), jsono('{"a":1}')));
----
{"a":1}

# The cursor fast-path (2 args) and the DOM fold (>2 args, here with an empty
# trailing patch) must agree on a value mixing nested objects, arrays with nulls,
# a deleted key, and a preserved scalar.
query I
SELECT to_json(jsono_merge_patch(
  jsono('{"a":{"b":[1,null,2]},"c":null,"d":"x"}'),
  jsono('{"a":{"e":3},"c":5}')
));
----
{"a":{"b":[1,null,2],"e":3},"c":5,"d":"x"}

query I
SELECT to_json(jsono_merge_patch(
  jsono('{"a":{"b":[1,null,2]},"c":null,"d":"x"}'),
  jsono('{"a":{"e":3},"c":5}'),
  jsono('{}')
));
----
{"a":{"b":[1,null,2],"e":3},"c":5,"d":"x"}

# RFC 7396 Appendix A: an explicit null in the target survives a patch that does
# not name its key. The cursor fast-path (2 args) and the DOM fold (3 args, empty
# trailing patch) must agree.
query I
SELECT to_json(jsono_merge_patch(jsono('{"e":null}'), jsono('{"a":1}')));
----
{"a":1,"e":null}

query I
SELECT to_json(jsono_merge_patch(jsono('{"e":null}'), jsono('{"a":1}'), jsono('{}')));
----
{"a":1,"e":null}

# Nested target null preserved when the patch touches a sibling key; the deeply
# nested f.g.h:null survives a verbatim target-only copy. A patch scalar replaces
# a target null (g), and a patch null deletes a key even when the target value is
# itself null (k).
query I
SELECT to_json(jsono_merge_patch(
  jsono('{"a":{"x":null,"y":1},"f":{"g":{"h":null,"i":2}},"g":null,"k":null}'),
  jsono('{"a":{"y":3},"g":2,"k":null}')
));
----
{"a":{"x":null,"y":3},"f":{"g":{"h":null,"i":2}},"g":2}

# A one-key scalar patch inserts the patch key in sorted order while the target's
# own nulls (top-level b, nested d.x) are preserved verbatim (RFC 7396).
query I
SELECT to_json(jsono_merge_patch(
  jsono('{"a":1,"b":null,"d":{"x":null},"f":6}'),
  jsono('{"c":"patch"}')
));
----
{"a":1,"b":null,"c":"patch","d":{"x":null},"f":6}

# The same one-key scalar path replaces an existing base value instead of
# duplicating the key.
query I
SELECT to_json(jsono_merge_patch(
  jsono('{"a":1,"c":{"x":1},"d":2}'),
  jsono('{"c":"patch"}')
));
----
{"a":1,"c":"patch","d":2}

# jsono_merge_patch folds N arguments through the cursor engine (no DOM): the first
# is the verbatim target, the rest are patches. A lone target is identity and keeps
# its nulls.
query I
SELECT to_json(jsono_merge_patch(jsono('{"keep":null,"a":1}')));
----
{"a":1,"keep":null}

# A non-object patch replaces the accumulator wholesale; an object patch merged onto
# a non-object/array accumulator starts from an empty object (its own nulls stripped).
query I
SELECT to_json(jsono_merge_patch(jsono('[1,2]'), jsono('{"a":1}')));
----
{"a":1}

query I
SELECT to_json(jsono_merge_patch(jsono('{"a":1}'), jsono('[3,4]')));
----
[3,4]

# A JSON null patch is a value (not a SQL NULL): it replaces the accumulator with null.
query I
SELECT to_json(jsono_merge_patch(jsono('{"a":1}'), jsono('null')));
----
null

# A four-argument chain mixing non-object and object values folds left to right.
query I
SELECT to_json(jsono_merge_patch(jsono('5'), jsono('{"a":1}'), jsono('[1,2]'), jsono('{"b":2}')));
----
{"b":2}

# SQL NULL (a missing row, distinct from a JSON null) propagates: a SQL NULL patch
# argument makes the whole result SQL NULL, while a SQL NULL target is an empty
# document an object patch merges onto. A mid-chain SQL NULL resets the accumulator.
query I
SELECT to_json(jsono_merge_patch(NULL, jsono('{"a":1}')));
----
{"a":1}

query I
SELECT to_json(jsono_merge_patch(jsono('{"a":1}'), NULL));
----
NULL

query I
SELECT to_json(jsono_merge_patch(jsono('{"a":1}'), NULL, jsono('{"c":3}')));
----
{"c":3}

query I
SELECT to_json(jsono_merge_patch(jsono('{"a":1}'), jsono('{"b":2}'), NULL));
----
NULL

# Group merge folds each row's view straight into the accumulator, ignoring nulls:
# keeps the latest non-null; array values are replaced verbatim, not merged.
query I
SELECT to_json(jsono_group_merge(j ORDER BY ts))
FROM (VALUES
  (jsono('{"a":[1,2],"b":1}'), 1),
  (jsono('{"a":null,"c":3}'), 2)
) AS t(j, ts);
----
{"a":[1,2],"b":1,"c":3}

# Wide result (>16 keys) builds object cursor checkpoints, and the merge value
# block copies scalar runs as bulk string slices that span the stride boundaries.
# Merge a tiny patch (one strip, one add) into a 25-key base and read back, so the
# checkpoint navigation a high-rank path lookup uses must agree with the bulk emit.
query I
SELECT to_json(jsono_merge_patch(
  jsono('{"k00":"v00","k01":"v01","k02":"v02","k03":"v03","k04":"v04","k05":"v05","k06":"v06","k07":"v07","k08":"v08","k09":"v09","k10":"v10","k11":"v11","k12":"v12","k13":"v13","k14":"v14","k15":"v15","k16":"v16","k17":"v17","k18":"v18","k19":"v19","k20":"v20","k21":"v21","k22":"v22","k23":"v23","k24":"v24"}'),
  jsono('{"k05":null,"knew":"new"}')
));
----
{"k00":"v00","k01":"v01","k02":"v02","k03":"v03","k04":"v04","k06":"v06","k07":"v07","k08":"v08","k09":"v09","k10":"v10","k11":"v11","k12":"v12","k13":"v13","k14":"v14","k15":"v15","k16":"v16","k17":"v17","k18":"v18","k19":"v19","k20":"v20","k21":"v21","k22":"v22","k23":"v23","k24":"v24","knew":"new"}

# Path navigation into the wide merged object uses the cursor checkpoints: a
# high-rank key past the stride boundary resolves, the stripped null is absent.
query III
SELECT
  jsono_type(m, '$.k20'),
  jsono_type(m, '$.knew'),
  jsono_type(m, '$.k05')
FROM (SELECT jsono_merge_patch(
  jsono('{"k00":"v00","k01":"v01","k02":"v02","k03":"v03","k04":"v04","k05":"v05","k06":"v06","k07":"v07","k08":"v08","k09":"v09","k10":"v10","k11":"v11","k12":"v12","k13":"v13","k14":"v14","k15":"v15","k16":"v16","k17":"v17","k18":"v18","k19":"v19","k20":"v20","k21":"v21","k22":"v22","k23":"v23","k24":"v24"}'),
  jsono('{"k05":null,"knew":"new"}')) AS m);
----
VARCHAR	VARCHAR	NULL

# The merged wide object exposes exactly its surviving keys (k05 stripped, knew
# added), in sorted order.
query I
SELECT jsono_keys(jsono_merge_patch(
  jsono('{"k00":"v00","k01":"v01","k02":"v02","k03":"v03","k04":"v04","k05":"v05","k06":"v06","k07":"v07","k08":"v08","k09":"v09","k10":"v10","k11":"v11","k12":"v12","k13":"v13","k14":"v14","k15":"v15","k16":"v16","k17":"v17","k18":"v18","k19":"v19","k20":"v20","k21":"v21","k22":"v22","k23":"v23","k24":"v24"}'),
  jsono('{"k05":null,"knew":"new"}')));
----
[k00, k01, k02, k03, k04, k06, k07, k08, k09, k10, k11, k12, k13, k14, k15, k16, k17, k18, k19, k20, k21, k22, k23, k24, knew]

# jsono_overlay: base (residual) is authoritative; the patch (shreds) fills only what the
# base lacks, recursively into nested objects. Powers shredded reconstruction.

# Top-level fill: a key the base lacks comes from the patch.
query I
SELECT to_json(jsono_overlay(jsono('{"did":"d1"}'), jsono('{"kind":"commit"}')));
----
{"did":"d1","kind":"commit"}

# Scalar conflict: the base wins, the patch copy is ignored.
query I
SELECT to_json(jsono_overlay(jsono('{"kind":"base"}'), jsono('{"kind":"patch"}')));
----
{"kind":"base"}

# Deep recurse: both have the object key, but the base dropped a nested leaf — the patch
# refills it while the base keeps the leaves it has.
query I
SELECT to_json(jsono_overlay(
  jsono('{"commit":{"operation":"create"}}'),
  jsono('{"commit":{"cid":"X","rev":"r1"}}')));
----
{"commit":{"cid":"X","operation":"create","rev":"r1"}}

# Nested conflict: the base wins each leaf even several levels down.
query I
SELECT to_json(jsono_overlay(
  jsono('{"a":{"b":{"c":"base"}}}'),
  jsono('{"a":{"b":{"c":"patch","d":"fill"}}}')));
----
{"a":{"b":{"c":"base","d":"fill"}}}

# An all-null patch subtree contributes nothing: no spurious empty object is introduced.
query I
SELECT to_json(jsono_overlay(jsono('{"did":"d2"}'), jsono('{"commit":{"cid":null,"rev":null}}')));
----
{"did":"d2"}

# The base's own explicit null is real data and is kept (base authoritative).
query I
SELECT to_json(jsono_overlay(jsono('{"a":null}'), jsono('{"a":"x","b":"y"}')));
----
{"a":null,"b":"y"}

# Shred-aware merge: a shredded patch (event_name shred) merged onto a plain target keeps
# the shred (does not flatten), so the result is shredded and the shred reads from its column.
query I
SELECT typeof(jsono_merge_patch(
  jsono('{"a":1}'),
  jsono('{"event_name":"page_view"}', shredding := {'event_name':'VARCHAR'})
)) = typeof(jsono('{}', shredding := {'event_name':'VARCHAR'}));
----
true

# the merged value reconstructs the full document and the shred carries the value
query II
SELECT to_json(m), m ->> 'event_name' FROM (
  SELECT jsono_merge_patch(
    jsono('{"a":1}'),
    jsono('{"event_name":"page_view"}', shredding := {'event_name':'VARCHAR'})
  ) AS m
);
----
{"a":1,"event_name":"page_view"}	page_view

# --- Shred/residual conflict correctness (default-shred makes jsono({...}) patches shredded) ---

# merge_patch: a shredded patch key that overlaps a base residual key must WIN (RFC 7386).
# Regression: the base used to shadow the shred via the residual-authoritative reconstruct.
query I
SELECT to_json(jsono_merge_patch(jsono('{"event_name":"search","x":1}'), jsono({'event_name': 'page_view'})));
----
{"event_name":"page_view","x":1}

# Bidirectional: a plain patch overriding a shredded base shred — the patch still wins.
query I
SELECT to_json(jsono_merge_patch(jsono({'event_name': 'a'}), jsono('{"event_name":"b"}')));
----
{"event_name":"b"}

# Disjoint keys: the shredded patch adds a new key, base keys preserved.
query I
SELECT to_json(jsono_merge_patch(jsono('{"x":1,"y":2}'), jsono({'event_name': 'click'})));
----
{"event_name":"click","x":1,"y":2}

# A typed (BIGINT) shred patch overwrites a base numeric key.
query I
SELECT to_json(jsono_merge_patch(jsono('{"n":1,"x":2}'), jsono({'n': 99::BIGINT})));
----
{"n":99,"x":2}

# overlay is base-authoritative: the shredded patch must NOT override an existing base key.
query I
SELECT to_json(jsono_overlay(jsono('{"event_name":"search"}'), jsono({'event_name': 'page_view'})));
----
{"event_name":"search"}

# overlay fills a key absent from the base from the shredded patch's shred.
query I
SELECT to_json(jsono_overlay(jsono('{"x":1}'), jsono({'event_name': 'page_view'})));
----
{"event_name":"page_view","x":1}

# Multi-arg merge_patch: later shredded patch wins over earlier patches and the base.
query I
SELECT to_json(jsono_merge_patch(jsono('{"event_name":"a","x":1}'),
                                 jsono({'event_name': 'b'}),
                                 jsono({'event_name': 'c'})));
----
{"event_name":"c","x":1}

# The merged value still round-trips its shred via the typed accessor (result stays shredded).
query II
SELECT typeof(m) = typeof(jsono('{}', shredding := {'event_name':'VARCHAR'})), m ->> 'event_name' FROM (
  SELECT jsono_merge_patch(jsono('{"event_name":"search","x":1}'), jsono({'event_name': 'page_view'})) AS m
);
----
true	page_view

# A NULL base with a shredded patch reconstructs to just the patch.
query I
SELECT to_json(jsono_merge_patch(jsono(NULL), jsono({'event_name': 'x'})));
----
{"event_name":"x"}

# Reconstructing a shredded value whose residual is a non-object scalar must emit it verbatim
# (shreds are object-key paths, necessarily absent here) rather than overlaying onto a non-object.
query I
SELECT to_json(jsono('5', shredding := {'k':'VARCHAR'})::STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB))));
----
5

query I
SELECT to_json(jsono_merge_patch(jsono('5', shredding := {'k':'VARCHAR'}), jsono('{"a":1}')));
----
{"a":1}

# --- Fast shred-merge path: all-shredded inputs, top-level shreds (no reconstruct/reshred) ---

# Disjoint shredded base + shredded patch: both stay shreds, result is shredded.
query II
SELECT to_json(m), typeof(m) = jsono_storage_type('a VARCHAR, b VARCHAR, c VARCHAR') FROM (
  SELECT jsono_merge_patch(jsono({'a': '1', 'b': '2'}), jsono({'c': '3'})) AS m
);
----
{"a":"1","b":"2","c":"3"}	true

# Same shred key in both shredded inputs: patch wins (RFC 7396), handled on the fast path
# because the key lives in the shreds, never the residual.
query I
SELECT to_json(jsono_merge_patch(jsono({'a': 'old', 'b': 'keep'}), jsono({'a': 'new'})));
----
{"a":"new","b":"keep"}

# JSONPath shred names must stay JSONPath names when merge_patch falls back to reconstruct+reshred;
# otherwise the reshred populates a literal "$.a" key shred and transparent reads of $.a return NULL.
query III
SELECT (jsono_storage_size(m)).shreds, m ->> '$.a', to_json(m)
FROM (
  SELECT jsono_merge_patch(
    jsono('{"a":"old","b":1}', shredding := {'$.a':'VARCHAR'}),
    jsono('{"a":"new"}', shredding := {'$.a':'VARCHAR'})
  ) AS m
);
----
3	new	{"a":"new","b":1}

# overlay over all-shredded inputs is base-authoritative even on the fast path.
query I
SELECT to_json(jsono_overlay(jsono({'a': 'base', 'b': 'keep'}), jsono({'a': 'patch', 'c': 'add'})));
----
{"a":"base","b":"keep","c":"add"}

# Typed shreds through the fast path.
query I
SELECT to_json(jsono_merge_patch(jsono({'n': 1::BIGINT, 'f': true}), jsono({'n': 9::BIGINT})));
----
{"f":true,"n":9}

# Multi-arg fast path: last shredded patch wins.
query I
SELECT to_json(jsono_merge_patch(jsono({'k': 'a'}), jsono({'k': 'b'}), jsono({'k': 'c'})));
----
{"k":"c"}

# Nested residual content (non-shred) is preserved through the fast path alongside the shreds.
query I
SELECT to_json(jsono_merge_patch(jsono({'name': 'x', 'meta': {'src': 'web'}}), jsono({'name': 'y'})));
----
{"meta":{"src":"web"},"name":"y"}

# --- Fast path with PLAIN inputs (a plain jsono argument no longer forces the reshred
# fallback). The lane copy-through must match the fallback exactly; the gate diverts to the
# fallback whenever a plain input could make it wrong. ---

# Disjoint plain patch (an object-valued key, kept plain): the base lanes copy through, the
# plain key folds into the residual.
query II
SELECT to_json(m), typeof(m) = jsono_storage_type('event_name VARCHAR, goals VARCHAR, url VARCHAR')
FROM (
  SELECT jsono_merge_patch(
    jsono({'event_name': 'pv', 'url': 'u'}),
    jsono('{"params":{"a":1,"b":2}}'),
    jsono({'goals': 'g'})
  ) AS m
);
----
{"event_name":"pv","goals":"g","params":{"a":1,"b":2},"url":"u"}	true

# The merged document still reads its lanes back through the typed accessor.
query III
SELECT m ->> 'event_name', m ->> 'goals', m ->> 'url'
FROM (
  SELECT jsono_merge_patch(
    jsono({'event_name': 'pv', 'url': 'u'}),
    jsono('{"params":{"a":1,"b":2}}'),
    jsono({'goals': 'g'})
  ) AS m
);
----
pv	g	u

# Plain patch naming a lane with a NON-NULL value: the value lands in the folded residual,
# the gate sees the collision and falls back so the patch wins (RFC 7396 last-wins).
query I
SELECT to_json(jsono_merge_patch(jsono({'event_name': 'x', 'goals': 'y'}), jsono('{"event_name":"z"}')));
----
{"event_name":"z","goals":"y"}

# Plain patch naming a lane with an RFC 7396 NULL deletes the lane. This is the trap the lane
# copy-through cannot express (the null leaves no trace in the folded residual), so the gate
# must divert to the fallback — without that guard the deleted lane would be wrongly kept.
query I
SELECT to_json(jsono_merge_patch(jsono({'event_name': 'x', 'goals': 'y'}), jsono('{"event_name":null}')));
----
{"goals":"y"}

# Non-object plain patch replaces the whole document (RFC 7396): the merged value has no lanes,
# so the gate diverts to the fallback rather than attaching the base lanes to a scalar.
query I
SELECT to_json(jsono_merge_patch(jsono({'event_name': 'x', 'goals': 'y'}), jsono('5')));
----
5

# Plain patch first, shredded base second (plain target replaced by the shredded object patch).
query I
SELECT to_json(jsono_merge_patch(jsono('7'), jsono({'event_name': 'x'})));
----
{"event_name":"x"}

# Vector-scale: every row is a disjoint plain patch onto a shredded base — the whole vector
# rides the fast path and each row reconstructs correctly.
query II
SELECT g, to_json(m)
FROM (
  SELECT g, jsono_merge_patch(j, jsono('{"params":{"n":' || g || '}}')) AS m
  FROM (
    SELECT i AS g, jsono('{"event_name":"e' || i || '","seq":"' || i || '"}',
                         shredding := {'event_name':'VARCHAR','seq':'VARCHAR'}) AS j
    FROM range(2050) t(i)
  )
) WHERE g IN (0, 1024, 2049)
ORDER BY g;
----
0	{"event_name":"e0","params":{"n":0},"seq":"0"}
1024	{"event_name":"e1024","params":{"n":1024},"seq":"1024"}
2049	{"event_name":"e2049","params":{"n":2049},"seq":"2049"}

# Vector-scale with a poisoned row: one row's plain patch deletes a lane, forcing the whole
# vector to the fallback — the other rows must still be correct.
query II
SELECT g, to_json(m)
FROM (
  SELECT g, jsono_merge_patch(j, patch) AS m
  FROM (
    SELECT i AS g,
           jsono('{"event_name":"e' || i || '","seq":"' || i || '"}',
                 shredding := {'event_name':'VARCHAR','seq':'VARCHAR'}) AS j,
           CASE WHEN i = 5 THEN jsono('{"event_name":null}') ELSE jsono('{"kept":1}') END AS patch
    FROM range(2050) t(i)
  )
) WHERE g IN (5, 1024)
ORDER BY g;
----
5	{"seq":"5"}
1024	{"event_name":"e1024","kept":1,"seq":"1024"}

# --- Fast path with NESTED object-key shreds (jsono({'params':{...}}) auto-shreds nested scalars
# into $.params.* lanes). A nested lane copies through like a top-level one, overlaid at its path
# on read; the gate diverts to the fallback on any collision/non-object along the path. ---

# Production shape: shredded base + auto-shredded nested patch + small shredded patch, all disjoint.
# The nested $.params.* lanes copy through; the result stays shredded over the union shred set.
query II
SELECT to_json(m), typeof(m) = jsono_storage_type(
  'event_name VARCHAR, goals VARCHAR, url VARCHAR, "$.params.a" VARCHAR, "$.params.b" VARCHAR'
)
FROM (
  SELECT jsono_merge_patch(
    jsono({'event_name': 'pv', 'url': 'u'}),
    jsono({'params': {'a': '1', 'b': '2'}}),
    jsono({'goals': 'g'})
  ) AS m
);
----
{"event_name":"pv","goals":"g","params":{"a":"1","b":"2"},"url":"u"}	true

# The nested lanes read back through the path accessor.
query III
SELECT m ->> '$.params.a', m ->> '$.params.b', m ->> 'goals'
FROM (
  SELECT jsono_merge_patch(
    jsono({'event_name': 'pv', 'url': 'u'}),
    jsono({'params': {'a': '1', 'b': '2'}}),
    jsono({'goals': 'g'})
  ) AS m
);
----
1	2	g

# Nested collision: a plain patch overwriting a nested lane lands the value in the folded residual,
# the path-aware probe sees it and falls back so the patch wins.
query I
SELECT to_json(jsono_merge_patch(jsono({'params': {'a': 'base'}}), jsono('{"params":{"a":"patch"}}')));
----
{"params":{"a":"patch"}}

# Nested null-delete: a plain patch nulling a nested lane deletes it. The null leaves no trace in the
# folded residual, so the plain-input path descent must catch it and fall back.
query I
SELECT to_json(jsono_merge_patch(jsono({'params': {'a': 'x', 'b': 'y'}}), jsono('{"params":{"a":null}}')));
----
{"params":{"b":"y"}}

# Nested parent replaced by a scalar: the lane cannot overlay into a non-object, so the path descent
# (a non-object node before the leaf) forces the fallback; RFC 7396 replaces params wholesale.
query I
SELECT to_json(jsono_merge_patch(jsono({'params': {'a': 'x'}}), jsono('{"params":5}')));
----
{"params":5}

# Disjoint nested addition: a plain patch adding a sibling key under the same parent keeps the base's
# nested lane (the patch key folds into the residual skeleton, the lane overlays beside it).
query I
SELECT to_json(jsono_merge_patch(jsono({'params': {'a': 'keep'}}), jsono('{"params":{"c":"add"}}')));
----
{"params":{"a":"keep","c":"add"}}

# Vector-scale nested fast path: every row's nested lane copies through across chunk boundaries.
query II
SELECT g, to_json(m)
FROM (
  SELECT g, jsono_merge_patch(j, jsono('{"tag":"t' || g || '"}')) AS m
  FROM (
    SELECT i AS g, jsono({'params': {'a': 'v' || i}}) AS j
    FROM range(2050) t(i)
  )
) WHERE g IN (0, 1024, 2049)
ORDER BY g;
----
0	{"params":{"a":"v0"},"tag":"t0"}
1024	{"params":{"a":"v1024"},"tag":"t1024"}
2049	{"params":{"a":"v2049"},"tag":"t2049"}

# Scalar↔object cross-patch: a field changes from a scalar to a nested object across patches, so the
# merged shred set carries both `a` (top-level scalar lane) and `$.a.a` (nested lane) — a sparse
# multi-shape layout. The fast path bails such overlapping lanes to the reshred fallback, which writes
# both lanes correctly; the to_json overlay reconstructs them (independent-overlay fallback). The
# shredded fold must equal the plain RFC 7396 reference. See test/sql/jsono_shredded_overlap.test.
query I
SELECT to_json(jsono_merge_patch(jsono('{"a":null}'), jsono('{"a":{"a":false}}'), jsono('{"a":false}')));
----
{"a":false}

query I
SELECT to_json(jsono_merge_patch(
  jsono('{"a":null}', shredding := {'a':'VARCHAR'}),
  jsono({'a': {'a': false}}),
  jsono({'a': false})
));
----
{"a":false}

# The merge keeps the value shredded over both overlapping lanes (it is not reduced to plain).
query I
SELECT typeof(jsono_merge_patch(
  jsono('{"a":null}', shredding := {'a':'VARCHAR'}),
  jsono({'a': {'a': false}}),
  jsono({'a': false})
)) = jsono_storage_type('a BOOLEAN, "$.a.a" BOOLEAN');
----
true

# Reverse direction (the field ends as the nested object): same overlapping merged set, shredded
# equals plain.
query I
SELECT to_json(jsono_merge_patch(
  jsono('{"a":false}', shredding := {'a':'BOOLEAN'}),
  jsono({'a': {'a': true}})
)) = to_json(jsono_merge_patch(jsono('{"a":false}'), jsono('{"a":{"a":true}}')));
----
true

# --- jsono_group_merge over shredded inputs: accepts shredded, returns shredded (sticky shreds) ---

# Shredded inputs fold the same as plain (latest non-null wins, nulls ignored), and the
# result stays shredded with the same shred set so the shred reads back from its column.
query III
SELECT to_json(m), m ->> 'event_name', typeof(m) = jsono_storage_type('event_name VARCHAR')
FROM (
  SELECT jsono_group_merge(j ORDER BY ts) AS m FROM (VALUES
    (jsono('{"event_name":"search","x":1}', shredding := {'event_name':'VARCHAR'}), 1),
    (jsono('{"event_name":"page_view"}', shredding := {'event_name':'VARCHAR'}), 2)
  ) t(j, ts)
);
----
{"event_name":"page_view","x":1}	page_view	true

# Same sticky-shred contract for public JSONPath shred names, not only bare top-level names.
query III
SELECT to_json(m), m ->> '$.event_name', (jsono_storage_size(m)).shreds
FROM (
  SELECT jsono_group_merge(j ORDER BY ts) AS m FROM (VALUES
    (jsono('{"event_name":"search","x":1}', shredding := {'$.event_name':'VARCHAR'}), 1),
    (jsono('{"event_name":"page_view"}', shredding := {'$.event_name':'VARCHAR'}), 2)
  ) t(j, ts)
);
----
{"event_name":"page_view","x":1}	page_view	9

# GROUP BY: each group folds independently and reshreds to its own shred value.
query III
SELECT g, to_json(m), m ->> 'k'
FROM (
  SELECT g, jsono_group_merge(j ORDER BY ts) AS m
  FROM (VALUES
    ('a', jsono('{"k":"a1"}', shredding := {'k':'VARCHAR'}), 1),
    ('a', jsono('{"k":"a2","p":1}', shredding := {'k':'VARCHAR'}), 2),
    ('b', jsono('{"k":"b1"}', shredding := {'k':'VARCHAR'}), 1)
  ) t(g, j, ts)
  GROUP BY g
) s
ORDER BY g;
----
a	{"k":"a2","p":1}	a2
b	{"k":"b1"}	b1

# Many groups (> vector size) exercise Finalize across multiple result chunks at nonzero
# offsets; every single-row group must reshred its shred correctly.
query I
SELECT count(*) FROM (
  SELECT g, jsono_group_merge(j) AS m
  FROM (
    SELECT i AS g, jsono('{"k":"v' || i || '"}', shredding := {'k':'VARCHAR'}) AS j
    FROM range(5000) t(i)
  ) GROUP BY g
) WHERE (m ->> 'k') = 'v' || g;
----
5000

# Window finalize: a full-frame merge over an ordered partition reshreds per output row.
query I
SELECT DISTINCT m ->> 'k' FROM (
  SELECT jsono_group_merge(j) OVER (ORDER BY ts ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) AS m
  FROM (VALUES
    (jsono('{"k":"a"}', shredding := {'k':'VARCHAR'}), 1),
    (jsono('{"k":"b"}', shredding := {'k':'VARCHAR'}), 2)
  ) t(j, ts)
);
----
b

# A group whose only value is NULL reshreds to an empty object with a NULL shred.
query III
SELECT to_json(m), m ->> 'k', typeof(m) = jsono_storage_type('k VARCHAR')
FROM (
  SELECT jsono_group_merge(j) AS m FROM (
    SELECT CASE WHEN i > 0 THEN jsono('{"k":"x"}', shredding := {'k':'VARCHAR'}) END AS j
    FROM range(1) t(i)
  )
);
----
{}	NULL	true

# A non-object value replaces the accumulator wholesale; reshredding a scalar yields a
# scalar residual with a NULL shred (still the shredded type).
query III
SELECT to_json(m), m ->> 'k', typeof(m) = jsono_storage_type('k VARCHAR')
FROM (
  SELECT jsono_group_merge(j ORDER BY ts) AS m FROM (VALUES
    (jsono('{"k":"x"}', shredding := {'k':'VARCHAR'}), 1),
    (jsono('5', shredding := {'k':'VARCHAR'}), 2)
  ) t(j, ts)
);
----
5	NULL	true

# A nested-path shred ($.a.b) is reshredded with the same path grammar as public shredding.
query III
SELECT to_json(m), m ->> '$.a.b', (jsono_storage_size(m)).shreds
FROM (
  SELECT jsono_group_merge(j ORDER BY ts) AS m FROM (VALUES
    (jsono('{"a":{"b":1}}', shredding := {'$.a.b':'BIGINT'}), 1),
    (jsono('{"a":{"b":2}}', shredding := {'$.a.b':'BIGINT'}), 2)
  ) t(j, ts)
);
----
{"a":{"b":2}}	2	8

# Shredded group_merge requires the extension optimizer; otherwise core DuckDB can route
# differently-shredded values through generic STRUCT casts before the aggregate sees them.
statement ok
SET disabled_optimizers='extension';

statement error
SELECT
  typeof(m) = jsono_storage_type('event_name VARCHAR'),
  to_json(m::STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB))))
FROM (
  SELECT jsono_group_merge(j ORDER BY ts) AS m FROM (VALUES
    (jsono('{"event_name":"search","x":1}', shredding := {'event_name':'VARCHAR'}), 1),
    (jsono('{"event_name":"page_view"}', shredding := {'event_name':'VARCHAR'}), 2)
  ) t(j, ts)
);
----
requires the extension optimizer

statement ok
RESET disabled_optimizers;

# Regression: plain (non-shredded) input keeps the plain return contract.
query I
SELECT typeof(jsono_group_merge(jsono('{"a":1}'))) = jsono_storage_type();
----
true

# A bare SQLNULL argument keeps the plain return contract (no shreds to stick).
query I
SELECT typeof(jsono_group_merge(NULL)) = jsono_storage_type();
----
true
