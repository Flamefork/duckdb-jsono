# name: test/sql/jsono_struct_constructor.test
# description: Native JSONO construction from STRUCT inputs
# group: [sql]

require jsono

require json

# STRUCT fields become a JSON object with sorted keys. VARCHAR stays a JSON string.
query I
SELECT to_json(jsono({'b': 2, 'a': 'x', 'n': NULL, 'arr': ['c', NULL, 'd']}));
----
{"a":"x","arr":["c",null,"d"],"b":2,"n":null}

# JSON children are parsed as subtrees; VARCHAR children with JSON-looking text stay strings.
query I
SELECT to_json(jsono({'s': '{"x":1}', 'j': '{"b":2,"a":1}'::JSON}));
----
{"j":{"a":1,"b":2},"s":"{\"x\":1}"}

# JSONO children compose without a text round-trip.
query I
SELECT to_json(jsono({'z': 1, 'nested': jsono('{"b":2,"a":1}')}));
----
{"nested":{"a":1,"b":2},"z":1}

# Nested STRUCT and LIST values follow JSON object/array semantics.
query I
SELECT to_json(jsono({'outer': {'b': 2, 'a': [1, NULL, 3]}, 'z': true}));
----
{"outer":{"a":[1,null,3],"b":2},"z":true}

# SQL NULL object fields always serialize as JSON null (lossless; matches core to_json).
query I
SELECT to_json(jsono({'b': NULL, 'a': 1, 'nested': {'x': NULL, 'y': 2}}));
----
{"a":1,"b":null,"nested":{"x":null,"y":2}}

# jsono(STRUCT) uses the same default constructor semantics as the bare STRUCT cast did; an
# INTEGER literal field auto-shreds through the BIGINT promotion.
query II
SELECT typeof(jsono({'a': 1})), to_json(jsono({'b': 2, 'a': 'x'}));
----
STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB), shreds STRUCT("$jsono$set" BIGINT, "$jsono$spill$0" BIGINT, a BIGINT)))	{"a":"x","b":2}

# Top-level NULL STRUCT becomes SQL NULL, matching jsono(NULL).
query I
SELECT jsono(NULL::STRUCT(a INTEGER)) IS NULL;
----
true

# DOUBLE struct fields have no source text, so they materialize through the
# shortest-round-trip double formatter (VAL_EXT/DOUBLE).
query I
SELECT to_json(jsono({'a': 3.5::DOUBLE, 'b': 2.0::DOUBLE, 'c': 0.1::DOUBLE}));
----
{"a":3.5,"b":2.0,"c":0.1}

query I
SELECT to_json(jsono({'big': 1e20::DOUBLE, 'small': 1e-7::DOUBLE, 'neg': -0.0::DOUBLE}));
----
{"big":100000000000000000000.0,"neg":-0.0,"small":1e-7}

# Top-level JSON input remains accepted.
query I
SELECT to_json(jsono('{"b":2,"a":1}'::JSON));
----
{"a":1,"b":2}

# The constructor takes a single STRUCT argument; the former options struct is gone — a second
# argument is only accepted as the named shredding spec.
statement error
SELECT jsono({'a': 1}, {'nulls': 'omit'});
----
pass shredding :=

# Non-finite doubles have no JSON representation and are rejected at construction.
statement error
SELECT jsono({'d': 'inf'::DOUBLE});
----
non-finite

statement error
SELECT jsono({'d': 'nan'::DOUBLE});
----
non-finite

# Exact integer and decimal STRUCT fields preserve their value instead of being
# coerced through BIGINT/DOUBLE: UBIGINT past INT64_MAX used to hard-fail and
# DECIMAL used to lose its exact digits. Construction now matches the parse path.
query I
SELECT to_json(jsono({'u': 18446744073709551615::UBIGINT}));
----
{"u":18446744073709551615}

query I
SELECT to_json(jsono({'u': 42::UBIGINT}));
----
{"u":42}

query I
SELECT to_json(jsono({'d': 123456789012345678901234567890123456.12::DECIMAL(38,2)}));
----
{"d":123456789012345678901234567890123456.12}

query I
SELECT to_json(jsono({'d': 12345.12::DECIMAL(10,2)}));
----
{"d":12345.12}

# Construction matches the text parse path byte-for-byte for the same exact value.
query I
SELECT to_json(jsono({'u': 18446744073709551615::UBIGINT})) = to_json(jsono('{"u":18446744073709551615}'));
----
true

query I
SELECT to_json(jsono({'d': 123456789012345678901234567890123456.12::DECIMAL(38,2)})) = to_json(jsono('{"d":123456789012345678901234567890123456.12}'));
----
true

# Exact types survive inside lists too.
query I
SELECT to_json(jsono({'ids': [1::UBIGINT, 18446744073709551615::UBIGINT]}));
----
{"ids":[1,18446744073709551615]}

# 128-bit integers take the same text classifier path instead of being rejected.
query I
SELECT to_json(jsono({'h': 123::HUGEINT}));
----
{"h":123}

query I
SELECT to_json(jsono({'h': 170141183460469231731687303715884105727::HUGEINT}));
----
{"h":170141183460469231731687303715884105727}

query I
SELECT to_json(jsono({'h': 340282366920938463463374607431768211455::UHUGEINT}));
----
{"h":340282366920938463463374607431768211455}

# The format requires unique sorted object keys (readers binary-search, rank-cache and
# shape_hash on that invariant). An unnamed STRUCT (row(...)) would emit every field under
# the duplicate key "", so it is rejected at bind time. This deliberately diverges from the
# text-parse DOM path, which dedupes duplicate keys last-wins: a parser must accept whatever
# JSON arrives, while struct construction can demand named fields instead of silently
# dropping data. Duplicate *named* fields cannot be built from SQL at all (DuckDB's binder
# rejects them in struct literals, struct_pack, STRUCT type syntax and row references), so
# the unnamed form is the whole reachable surface.
statement error
SELECT jsono(row(1, 2));
----
unnamed

statement error
SELECT jsono(row(42));
----
unnamed

# Nested unnamed structs are rejected through the same recursive plan.
statement error
SELECT jsono({'a': 1, 'b': row(1, 2)});
----
unnamed

# The bare STRUCT -> jsono cast shares the constructor plan and the same guard.
statement error
SELECT row(1, 2)::STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB)));
----
unnamed

# PIN: TRY_CAST between identical JSONO types is elided by the cast registry (equal types bind
# DuckDB's no-op cast before the extension bind is consulted), so it offers no row-level
# corruption recovery: a valid row whose body is NULL (the trace of an unsafe raw struct cast)
# passes through and still fails loud at the first reader. Corrupt storage is never laundered
# into SQL NULL, TRY_CAST or not.
statement error
SELECT jsono_extract_string(TRY_CAST(struct_pack(jsono := struct_pack(body := NULL::STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB))) AS STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB)))), '$.a');
----
corrupt JSONO storage

# A valid (non-NULL) row whose residual blob is NULL is corrupt — the writer nulls the whole
# struct for a NULL value, so this is the trace of a struct cast NULL-filling the row's body.
# The lossless reconstruct cast refuses to invent a value.
statement error
SELECT struct_pack(
        "jsono" := struct_pack(
            body := NULL::STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB),
            shreds := struct_pack(
                "$jsono$set" := NULL::BIGINT,
                "$jsono$spill$0" := 0::BIGINT,
                a := 'v')))::STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB)));
----
body is NULL
