# name: test/sql/jsono_struct_constructor.test
# description: Native JSONO construction from STRUCT inputs
# group: [sql]

require jsono

require json

# STRUCT fields become a JSON object with sorted keys. VARCHAR stays a JSON string.
query I
SELECT to_json(jsono({'b': 2, 'a': 'x', 'n': NULL, 'arr': ['c', NULL, 'd']}));
----
{"a":"x","arr":["c",null,"d"],"b":2,"n":null}

# JSON children are parsed as subtrees; VARCHAR children with JSON-looking text stay strings.
query I
SELECT to_json(jsono({'s': '{"x":1}', 'j': '{"b":2,"a":1}'::JSON}));
----
{"j":{"a":1,"b":2},"s":"{\"x\":1}"}

# JSONO children compose without a text round-trip.
query I
SELECT to_json(jsono({'z': 1, 'nested': jsono('{"b":2,"a":1}')}));
----
{"nested":{"a":1,"b":2},"z":1}

# Nested STRUCT and LIST values follow JSON object/array semantics.
query I
SELECT to_json(jsono({'outer': {'b': 2, 'a': [1, NULL, 3]}, 'z': true}));
----
{"outer":{"a":[1,null,3],"b":2},"z":true}

# SQL NULL object fields always serialize as JSON null (lossless; matches core to_json).
query I
SELECT to_json(jsono({'b': NULL, 'a': 1, 'nested': {'x': NULL, 'y': 2}}));
----
{"a":1,"b":null,"nested":{"x":null,"y":2}}

# jsono(STRUCT) uses the same default constructor semantics as the bare STRUCT cast did.
query II
SELECT typeof(jsono({'a': 1})), to_json(jsono({'b': 2, 'a': 'x'}));
----
STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB)))	{"a":"x","b":2}

# Top-level NULL STRUCT becomes SQL NULL, matching jsono(NULL).
query I
SELECT jsono(NULL::STRUCT(a INTEGER)) IS NULL;
----
true

# DOUBLE struct fields have no source text, so they materialize through the
# shortest-round-trip double formatter (VAL_EXT/DOUBLE).
query I
SELECT to_json(jsono({'a': 3.5::DOUBLE, 'b': 2.0::DOUBLE, 'c': 0.1::DOUBLE}));
----
{"a":3.5,"b":2.0,"c":0.1}

query I
SELECT to_json(jsono({'big': 1e20::DOUBLE, 'small': 1e-7::DOUBLE, 'neg': -0.0::DOUBLE}));
----
{"big":100000000000000000000.0,"neg":-0.0,"small":1e-7}

# Top-level JSON input remains accepted.
query I
SELECT to_json(jsono('{"b":2,"a":1}'::JSON));
----
{"a":1,"b":2}

# The constructor takes a single STRUCT argument; the former options struct is gone — a second
# argument is only accepted as the named shredding spec.
statement error
SELECT jsono({'a': 1}, {'nulls': 'omit'});
----
pass shredding :=

# Non-finite doubles have no JSON representation and are rejected at construction.
statement error
SELECT jsono({'d': 'inf'::DOUBLE});
----
non-finite

statement error
SELECT jsono({'d': 'nan'::DOUBLE});
----
non-finite

# Exact integer and decimal STRUCT fields preserve their value instead of being
# coerced through BIGINT/DOUBLE: UBIGINT past INT64_MAX used to hard-fail and
# DECIMAL used to lose its exact digits. Construction now matches the parse path.
query I
SELECT to_json(jsono({'u': 18446744073709551615::UBIGINT}));
----
{"u":18446744073709551615}

query I
SELECT to_json(jsono({'u': 42::UBIGINT}));
----
{"u":42}

query I
SELECT to_json(jsono({'d': 123456789012345678901234567890123456.12::DECIMAL(38,2)}));
----
{"d":123456789012345678901234567890123456.12}

query I
SELECT to_json(jsono({'d': 12345.12::DECIMAL(10,2)}));
----
{"d":12345.12}

# Construction matches the text parse path byte-for-byte for the same exact value.
query I
SELECT to_json(jsono({'u': 18446744073709551615::UBIGINT})) = to_json(jsono('{"u":18446744073709551615}'));
----
true

query I
SELECT to_json(jsono({'d': 123456789012345678901234567890123456.12::DECIMAL(38,2)})) = to_json(jsono('{"d":123456789012345678901234567890123456.12}'));
----
true

# Exact types survive inside lists too.
query I
SELECT to_json(jsono({'ids': [1::UBIGINT, 18446744073709551615::UBIGINT]}));
----
{"ids":[1,18446744073709551615]}

# 128-bit integers take the same text classifier path instead of being rejected.
query I
SELECT to_json(jsono({'h': 123::HUGEINT}));
----
{"h":123}

query I
SELECT to_json(jsono({'h': 170141183460469231731687303715884105727::HUGEINT}));
----
{"h":170141183460469231731687303715884105727}

query I
SELECT to_json(jsono({'h': 340282366920938463463374607431768211455::UHUGEINT}));
----
{"h":340282366920938463463374607431768211455}

# The format requires unique sorted object keys (readers binary-search, rank-cache and
# shape_hash on that invariant). An unnamed STRUCT (row(...)) would emit every field under
# the duplicate key "", so it is rejected at bind time. This deliberately diverges from the
# text-parse DOM path, which dedupes duplicate keys last-wins: a parser must accept whatever
# JSON arrives, while struct construction can demand named fields instead of silently
# dropping data. Duplicate *named* fields cannot be built from SQL at all (DuckDB's binder
# rejects them in struct literals, struct_pack, STRUCT type syntax and row references), so
# the unnamed form is the whole reachable surface.
statement error
SELECT jsono(row(1, 2));
----
unnamed

statement error
SELECT jsono(row(42));
----
unnamed

# Nested unnamed structs are rejected through the same recursive plan.
statement error
SELECT jsono({'a': 1, 'b': row(1, 2)});
----
unnamed

# The bare STRUCT -> jsono cast shares the constructor plan and the same guard.
statement error
SELECT row(1, 2)::STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB)));
----
unnamed

# PIN: TRY_CAST between identical JSONO types is elided by the cast registry (equal types bind
# DuckDB's no-op cast before the extension bind is consulted), so it offers no row-level
# corruption recovery: a valid row whose body is NULL (the trace of an unsafe raw struct cast)
# passes through and still fails loud at the first reader. Corrupt storage is never laundered
# into SQL NULL, TRY_CAST or not.
statement error
SELECT jsono_extract_string(TRY_CAST(struct_pack(jsono := struct_pack(body := NULL::STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB))) AS STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB)))), '$.a');
----
corrupt JSONO storage

# One-pass shredded write: a NULL shred field stays in the residual as an explicit null
# (NULL shred = "value lives in the residual"), non-NULL shred fields are stripped and
# manifest-covered. Mixed NULL masks per row exercise the partial-strip emit.
query III
SELECT j.jsono."a", j.jsono."k", to_json(j)::VARCHAR
FROM (
    SELECT jsono(struct_pack(a := a, k := k)) AS j
    FROM (VALUES ('x', 1::BIGINT), (NULL, 2::BIGINT), ('z', NULL::BIGINT)) v(a, k)
) ORDER BY ALL;
----
x	1	{"a":"x","k":1}
z	NULL	{"a":"z","k":null}
NULL	2	{"a":null,"k":2}

# A field literally named like a JSONPath keeps the locate-and-strip semantics: the shred
# name parses as the path $.x, which does not exist, so the shred is NULL and the value
# stays in the residual under its literal key.
query II
SELECT j.jsono."$.x" IS NULL, to_json(j)::VARCHAR FROM (SELECT jsono({'$.x': 'v', 'y': 1}) AS j);
----
true	{"$.x":"v","y":1}

# Type-driven auto-shred descends one struct level: top-level scalars keep their bare name, scalars
# directly inside a nested STRUCT are lifted under their $.parent.child JSON path. The shred set is
# a pure function of the input type (known at bind), so the constructor's return type carries them.
query I
SELECT typeof(jsono({'did': 'd1', 'kind': 'k', 'commit': {'collection': 'coll', 'operation': 'create'}}));
----
STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB), "$jsono$vc" UBIGINT, "$.commit.collection" VARCHAR, "$.commit.operation" VARCHAR, did VARCHAR, kind VARCHAR))

# The walk stops after one level: a scalar two or more levels deep stays in the residual (a deep
# schema would otherwise lift many cold leaves). Only $.b.c is shredded; $.b.d.e is not.
query I
SELECT typeof(jsono({'a': 1::BIGINT, 'b': {'c': 'x', 'd': {'e': 'deep'}}}));
----
STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB), "$jsono$vc" UBIGINT, "$.b.c" VARCHAR, a BIGINT))

# Losslessness holds for the un-shredded deep leaf too: $.b.d.e round-trips through the residual.
query I
SELECT to_json(jsono({'a': 1::BIGINT, 'b': {'c': 'x', 'd': {'e': 'deep'}}}))::VARCHAR;
----
{"a":1,"b":{"c":"x","d":{"e":"deep"}}}

# Nested auto-shred is lossless: the reconstructed document equals the plain parse, nesting intact.
query I
SELECT to_json(jsono({'did': 'd1', 'kind': 'k', 'commit': {'collection': 'coll', 'operation': 'create'}}))::VARCHAR;
----
{"commit":{"collection":"coll","operation":"create"},"did":"d1","kind":"k"}

# A nested NULL scalar stays an explicit null in the residual (NULL shred = value-in-residual);
# the typed nested shred captures the present value.
query III
SELECT j.jsono."$.commit.collection", j.jsono."$.commit.n", to_json(j)::VARCHAR
FROM (
    SELECT jsono({'commit': {'collection': c, 'n': n}}) AS j
    FROM (VALUES ('post', 1::BIGINT), (NULL, NULL::BIGINT)) v(c, n)
) ORDER BY ALL;
----
post	1	{"commit":{"collection":"post","n":1}}
NULL	NULL	{"commit":{"collection":null,"n":null}}

# A nested key carrying a path-structural character is emitted as a quoted path step and round-trips.
query I
SELECT to_json(jsono({'nest': {'a.b': 'v', 'c': 'plain'}}))::VARCHAR;
----
{"nest":{"a.b":"v","c":"plain"}}

# A bare top-level $.path read on a nested auto-shred resolves to the typed shred subcolumn (the
# optimizer's transparency rewrite matches the shred by its parsed path, not by field name string).
statement ok
CREATE TABLE nested_shred AS
SELECT jsono({'did': did, 'commit': {'collection': coll}}) AS j
FROM (VALUES ('d1', 'app.bsky.feed.post'), ('d2', 'app.bsky.feed.like'), ('d1', 'app.bsky.feed.post')) v(did, coll);

query II
SELECT j ->> '$.commit.collection' AS c, count(*) FROM nested_shred GROUP BY c ORDER BY c;
----
app.bsky.feed.like	1
app.bsky.feed.post	2

# Shred-name collision: a literal top-level key spelled as a JSON path ('$.commit.collection')
# and a nested scalar lifted to that same path would both want one shred field name. A shredded
# STRUCT cannot carry duplicate children (struct_extract would bind one and make the other value
# unreachable via ->>), so both colliding shreds stay in the residual and the type is plain. The
# residual keeps every value losslessly. (Astronomically rare: a JSON key literally spelled '$.a.b'.)
query I
SELECT typeof(jsono({'$.commit.collection': 'flat', 'commit': {'collection': 'nested'}}));
----
STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB)))

# Both colliding values round-trip through the residual.
query I
SELECT to_json(jsono({'$.commit.collection': 'flat', 'commit': {'collection': 'nested'}}))::VARCHAR;
----
{"$.commit.collection":"flat","commit":{"collection":"nested"}}

# Path resolution stays correct: $.commit.collection resolves the real nested path, while the
# literal top-level key is addressable via its escaped path step.
query II
SELECT j ->> '$.commit.collection' AS path_resolved, j ->> '$."$.commit.collection"' AS literal_key
FROM (SELECT jsono({'$.commit.collection': 'flat', 'commit': {'collection': 'nested'}}) AS j);
----
nested	flat

# A non-colliding sibling next to the collision is still lifted normally: only the two colliding
# names drop to the residual, the unambiguous nested scalar keeps its typed shred.
query I
SELECT typeof(jsono({'$.commit.collection': 'flat', 'commit': {'collection': 'nested', 'operation': 'create'}}));
----
STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB), "$jsono$vc" UBIGINT, "$.commit.operation" VARCHAR))

# Type-driven auto-shred is always value-complete: a shred's type IS its field's type, so a present
# value always fits and a NULL is only an absent field, never a residual diversion. A typed shred
# with absent (NULL) rows is therefore read COALESCE-free — the value-complete fast path that gives
# jsono(struct, shredding) the zone-map pushdown on read-back.
statement ok
CREATE TABLE sc_value_complete AS
SELECT jsono({'x': CASE WHEN i % 3 = 0 THEN NULL ELSE i END :: BIGINT, 'k': 'a'}) AS j
FROM range(3000) tt(i);

statement ok
PRAGMA explain_output='physical_only';

query II
EXPLAIN SELECT MIN(CAST(j->>'$.x' AS BIGINT)) FROM sc_value_complete;
----
physical_plan	<!REGEX>:.*COALESCE.*

statement ok
PRAGMA explain_output='all';

# 2000 of 3000 rows carry $.x (the others are NULL); MIN/MAX over the present integers.
query III
SELECT MIN(CAST(j->>'$.x' AS BIGINT)), MAX(CAST(j->>'$.x' AS BIGINT)), COUNT(CAST(j->>'$.x' AS BIGINT)) FROM sc_value_complete;
----
1	2999	2000
