# name: test/sql/jsono_spill_semantics.test
# description: The $jsono$set / $jsono$spill write discipline: a clean value row stamps the layout hash with a NULL spill, a dirty row the flipped hash with the mask of diverted-shred bits (sorted-name ranks), a SQL-NULL row NULLs both — across the text one-pass writer, the plain-jsono shred writer, the struct constructor and reshred.
# group: [sql]

require jsono

require json

# The per-row classes at one glance, spelled through the text one-pass writer. Shreds sorted by
# clean (no bit); a type-gate miss and a container at the path are spills.
query IIII
SELECT j->>'a' AS a,
       j.jsono.shreds."$jsono$spill" AS spill,
       j.jsono.shreds."$jsono$set" = jsono('{"a":1,"b":2}', shredding := {'a':'BIGINT','$.b':'BIGINT'}).jsono.shreds."$jsono$set" AS clean_marker,
       to_json(j)::VARCHAR AS rt
FROM (
  SELECT i, jsono(d, shredding := {'a':'BIGINT','$.b':'BIGINT'}) AS j FROM (VALUES
    (1, '{"a":1,"b":2}'),      -- both fit: clean
    (2, '{"b":2}'),            -- a absent: clean
    (3, '{"a":null,"b":2}'),   -- a explicit null: clean
    (4, '{"a":"x","b":2}'),    -- a diverts (rank 1): mask 2
    (5, '{"a":{"k":1},"b":2}'),-- a is a container (rank 1): mask 2
    (6, '{"a":1,"b":"x"}'),    -- b diverts (rank 0): mask 1
    (7, '{"a":"x","b":"y"}')   -- both divert: mask 3
  ) t(i, d)
) ORDER BY i;
----
1	NULL	1	{"a":1,"b":2}
NULL	NULL	1	{"b":2}
NULL	NULL	1	{"a":null,"b":2}
x	2	0	{"a":"x","b":2}
{"k":1}	2	0	{"a":{"k":1},"b":2}
1	1	0	{"a":1,"b":"x"}
x	3	0	{"a":"x","b":"y"}

# The dirty marker is exactly the clean hash with its lowest bit flipped.
query I
SELECT xor(d.jsono.shreds."$jsono$set", c.jsono.shreds."$jsono$set")
FROM (SELECT jsono('{"a":"x"}', shredding := {'a':'BIGINT'}) AS d,
             jsono('{"a":1}', shredding := {'a':'BIGINT'}) AS c);
----
1

# A SQL-NULL row NULLs the whole shreds subtree (marker, spill, lanes).
query III
SELECT j IS NULL, j.jsono.shreds."$jsono$set" IS NULL, j.jsono.shreds."$jsono$spill" IS NULL
FROM (SELECT jsono(NULL::VARCHAR, shredding := {'a':'BIGINT'}) AS j);
----
true	true	true

# The plain-jsono shred writer (jsono(jsono, shredding :=)) stamps identically to the text path.
query II
SELECT j.jsono.shreds."$jsono$spill",
       j = jsono('{"a":"x","b":2}', shredding := {'a':'BIGINT','$.b':'BIGINT'})
FROM (SELECT jsono(jsono('{"a":"x","b":2}'), shredding := {'a':'BIGINT','$.b':'BIGINT'}) AS j);
----
2	true

# The struct constructor's auto-shred never diverts: clean marker, NULL spill on every row.
query II
SELECT j.jsono.shreds."$jsono$spill" IS NULL,
       j.jsono.shreds."$jsono$set" IS NOT NULL
FROM (SELECT jsono({'x': 5, 's': 'v'}) AS j);
----
true	true

# Reshred translates a kept shred's spill bit into the target set's rank numbering: the source has
# only `a` (dirty, bit 0); the widened target {a BIGINT, b VARCHAR} carries `a` at rank 0 too, and a
# fresh clean shred `b` — the mask stays 1 and the residual value still reads through the fallback.
query III
SELECT j.jsono.shreds."$jsono$spill", j->>'a', j->>'b'
FROM (SELECT jsono(jsono('{"a":"x","b":"y"}', shredding := {'a':'BIGINT'}),
                   shredding := {'a':'BIGINT','b':'VARCHAR'}) AS j);
----
1	x	y

# Reshred re-numbering when ranks shift: source {z BIGINT} diverts (bit 0 of a 1-shred set);
# target {a VARCHAR, z BIGINT} lists z at rank 1 — the translated mask moves the bit.
query II
SELECT j.jsono.shreds."$jsono$spill", j->>'z'
FROM (SELECT jsono(jsono('{"z":"str","a":"ok"}', shredding := {'z':'BIGINT'}),
                   shredding := {'z':'BIGINT','a':'VARCHAR'}) AS j);
----
2	str

# Dropping the diverted shred cleans the row: the value never left the residual, so the narrowed-set
# reshred is clean (no mask, clean marker).
query II
SELECT j.jsono.shreds."$jsono$spill" IS NULL, j->>'a'
FROM (SELECT jsono(jsono('{"a":"x","b":1}', shredding := {'a':'BIGINT','b':'BIGINT'}),
                   shredding := {'b':'BIGINT'}) AS j);
----
true	x

# Array shreds never set spill bits: a diverted array path (a scalar there) keeps the row clean —
# the lane is NULL and readers always reconstruct arrays from the residual.
query II
SELECT j.jsono.shreds."$jsono$spill" IS NULL, to_json(j)::VARCHAR
FROM (SELECT jsono('{"tags": 7}', shredding := {'tags':'BIGINT[]'}) AS j);
----
true	{"tags":7}

# A set past 63 shreds grows a second spill column ("$jsono$spill1"): the type carries ⌈N/63⌉
# bitmap columns, one bit per shred rank.
query II
SELECT jsono_storage_type('k00 BIGINT, k01 BIGINT, k02 BIGINT, k03 BIGINT, k04 BIGINT, k05 BIGINT, k06 BIGINT, k07 BIGINT, k08 BIGINT, k09 BIGINT, k10 BIGINT, k11 BIGINT, k12 BIGINT, k13 BIGINT, k14 BIGINT, k15 BIGINT, k16 BIGINT, k17 BIGINT, k18 BIGINT, k19 BIGINT, k20 BIGINT, k21 BIGINT, k22 BIGINT, k23 BIGINT, k24 BIGINT, k25 BIGINT, k26 BIGINT, k27 BIGINT, k28 BIGINT, k29 BIGINT, k30 BIGINT, k31 BIGINT, k32 BIGINT, k33 BIGINT, k34 BIGINT, k35 BIGINT, k36 BIGINT, k37 BIGINT, k38 BIGINT, k39 BIGINT, k40 BIGINT, k41 BIGINT, k42 BIGINT, k43 BIGINT, k44 BIGINT, k45 BIGINT, k46 BIGINT, k47 BIGINT, k48 BIGINT, k49 BIGINT, k50 BIGINT, k51 BIGINT, k52 BIGINT, k53 BIGINT, k54 BIGINT, k55 BIGINT, k56 BIGINT, k57 BIGINT, k58 BIGINT, k59 BIGINT, k60 BIGINT, k61 BIGINT, k62 BIGINT, k63 BIGINT') LIKE '%"$jsono$spill1" BIGINT%',
       jsono_storage_type('k00 BIGINT, k01 BIGINT, k02 BIGINT') LIKE '%"$jsono$spill1"%';
----
true	false

# A 64-shred value writes and reads through both spill columns: shred k63 (the highest rank, bit
# 0 of "$jsono$spill1") diverts while k00 (bit 0 of "$jsono$spill") stays clean; the stamp, the
# reads and the validate discipline all hold across the column boundary.
statement ok
CREATE TABLE wide64 AS
SELECT jsono(d, shredding := {'k00':'BIGINT', 'k01':'BIGINT', 'k02':'BIGINT', 'k03':'BIGINT', 'k04':'BIGINT', 'k05':'BIGINT', 'k06':'BIGINT', 'k07':'BIGINT', 'k08':'BIGINT', 'k09':'BIGINT', 'k10':'BIGINT', 'k11':'BIGINT', 'k12':'BIGINT', 'k13':'BIGINT', 'k14':'BIGINT', 'k15':'BIGINT', 'k16':'BIGINT', 'k17':'BIGINT', 'k18':'BIGINT', 'k19':'BIGINT', 'k20':'BIGINT', 'k21':'BIGINT', 'k22':'BIGINT', 'k23':'BIGINT', 'k24':'BIGINT', 'k25':'BIGINT', 'k26':'BIGINT', 'k27':'BIGINT', 'k28':'BIGINT', 'k29':'BIGINT', 'k30':'BIGINT', 'k31':'BIGINT', 'k32':'BIGINT', 'k33':'BIGINT', 'k34':'BIGINT', 'k35':'BIGINT', 'k36':'BIGINT', 'k37':'BIGINT', 'k38':'BIGINT', 'k39':'BIGINT', 'k40':'BIGINT', 'k41':'BIGINT', 'k42':'BIGINT', 'k43':'BIGINT', 'k44':'BIGINT', 'k45':'BIGINT', 'k46':'BIGINT', 'k47':'BIGINT', 'k48':'BIGINT', 'k49':'BIGINT', 'k50':'BIGINT', 'k51':'BIGINT', 'k52':'BIGINT', 'k53':'BIGINT', 'k54':'BIGINT', 'k55':'BIGINT', 'k56':'BIGINT', 'k57':'BIGINT', 'k58':'BIGINT', 'k59':'BIGINT', 'k60':'BIGINT', 'k61':'BIGINT', 'k62':'BIGINT', 'k63':'BIGINT'}) AS j
FROM (VALUES ('{"k00": 7}'), ('{"k00": 7, "k63": "oops"}')) t(d);

query IIIII
SELECT j.jsono.shreds."$jsono$spill", j.jsono.shreds."$jsono$spill1", j->>'k00', j->>'k63', jsono_validate(j)
FROM wide64 ORDER BY 3, 4;
----
0	1	7	oops	1
NULL	NULL	7	NULL	1


require parquet

# The uniform dirty-mask quarantine survives a Parquet round-trip: rows where `n` diverts stamp the
# dirty marker with mask bit(n); the clean rows stamp the clean marker with NULL spill. The scan's
# marker min/max stay within the {clean, dirty} pair and the spill min==max decodes exactly, so the
# unrelated `$.URL.scheme` lane reads COALESCE-free off Parquet while `n` keeps its fallback.
statement ok
COPY (
  SELECT jsono(
    '{"URL":{"scheme":"' || (CASE WHEN i % 3 = 0 THEN 'goal' ELSE 'https' END) || '"}, "n": ' ||
    (CASE WHEN i % 100 = 8 THEN '"oops"' ELSE i::VARCHAR END) || '}',
    shredding := {'$.URL.scheme':'VARCHAR','n':'BIGINT'}) AS j
  FROM range(2000) tt(i)
) TO '__TEST_DIR__/spill_quarantine.parquet' (FORMAT parquet);

statement ok
PRAGMA explain_output='physical_only';

query II
EXPLAIN SELECT count(*) FROM read_parquet('__TEST_DIR__/spill_quarantine.parquet') WHERE j->>'$.URL.scheme' = 'goal';
----
physical_plan	<!REGEX>:.*COALESCE.*

query II
EXPLAIN SELECT MIN(TRY_CAST(j->>'n' AS BIGINT)) FROM read_parquet('__TEST_DIR__/spill_quarantine.parquet');
----
physical_plan	<REGEX>:.*COALESCE.*

statement ok
PRAGMA explain_output='all';

query III
SELECT count(*) FILTER (j->>'$.URL.scheme' = 'goal'),
       MIN(TRY_CAST(j->>'n' AS BIGINT)),
       count(*) FILTER (j->>'n' = 'oops')
FROM read_parquet('__TEST_DIR__/spill_quarantine.parquet');
----
667	0	20

# jsono_validate enforces the spill discipline: honest values pass; a forged mask on a clean-marker
# row, a hidden divert with a clean bit, and an out-of-domain mask are all invalid.
query IIII
SELECT jsono_validate(jsono('{"a":1}', shredding := {'a':'BIGINT'})),
       jsono_validate(jsono('{"a":"x"}', shredding := {'a':'BIGINT'})),
       jsono_validate(jsono('{"b":2}', shredding := {'a':'BIGINT'})),
       jsono_validate(jsono('{"a":null}', shredding := {'a':'BIGINT'}));
----
true	true	true	true

# Forged: clean marker but a mask present.
query I
SELECT jsono_validate(struct_pack(jsono := struct_pack(
  body := c.jsono.body,
  shreds := struct_pack(
    "$jsono$set" := c.jsono.shreds."$jsono$set",
    "$jsono$spill" := 1::BIGINT,
    a := c.jsono.shreds.a
  )))::STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB), shreds STRUCT("$jsono$set" BIGINT, "$jsono$spill" BIGINT, a BIGINT))))
FROM (SELECT jsono('{"a":1}', shredding := {'a':'BIGINT'}) AS c);
----
false

# Forged: dirty row whose mask is out of domain (bit 5 with one shred).
query I
SELECT jsono_validate(struct_pack(jsono := struct_pack(
  body := d.jsono.body,
  shreds := struct_pack(
    "$jsono$set" := d.jsono.shreds."$jsono$set",
    "$jsono$spill" := 32::BIGINT,
    a := d.jsono.shreds.a
  )))::STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB), shreds STRUCT("$jsono$set" BIGINT, "$jsono$spill" BIGINT, a BIGINT))))
FROM (SELECT jsono('{"a":"oops"}', shredding := {'a':'BIGINT'}) AS d);
----
false

# Forged: a desynced lane (set lane while the residual still holds the path) is invalid — a set
# lane must mean the path was stripped.
query I
SELECT jsono_validate(struct_pack(jsono := struct_pack(
  body := jsono('{"a":1}')."jsono".body,
  shreds := struct_pack(
    "$jsono$set" := c.jsono.shreds."$jsono$set",
    "$jsono$spill" := NULL::BIGINT,
    a := 999::BIGINT
  )))::STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB), shreds STRUCT("$jsono$set" BIGINT, "$jsono$spill" BIGINT, a BIGINT))))
FROM (SELECT jsono('{"a":1}', shredding := {'a':'BIGINT'}) AS c);
----
false
