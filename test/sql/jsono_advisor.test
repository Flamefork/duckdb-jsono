# name: test/sql/jsono_advisor.test
# description: jsono_suggest_shredding + jsono_shred_stats — the shredding advisor aggregates
# group: [sql]

require jsono

# jsono_shred_stats renders its LIST<STRUCT> result through core json's to_json(ANY).
require json

# ---- jsono_suggest_shredding: suggest a shredding spec from a plain jsono corpus ----

statement ok
CREATE TABLE docs AS SELECT jsono(d) AS j FROM (VALUES
  ('{"stable_int":1,"stable_str":"a","ratio":1.5,"flag":true,"meta":{"nested_int":10},"tags":[1,2,3],"items":[{"n":1,"s":"x"}],"sparse":99,"mixed":1}'),
  ('{"stable_int":2,"stable_str":"b","ratio":2.5,"flag":false,"meta":{"nested_int":20},"tags":[4,5],"items":[{"n":2,"s":"y"}],"mixed":2}'),
  ('{"stable_int":3,"stable_str":"c","ratio":3.5,"flag":true,"meta":{"nested_int":30},"tags":[6],"items":[{"n":3,"s":"z"}],"mixed":"text"}'),
  ('{"stable_int":4,"stable_str":"d","ratio":4.5,"flag":false,"meta":{"nested_int":40},"tags":[],"items":[],"mixed":"text"}')
) AS t(d);

# Default min_presence=0.5, min_fit=1.0. Stable typed fields, a nested scalar ($.meta.nested_int),
# an object array (items) and a scalar array (tags) are lifted; the sparse field (1/4 rows) drops
# below min_presence, the mixed-type field (BIGINT half, VARCHAR half) fits no single lane, and the
# decimal `ratio` field fits no typed lane either (JSON decimals never lift losslessly into a scalar
# lane — the strip gate is JsonoScalarFitsPrimitive, so they stay in the residual).
query I
SELECT jsono_suggest_shredding(j) FROM docs;
----
{"$.meta.nested_int": 'BIGINT', flag: 'BOOLEAN', items: 'STRUCT(n BIGINT, s VARCHAR)[]', stable_int: 'BIGINT', stable_str: 'VARCHAR', tags: 'BIGINT[]'}

# The suggested literal is ready-to-paste: feeding it back into jsono(doc, shredding := ...) binds
# and round-trips the document (proves the spec syntax and every type string parse).
query I
SELECT to_json(jsono('{"stable_int":1,"stable_str":"a","flag":true,"meta":{"nested_int":10},"tags":[1,2,3],"items":[{"n":1,"s":"x"}]}',
  shredding := {"$.meta.nested_int": 'BIGINT', flag: 'BOOLEAN', items: 'STRUCT(n BIGINT, s VARCHAR)[]', stable_int: 'BIGINT', stable_str: 'VARCHAR', tags: 'BIGINT[]'}));
----
{"flag":true,"items":[{"n":1,"s":"x"}],"meta":{"nested_int":10},"stable_int":1,"stable_str":"a","tags":[1,2,3]}

# Lowering min_fit to 0.5 accepts the mixed field at the majority lane (BIGINT fits 2/4 >= 0.5,
# first in the BIGINT > DOUBLE > BOOLEAN > VARCHAR preference order).
query I
SELECT jsono_suggest_shredding(j, min_fit := 0.5) FROM docs;
----
{"$.meta.nested_int": 'BIGINT', flag: 'BOOLEAN', items: 'STRUCT(n BIGINT, s VARCHAR)[]', mixed: 'BIGINT', stable_int: 'BIGINT', stable_str: 'VARCHAR', tags: 'BIGINT[]'}

# Lowering min_presence to 0.25 keeps the sparse field (present in 1/4 rows).
query I
SELECT jsono_suggest_shredding(j, min_presence := 0.25) FROM docs;
----
{"$.meta.nested_int": 'BIGINT', flag: 'BOOLEAN', items: 'STRUCT(n BIGINT, s VARCHAR)[]', sparse: 'BIGINT', stable_int: 'BIGINT', stable_str: 'VARCHAR', tags: 'BIGINT[]'}

# UBIGINT is preferred over BIGINT only when a value exceeds the int64 range.
query I
SELECT jsono_suggest_shredding(jsono(d)) FROM (VALUES
  ('{"big":18446744073709551615}'),
  ('{"big":10000000000000000000}')
) AS t(d);
----
{big: 'UBIGINT'}

# The DOUBLE lane is reachable only from a real Double-kind scalar: the text parser yields JSON
# decimals (which never fit a scalar lane), so DOUBLE needs a value ingested as a struct DOUBLE. A
# struct-ingested doc reconstructed back to PLAIN jsono keeps the Double kind, and the advisor picks
# the DOUBLE lane over it (BIGINT/UBIGINT do not fit a non-integral double).
statement ok
CREATE TABLE double_docs AS
SELECT CAST(jsono({'v': v}) AS
  STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB)))
) AS j
FROM (VALUES (1.5::DOUBLE), (2.5::DOUBLE), (3.5::DOUBLE)) AS t(v);

query I
SELECT jsono_suggest_shredding(j) FROM double_docs;
----
{v: 'DOUBLE'}

# The suggested DOUBLE spec is ready-to-paste over the plain (Double-carrying) value: the shred type
# is a DOUBLE lane and the shredded value round-trips losslessly (the lane fits, so nothing diverts).
query I
SELECT count(*) FROM double_docs
WHERE to_json(jsono(j, shredding := {v: 'DOUBLE'})) IS DISTINCT FROM to_json(j)
   OR typeof(jsono(j, shredding := {v: 'DOUBLE'})) <> jsono_storage_type('v DOUBLE');
----
0

# An explicit JSON null is lossless in every lane (it stays complete in the residual), so it counts
# as fitting any type and does NOT drop a path at the default min_fit := 1.0. A scalar leaf that is
# int in some rows and null in others is still suggested at its int lane.
query I
SELECT jsono_suggest_shredding(jsono(d)) FROM (VALUES
  ('{"k":1}'),
  ('{"k":2}'),
  ('{"k":null}')
) AS t(d);
----
{k: 'BIGINT'}

# Same lossless-null rule for a scalar array: a null element never disqualifies the element lane
# (the writer keeps it verbatim in the residual skeleton), so tags stays BIGINT[] at min_fit := 1.0.
query I
SELECT jsono_suggest_shredding(jsono(d)) FROM (VALUES
  ('{"tags":[1,null,2]}'),
  ('{"tags":[3,4]}')
) AS t(d);
----
{tags: 'BIGINT[]'}

# And for an object-array subfield: a null subfield value counts as fitting its element lane, so the
# object array is still lifted with the typed subfield at min_fit := 1.0.
query I
SELECT jsono_suggest_shredding(jsono(d)) FROM (VALUES
  ('{"items":[{"n":1},{"n":null}]}'),
  ('{"items":[{"n":2}]}')
) AS t(d);
----
{items: 'STRUCT(n BIGINT)[]'}

# A path seen as a scalar in some rows and an array in others is genuinely mixed. min_fit is measured
# over the path's TOTAL present rows (scalar + array), so at the default min_fit := 1.0 neither role
# covers every present value: the path drops and, being the only path, the whole spec is SQL NULL.
query I
SELECT jsono_suggest_shredding(jsono(d)) FROM (VALUES
  ('{"p":1}'),
  ('{"p":2}'),
  ('{"p":[1,2]}'),
  ('{"p":[3,4]}')
) AS t(d);
----
NULL

# Lowering min_fit surfaces the majority role: 3 scalar rows and 1 array row make the scalar lane fit
# 3/4 present values, clearing min_fit := 0.75 and winning over the array lane (1/4).
query I
SELECT jsono_suggest_shredding(jsono(d), min_fit := 0.75) FROM (VALUES
  ('{"p":1}'),
  ('{"p":2}'),
  ('{"p":3}'),
  ('{"p":[1,2]}')
) AS t(d);
----
{p: 'BIGINT'}

# A path that is a scalar in some rows and an OBJECT in others is genuinely mixed. The object
# occurrences count into the path's total_present (the min_fit denominator) but feed no scalar role,
# so at min_fit := 1.0 the VARCHAR lane fits only 2/4 present rows and `meta` drops — only the nested
# $.meta.n candidate (a real scalar leaf under the two object rows) survives.
query I
SELECT jsono_suggest_shredding(jsono(d)) FROM (VALUES
  ('{"meta":"s1"}'),
  ('{"meta":"s2"}'),
  ('{"meta":{"n":1}}'),
  ('{"meta":{"n":2}}')
) AS t(d);
----
{"$.meta.n": 'BIGINT'}

# Lowering min_fit to 0.5 surfaces the majority VARCHAR (2/4 scalar rows clear the threshold) beside
# the nested candidate. The overlapping pair (a shred inside another shred's path) stays ready-to-
# paste — the constructor accepts the nested shred (the container lane becomes render-unsafe) and the
# shredded value round-trips losslessly.
query I
SELECT jsono_suggest_shredding(jsono(d), min_fit := 0.5) FROM (VALUES
  ('{"meta":"s1"}'),
  ('{"meta":"s2"}'),
  ('{"meta":{"n":1}}'),
  ('{"meta":{"n":2}}')
) AS t(d);
----
{"$.meta.n": 'BIGINT', meta: 'VARCHAR'}

query I
SELECT count(*) FROM (
  SELECT to_json(jsono(d, shredding := {'$.meta.n':'BIGINT', meta:'VARCHAR'})) AS s,
         to_json(jsono(d)) AS p
  FROM (VALUES ('{"meta":"s1"}'), ('{"meta":"s2"}'), ('{"meta":{"n":1}}'), ('{"meta":{"n":2}}')) t(d)
) WHERE s IS DISTINCT FROM p;
----
0

# A corpus of only non-object root documents (scalars and arrays) names no key to shred: every
# document is skipped at the OBJ_START gate, so no candidate is ever recorded and the result is NULL.
query I
SELECT jsono_suggest_shredding(jsono(d)) FROM (VALUES
  ('5'),
  ('"str"'),
  ('[1,2,3]'),
  ('true')
) AS t(d);
----
NULL

# No qualifying paths (or no non-NULL rows) yields SQL NULL.
query I
SELECT jsono_suggest_shredding(j) FROM docs WHERE false;
----
NULL

# ---- jsono_suggest_shredding: input validation ----

# Named args reach the bind validator (SPECIAL_HANDLING): a NULL constant is rejected loud.
statement error
SELECT jsono_suggest_shredding(j, min_fit := NULL) FROM docs;
----
must not be NULL

statement error
SELECT jsono_suggest_shredding(j, min_fit := 2.0) FROM docs;
----
min_fit

statement error
SELECT jsono_suggest_shredding(j, min_presence := -0.1) FROM docs;
----
min_presence

# A non-constant threshold cannot be evaluated at bind, so it is rejected loud instead of silently
# picking a row's value (random() is volatile and does not fold to a constant).
statement error
SELECT jsono_suggest_shredding(j, min_fit := random()) FROM docs;
----
must be constant

statement error
SELECT jsono_suggest_shredding(j, min_presence := random()) FROM docs;
----
must be constant

statement error
SELECT jsono_suggest_shredding(j, bogus := 0.5) FROM docs;
----
unknown argument

# A shredded column must be re-suggested from its plain source, not from the shredded form.
statement error
SELECT jsono_suggest_shredding(jsono('{"a":1}', shredding := {'a':'BIGINT'}));
----
plain

# Exceeding the distinct-path cap fails loud instead of silently truncating.
statement error
SELECT jsono_suggest_shredding(j) FROM (
  SELECT jsono('{' || string_agg('"k' || i || '":' || i, ',') || '}') AS j FROM range(8193) AS t(i)
);
----
8192

# ---- spec keys that need quoting or path-form naming ----

# Non-identifier keys are double-quoted with embedded quotes doubled (SQL identifier escaping);
# a key the spec parser would misread as a JSONPath (`$`-leading) or reject as a reserved layout
# name (`body`) is spelled through its quoted `$.`-rooted path form. Every emitted key must
# re-parse when the spec is pasted back into jsono(value, shredding := ...).
query I
SELECT jsono_suggest_shredding(jsono('{"a\"b":1,"a\\b":2,"a.b":3,"with space":4,"$x":5,"body":6}'));
----
{"$.$x": 'BIGINT', "$.body": 'BIGINT', "a""b": 'BIGINT', "a.b": 'BIGINT', "a\b": 'BIGINT', "with space": 'BIGINT'}

query I
SELECT count(*) FROM (
  SELECT to_json(jsono(d, shredding := {"$.$x": 'BIGINT', "$.body": 'BIGINT', "a""b": 'BIGINT', "a.b": 'BIGINT', "a\b": 'BIGINT', "with space": 'BIGINT'})) AS s,
         to_json(jsono(d)) AS p
  FROM (VALUES ('{"a\"b":1,"a\\b":2,"a.b":3,"with space":4,"$x":5,"body":6}')) t(d)
) WHERE s IS DISTINCT FROM p;
----
0

# A nested key with an embedded quote is JSONPath-quoted first (backslash escaping inside the
# path step), then SQL-quoted as a struct key (quote doubling) — two distinct escaping layers.
query I
SELECT jsono_suggest_shredding(jsono('{"m":{"q\"uote":1}}'));
----
{"$.m.""q\""uote""": 'BIGINT'}

query I
SELECT count(*) FROM (
  SELECT to_json(jsono(d, shredding := {"$.m.""q\""uote""": 'BIGINT'})) AS s,
         to_json(jsono(d)) AS p
  FROM (VALUES ('{"m":{"q\"uote":1}}')) t(d)
) WHERE s IS DISTINCT FROM p;
----
0

# An object-array subfield name is a STRUCT field identifier in the type string — same doubling.
query I
SELECT jsono_suggest_shredding(jsono('{"arr":[{"a\"b":1}]}'));
----
{arr: 'STRUCT("a""b" BIGINT)[]'}

query I
SELECT count(*) FROM (
  SELECT to_json(jsono(d, shredding := {arr: 'STRUCT("a""b" BIGINT)[]'})) AS s,
         to_json(jsono(d)) AS p
  FROM (VALUES ('{"arr":[{"a\"b":1}]}')) t(d)
) WHERE s IS DISTINCT FROM p;
----
0

# Empty keys (at any level) are out of the shred universe — their lane name would carry an empty
# quoted path step, which the shredded readers do not support — so they are never suggested.
query I
SELECT jsono_suggest_shredding(jsono(d)) FROM (VALUES
  ('{"":1}'),
  ('{"m":{"":2}}'),
  ('{"arr":[{"":3}]}')
) AS t(d);
----
NULL

# An empty subfield is skipped without dropping the sibling that qualifies.
query I
SELECT jsono_suggest_shredding(jsono('{"arr":[{"":1,"n":2}]}'));
----
{arr: 'STRUCT(n BIGINT)[]'}

# ---- jsono_shred_stats: per-shred lane / divert / complete rates over shredded input ----

statement ok
CREATE TABLE shredded AS SELECT jsono(d, shredding := {'a':'BIGINT'}) AS j FROM (VALUES
  ('{"a":5,"b":1}'),
  ('{"a":"x"}'),
  ('{"b":2}'),
  ('{"a":7}')
) AS t(d);

# path a: lane present in 2/4 (fitting ints), diverted in 1/4 (the string "x" stays in the residual),
# complete in 3/4 (a fit, an absent path, and another fit — only the divert is incomplete).
query I
SELECT to_json(jsono_shred_stats(j)) FROM shredded;
----
[{"path":"a","type":"BIGINT","lane_rate":0.5,"divert_rate":0.25,"complete_rate":0.75}]

# An array shred reports complete_rate 1.0 (array shreds carry no completeness flag); tags is
# present as a lane in 1/2 rows and never diverted (its only absence is a missing key).
query I
SELECT to_json(jsono_shred_stats(j)) FROM (
  SELECT jsono(d, shredding := {'tags':'BIGINT[]'}) AS j FROM (VALUES
    ('{"tags":[1,2]}'),
    ('{"x":1}')
  ) AS t(d)
);
----
[{"path":"tags","type":"BIGINT[]","lane_rate":0.5,"divert_rate":0.0,"complete_rate":1.0}]

# An array shred DIVERTS when the value at its path does not fit the element lane (a scalar there
# stays whole in the residual): lane NULL plus a residual hit counts as a divert, unlike the
# missing key above.
query I
SELECT to_json(jsono_shred_stats(j)) FROM (
  SELECT jsono(d, shredding := {'tags':'BIGINT[]'}) AS j FROM (VALUES
    ('{"tags":[1,2]}'),
    ('{"tags":"oops"}')
  ) AS t(d)
);
----
[{"path":"tags","type":"BIGINT[]","lane_rate":0.5,"divert_rate":0.5,"complete_rate":1.0}]

# An object-array shred (LIST<STRUCT> lane) reports lane / divert / complete the same way the scalar
# array does: lane present when the value is a regular array (2/4 here), diverted when a scalar sits
# at the path and stays whole in the residual (1/4), a missing key is neither (1/4), and array shreds
# carry no completeness flag so complete_rate is always 1.0.
query I
SELECT to_json(jsono_shred_stats(j)) FROM (
  SELECT jsono(d, shredding := {'items':'STRUCT(n BIGINT)[]'}) AS j FROM (VALUES
    ('{"items":[{"n":1},{"n":2}]}'),
    ('{"items":"oops"}'),
    ('{"x":1}'),
    ('{"items":[{"n":3}]}')
  ) AS t(d)
);
----
[{"path":"items","type":"STRUCT(n BIGINT)[]","lane_rate":0.5,"divert_rate":0.25,"complete_rate":1.0}]

# Multiple shreds report in sorted path order.
query I
SELECT to_json(jsono_shred_stats(j)) FROM (
  SELECT jsono(d, shredding := {'a':'BIGINT','name':'VARCHAR'}) AS j FROM (VALUES
    ('{"a":1,"name":"x"}'),
    ('{"a":2,"name":"y"}')
  ) AS t(d)
);
----
[{"path":"a","type":"BIGINT","lane_rate":1.0,"divert_rate":0.0,"complete_rate":1.0},{"path":"name","type":"VARCHAR","lane_rate":1.0,"divert_rate":0.0,"complete_rate":1.0}]

# An explicit JSON null keeps a complete NULL lane (it reads back as `->>` NULL) and lives in the
# residual as null — it is NOT a divert. Here row `null` counts toward complete_rate but not
# divert_rate, while the string "x" (a real type-too-narrow divert) counts divert but not complete.
query I
SELECT to_json(jsono_shred_stats(j)) FROM (
  SELECT jsono(d, shredding := {'k':'BIGINT'}) AS j FROM (VALUES
    ('{"k":1}'),
    ('{"k":null}'),
    ('{"k":"x"}'),
    ('{"k":4}')
  ) AS t(d)
);
----
[{"path":"k","type":"BIGINT","lane_rate":0.5,"divert_rate":0.25,"complete_rate":0.75}]

# All-NULL (no non-NULL rows) yields SQL NULL.
query I
SELECT jsono_shred_stats(j) FROM shredded WHERE false;
----
NULL

# Plain (non-shredded) input is rejected loud — that is jsono_suggest_shredding's job.
statement error
SELECT jsono_shred_stats(jsono('{"a":1}'));
----
shredded

# A nested-path shred ($.m.deep): a fit populates the lane; a diverted string stays in the residual
# under the full path (a real divert); a row where m is a scalar breaks the path's object skeleton
# (the path is absent — complete, no divert), like a missing key.
query I
SELECT to_json(jsono_shred_stats(j)) FROM (
  SELECT jsono(d, shredding := {'$.m.deep':'BIGINT'}) AS j FROM (VALUES
    ('{"m":{"deep":1}}'),
    ('{"m":{"deep":"x"}}'),
    ('{"m":5}'),
    ('{"x":1}')
  ) AS t(d)
);
----
[{"path":"$.m.deep","type":"BIGINT","lane_rate":0.25,"divert_rate":0.25,"complete_rate":0.75}]

# A spec key that begins with `$` but is not a `$.`-rooted JSONPath is rejected loudly by the
# constructor (the spec DSL reserves the `$` prefix for JSONPath), so no literal `$`-prefixed
# shred name ever reaches the stats path classifier.
statement error
SELECT jsono('{"$x":1}', shredding := {'$x':'BIGINT'});
----
invalid path

# jsono_shred_stats is a whole-document reader: a row narrowed by a raw struct cast (the dropped
# shred still named by the residual manifest) fails loud like every other reader instead of
# reporting plausible rates over the loss. Contract owner: jsono_shredded_cast_guard.test.
statement ok
CREATE TABLE stats_wide AS
  SELECT jsono('{"a":1,"b":"x"}', shredding := {'a':'BIGINT','b':'VARCHAR'}) AS j;

statement ok
CREATE TABLE stats_narrow AS
  SELECT jsono('{"a":1}', shredding := {'a':'BIGINT'}) AS j WHERE 1=0;

statement ok
SET disabled_optimizers='extension';

statement ok
INSERT INTO stats_narrow SELECT j FROM stats_wide;

statement ok
RESET disabled_optimizers;

statement error
SELECT jsono_shred_stats(j) FROM stats_narrow;
----
narrowed by a raw struct cast

# ---- named-argument and cap edges ----

# A duplicate named argument is rejected loud instead of silently keeping the last value.
statement error
SELECT jsono_suggest_shredding(j, min_fit := 1.0, min_fit := 0.5) FROM docs;
----
duplicate argument

# Exceeding the object-array subfield cap fails loud instead of silently truncating the STRUCT spec.
statement error
SELECT jsono_suggest_shredding(j) FROM (
  SELECT jsono('{"arr":[{' || string_agg('"s' || i || '":1', ',') || '}]}') AS j FROM range(8193) AS t(i)
);
----
subfield

# ---- plan (de)serialization ----

# The named thresholds survive a plan (de)serialize round-trip through the custom serialize
# callbacks — a deserialize-side re-bind would see plain arguments with the := aliases stripped
# and reject them. The result must reflect BOTH non-default thresholds.
statement ok
PRAGMA verify_serializer;

query I
SELECT jsono_suggest_shredding(j, min_presence := 0.25, min_fit := 0.5) FROM docs;
----
{"$.meta.nested_int": 'BIGINT', flag: 'BOOLEAN', items: 'STRUCT(n BIGINT, s VARCHAR)[]', mixed: 'BIGINT', sparse: 'BIGINT', stable_int: 'BIGINT', stable_str: 'VARCHAR', tags: 'BIGINT[]'}

statement ok
PRAGMA disable_verify_serializer;

# ---- Parquet round-trip: both advisor aggregates read the physical vector shapes Parquet produces
#      (blob children, per-column null masks) rather than the in-memory constructor's vectors, and
#      must yield the identical suggestion / stats. Asserted by equality with the in-memory result. ----

require parquet

statement ok
COPY docs TO '__TEST_DIR__/jsono_advisor_docs.parquet' (FORMAT parquet);

# jsono_suggest_shredding over the Parquet-backed plain corpus equals the in-memory suggestion.
query I
SELECT jsono_suggest_shredding(j) = (SELECT jsono_suggest_shredding(j) FROM docs)
FROM read_parquet('__TEST_DIR__/jsono_advisor_docs.parquet');
----
true

statement ok
COPY shredded TO '__TEST_DIR__/jsono_advisor_shredded.parquet' (FORMAT parquet);

# jsono_shred_stats over the Parquet-backed shredded column equals the in-memory stats.
query I
SELECT to_json(jsono_shred_stats(j)) = (SELECT to_json(jsono_shred_stats(j)) FROM shredded)
FROM read_parquet('__TEST_DIR__/jsono_advisor_shredded.parquet');
----
true
