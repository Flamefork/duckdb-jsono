# name: test/sql/jsono_array_length.test
# description: jsono_array_length returns the element count of the array at the root or at a path
# group: [sql]

require jsono

require json

# Root array: element count, including the empty array.
query III
SELECT jsono_array_length(jsono('[10,20,30]')), jsono_array_length(jsono('[]')), jsono_array_length(jsono('[1]'));
----
3	0	1

# Nested and mixed elements are each counted once regardless of their own shape.
query II
SELECT jsono_array_length(jsono('[[1,2],[3],[]]')), jsono_array_length(jsono('[1,{"a":1},[2,3],"x",null]'));
----
3	5

# Path overload: VARCHAR JSONPath into nested arrays, including a bracketed array index.
query III
SELECT
  jsono_array_length(jsono('{"items":[1,2,3,4]}'), '$.items'),
  jsono_array_length(jsono('{"a":{"b":[9]}}'), '$.a.b'),
  jsono_array_length(jsono('{"x":[[1,2,3],[4,5]]}'), '$.x[0]');
----
4	1	3

# Non-array roots (object, scalar, string) and JSON null → NULL.
query IIII
SELECT
  jsono_array_length(jsono('{"a":1}')),
  jsono_array_length(jsono('42')),
  jsono_array_length(jsono('"hello"')),
  jsono_array_length(jsono('null'));
----
NULL	NULL	NULL	NULL

# Path to a non-array value → NULL; missing path → NULL; out-of-range index → NULL.
query III
SELECT
  jsono_array_length(jsono('{"a":1}'), '$.a'),
  jsono_array_length(jsono('{"a":[1,2]}'), '$.missing'),
  jsono_array_length(jsono('{"x":[1,2,3]}'), '$.x[9]');
----
NULL	NULL	NULL

# SQL NULL input → NULL, with and without a path.
query II
SELECT jsono_array_length(NULL), jsono_array_length(NULL, '$.a');
----
NULL	NULL

# Non-JSONO argument is rejected loudly.
statement error
SELECT jsono_array_length('foo');
----
jsono_array_length: argument must be JSONO

# Shredded round-trip: a value that shreds one scalar path ($.a) still answers array_length for an
# array left in the residual, counted off the reconstructed document (array_length keeps the full
# reconstruct-cast). The 1-arg call on the object root stays NULL.
statement ok
CREATE TABLE t AS SELECT jsono('{"a":1,"items":[7,8,9]}', shredding := {'$.a':'BIGINT'}) AS j;

query II
SELECT jsono_array_length(j, '$.items'), jsono_array_length(j) FROM t;
----
3	NULL

# A stored root array answers its length through the whole-document 1-arg overload.
statement ok
CREATE TABLE arr AS SELECT jsono('[1,2,3,4,5]') AS j;

query I
SELECT jsono_array_length(j) FROM arr;
----
5
