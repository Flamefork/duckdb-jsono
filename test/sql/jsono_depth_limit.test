# name: test/sql/jsono_depth_limit.test
# description: JSONO bounds nesting depth instead of overflowing the stack on deep input
# group: [sql]

require jsono

# Moderately deep nesting (under the limit) round-trips through parse and to_json.
query I
SELECT to_json(jsono(repeat('[', 30) || repeat(']', 30))) IS NOT NULL;
----
true

# Array nesting beyond the limit is rejected at construction, not crashed.
statement error
SELECT jsono(repeat('[', 1001) || repeat(']', 1001));
----
nesting depth exceeds maximum

# Object nesting beyond the limit is rejected the same way.
statement error
SELECT jsono(repeat('{"a":', 1001) || '1' || repeat('}', 1001));
----
nesting depth exceeds maximum
