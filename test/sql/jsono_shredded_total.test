# name: test/sql/jsono_shredded_total.test
# description: COALESCE-free typed-shred read when column statistics prove the shred total (no residual rows)
# group: [sql]

require jsono

require json

# A homogeneous BIGINT shred: every row's $.x fits the shred type, so no row falls into the residual.
# The base-table null statistics then prove the shred carries no NULL, and the optimizer emits a bare
# struct_extract with no residual COALESCE fallback.
statement ok
CREATE TABLE total_t AS
SELECT jsono('{"x": ' || (i * 2)::VARCHAR || ', "k":"a"}', shredding := {'$.x':'BIGINT'}) AS j
FROM range(2000) tt(i);

statement ok
PRAGMA explain_output='physical_only';

# (a) total shred: the typed read has no COALESCE and the scan projects only the shred column.
query II
EXPLAIN SELECT MIN(CAST(j->>'$.x' AS BIGINT)) FROM total_t;
----
physical_plan	<!REGEX>:.*COALESCE.*

query II
EXPLAIN SELECT MIN(CAST(j->>'$.x' AS BIGINT)) FROM total_t;
----
physical_plan	<REGEX>:.*\$\.x.*

# A selective equality filter on the total shred is pushed into the scan as a struct_extract filter
# (zone-map prunable), not a post-scan COALESCE evaluation.
query II
EXPLAIN SELECT count(*) FROM total_t WHERE CAST(j->>'$.x' AS BIGINT) = 1998;
----
physical_plan	<!REGEX>:.*COALESCE.*

statement ok
PRAGMA explain_output='all';

# Values stay correct after the COALESCE-free rewrite.
query II
SELECT MIN(CAST(j->>'$.x' AS BIGINT)), MAX(CAST(j->>'$.x' AS BIGINT)) FROM total_t;
----
0	3998

query I
SELECT count(*) FROM total_t WHERE CAST(j->>'$.x' AS BIGINT) = 1998;
----
1

# The text contract (->> without an outer cast) also drops the fallback when the shred is total.
query I
SELECT count(*) FROM total_t WHERE j->>'$.x' = '1998';
----
1

# (b) heterogeneous shred: half the rows hold a string at $.x, which cannot fit a BIGINT shred and is
# kept in the residual with a NULL shred. The statistics then report the shred CAN have NULL, so the
# safe COALESCE fallback is retained and the value is still correct.
statement ok
CREATE TABLE hetero_t AS
SELECT jsono(
  CASE WHEN i % 2 = 0 THEN '{"x": ' || i::VARCHAR || '}' ELSE '{"x": "str"}' END,
  shredding := {'$.x':'BIGINT'}) AS j
FROM range(1000) tt(i);

statement ok
PRAGMA explain_output='physical_only';

query II
EXPLAIN SELECT MIN(TRY_CAST(j->>'$.x' AS BIGINT)) FROM hetero_t;
----
physical_plan	<REGEX>:.*COALESCE.*

statement ok
PRAGMA explain_output='all';

query II
SELECT MIN(TRY_CAST(j->>'$.x' AS BIGINT)), MAX(TRY_CAST(j->>'$.x' AS BIGINT)) FROM hetero_t;
----
0	998

# (b2) value-complete-but-not-total shred: a third of the rows OMIT $.x (an absent path -> NULL shred,
# not a residual diversion), the rest are integers. No present scalar was diverted, so the
# value-complete marker carries no NULL. The shred itself still has NULLs (from the absent rows), yet
# the optimizer reads it COALESCE-free anyway: a bare struct_extract returns NULL for an absent path,
# which is the correct read, and MIN/MAX/count (which ignore those NULLs) stay correct. This is the
# value-complete fast path that lets a typed shred beat ClickHouse without dropping the absent rows.
statement ok
CREATE TABLE vc_absent AS
SELECT jsono(
  CASE WHEN i % 3 = 0 THEN '{"k":"a"}' ELSE '{"x": ' || i::VARCHAR || '}' END,
  shredding := {'$.x':'BIGINT'}) AS j
FROM range(3000) tt(i);

statement ok
PRAGMA explain_output='physical_only';

query II
EXPLAIN SELECT MIN(CAST(j->>'$.x' AS BIGINT)) FROM vc_absent;
----
physical_plan	<!REGEX>:.*COALESCE.*

statement ok
PRAGMA explain_output='all';

# 2000 of 3000 rows carry $.x (the others omit it); MIN/MAX over the present integers, count ignores
# the absent rows.
query III
SELECT MIN(CAST(j->>'$.x' AS BIGINT)), MAX(CAST(j->>'$.x' AS BIGINT)), COUNT(CAST(j->>'$.x' AS BIGINT)) FROM vc_absent;
----
1	2999	2000

# (c) a column with no base-table statistics (an inline VALUES relation, no LogicalGet leaf the
# optimizer can pull stats from): the total fast path cannot prove totality, so the COALESCE stays.
statement ok
PRAGMA explain_output='physical_only';

query II
EXPLAIN
SELECT MIN(CAST(v->>'$.x' AS BIGINT))
FROM (VALUES (jsono('{"x":1}', shredding := {'$.x':'BIGINT'})),
             (jsono('{"x":2}', shredding := {'$.x':'BIGINT'}))) AS rows(v);
----
physical_plan	<REGEX>:.*COALESCE.*

statement ok
PRAGMA explain_output='all';

# (d) narrowing-safety: a raw by-name struct cast that drops a shred narrows the row, and any read of
# the dropped path still fails loud via the shred manifest — the total fast path does not mask it.
statement ok
CREATE TABLE narrow_total AS SELECT jsono('{}', shredding := {'$.a':'BIGINT'}) AS j WHERE false;

statement ok
SET disabled_optimizers='extension';

# The raw cast drops $.b: its value was stripped from the residual at write time, so the manifest
# records the loss.
statement ok
INSERT INTO narrow_total SELECT jsono('{"a":1,"b":2}', shredding := {'$.a':'BIGINT','$.b':'BIGINT'});

statement ok
RESET disabled_optimizers;

# The surviving $.a shred is total (no NULL), so its read is COALESCE-free — yet reading the dropped
# $.b path on the same narrowed row still fails loud.
query I
SELECT CAST(j->>'$.a' AS BIGINT) FROM narrow_total;
----
1

statement error
SELECT j->>'$.b' FROM narrow_total;
----
narrowed by a raw struct cast

# (e) set-operation reshred of value-complete typed shreds: a UNION of two differently-shredded
# branches reshreds each to the merged shred set {$.x, $.a, $.b}. The kept BIGINT shred $.x diverted
# nothing in either branch, so the reshredded result stays value-complete and the stored column reads
# COALESCE-free — the fast path now reaches set-op / CASE / INSERT-into-shredded outputs.
statement ok
CREATE TABLE reshred_vc AS
SELECT jsono('{"x":' || i || ',"a":"A"}', shredding := {'$.x':'BIGINT','$.a':'VARCHAR'}) AS j FROM range(1000) tt(i)
UNION ALL
SELECT jsono('{"x":' || (i + 1000) || ',"b":"B"}', shredding := {'$.x':'BIGINT','$.b':'VARCHAR'}) AS j FROM range(1000) tt(i);

statement ok
PRAGMA explain_output='physical_only';

query II
EXPLAIN SELECT MIN(CAST(j->>'$.x' AS BIGINT)) FROM reshred_vc;
----
physical_plan	<!REGEX>:.*COALESCE.*

statement ok
PRAGMA explain_output='all';

query III
SELECT MIN(CAST(j->>'$.x' AS BIGINT)), MAX(CAST(j->>'$.x' AS BIGINT)), COUNT(CAST(j->>'$.x' AS BIGINT)) FROM reshred_vc;
----
0	1999	2000

# (f) reshred over a DIVERTED source: $.x is a numeric STRING in one branch — a present scalar that
# fails the merged BIGINT shred and stays in the residual. The reshredded result is then NOT
# value-complete (the kept-shred residual probe catches it), the COALESCE fallback is retained, and
# it recovers the residual value. Were the row wrongly marked value-complete, the bare read would
# miss those values and MIN would be 1000 instead of 0.
statement ok
CREATE TABLE reshred_div AS
SELECT jsono('{"x":"' || i || '","a":"A"}', shredding := {'$.x':'BIGINT','$.a':'VARCHAR'}) AS j FROM range(10) tt(i)
UNION ALL
SELECT jsono('{"x":' || (i + 1000) || ',"b":"B"}', shredding := {'$.x':'BIGINT','$.b':'VARCHAR'}) AS j FROM range(10) tt(i);

statement ok
PRAGMA explain_output='physical_only';

query II
EXPLAIN SELECT MIN(TRY_CAST(j->>'$.x' AS BIGINT)) FROM reshred_div;
----
physical_plan	<REGEX>:.*COALESCE.*

statement ok
PRAGMA explain_output='all';

query II
SELECT MIN(TRY_CAST(j->>'$.x' AS BIGINT)), MAX(TRY_CAST(j->>'$.x' AS BIGINT)) FROM reshred_div;
----
0	1009

# (g) merge fast-path is value-complete by construction: it is taken only when no shred key appears
# in the folded residual (the no-conflict gate). A diverted scalar would sit in that residual at the
# shred's key and divert to the correct reshred fallback — so every NULL shred in the fast path is an
# absent path, and the merged result reads COALESCE-free.
statement ok
CREATE TABLE merge_vc AS
SELECT jsono_merge_patch(
         jsono('{"x":' || i || '}', shredding := {'$.x':'BIGINT'}),
         jsono('{"y":"' || i || '"}', shredding := {'$.y':'VARCHAR'})) AS j
FROM range(1000) tt(i);

statement ok
PRAGMA explain_output='physical_only';

query II
EXPLAIN SELECT MIN(CAST(j->>'$.x' AS BIGINT)) FROM merge_vc;
----
physical_plan	<!REGEX>:.*COALESCE.*

statement ok
PRAGMA explain_output='all';

query II
SELECT MIN(CAST(j->>'$.x' AS BIGINT)), MAX(CAST(j->>'$.x' AS BIGINT)) FROM merge_vc;
----
0	999
