# name: test/sql/jsono_shredded.test
# description: Transparent reads over a shredded JSONO struct (nested layout: body + shreds)
# group: [sql]

require jsono

# Shredded transparency rides on core json's ->>(JSON) overload: a shredded
# struct binds it via an implicit struct->JSON cast, which the optimizer rewrites.
require json

# A "shredded" JSONO value is a top-level STRUCT with one "jsono<fp>" layout field,
# carrying a `body` STRUCT (the authoritative four-blob JSONO encoding) and a `shreds` STRUCT of
# shred columns named by canonical path. PRESERVE model: the body encodes the full document and
# each shred also holds j ->> path. The body here is {"kind":"commit","did":"d1","extra":"e1"};
# shreds cover $.kind and $.did (layout fp jsono).
statement ok
CREATE TABLE shred AS
SELECT struct_pack(
    "jsono" := struct_pack(
        body := jsono('{"kind":"commit","did":"d1","extra":"e1"}')."jsono".body,
        "$.did"  := 'd1',
            "$.kind" := 'commit')
) AS j;

# bare ->> on a shred path resolves transparently
query I
SELECT j ->> '$.kind' FROM shred;
----
commit

query I
SELECT j ->> '$.did' FROM shred;
----
d1

# shorthand key form maps to the same shred as the canonical $.kind
query I
SELECT j ->> 'kind' FROM shred;
----
commit

# a path not covered by a shred falls back to the authoritative body
query I
SELECT j ->> '$.extra' FROM shred;
----
e1

# an absent path is NULL, not an error
query I
SELECT j ->> '$.missing' FROM shred;
----
NULL

# to_json reconstructs the full value from the body; shreds are never leaked
query I
SELECT to_json(j) FROM shred;
----
{"did":"d1","extra":"e1","kind":"commit"}

# transparent in a filter, including a non-shred path consumed elsewhere
query I
SELECT j ->> '$.extra' FROM shred WHERE j ->> '$.kind' = 'commit';
----
e1

# The shred is authoritative for its path: a shred intentionally desynced from the
# body returns the shred value, proving the read hits the shred column directly.
statement ok
CREATE TABLE shred_sentinel AS
SELECT struct_pack(
    "jsono" := struct_pack(
        body := jsono('{"kind":"commit","did":"d1"}')."jsono".body,
        "$.kind" := 'SENTINEL')
) AS j;

query I
SELECT j ->> '$.kind' FROM shred_sentinel;
----
SENTINEL

# to_json overlays shreds onto the body, which is authoritative: the desynced
# $.kind shred is ignored for reconstruction (it still drives the ->> read above).
# In a real shred the shred and body never disagree.
query I
SELECT to_json(j) FROM shred_sentinel;
----
{"did":"d1","kind":"commit"}

# Multi-row, a NULL struct row, and a Parquet round-trip (the DuckLake-shaped
# path: the shredded struct loses no fields through Parquet and the rewrite still
# fires on the read_parquet-sourced column). Shreds are computed from the value so
# the PRESERVE invariant holds for every row.
require parquet

statement ok
CREATE TABLE docs(id INTEGER, doc VARCHAR);

statement ok
INSERT INTO docs VALUES
  (1, '{"kind":"commit","did":"d1","extra":"e1"}'),
  (2, '{"kind":"like","did":"d2","extra":"e2"}'),
  (3, NULL);

statement ok
CREATE TABLE multi AS
SELECT id,
  jsono(doc, shredding := {'$.did':'VARCHAR','$.kind':'VARCHAR'}) AS j
FROM docs;

statement ok
COPY multi TO '__TEST_DIR__/shredded.parquet' (FORMAT parquet);

# shred, non-shred and to_json agree across the direct table and the Parquet copy,
# including the NULL row.
query ITTT
SELECT id, j ->> '$.kind', j ->> '$.extra', to_json(j) FROM multi ORDER BY id;
----
1	commit	e1	{"did":"d1","extra":"e1","kind":"commit"}
2	like	e2	{"did":"d2","extra":"e2","kind":"like"}
3	NULL	NULL	NULL

query ITTT
SELECT id, j ->> '$.kind', j ->> '$.extra', to_json(j) FROM '__TEST_DIR__/shredded.parquet' ORDER BY id;
----
1	commit	e1	{"did":"d1","extra":"e1","kind":"commit"}
2	like	e2	{"did":"d2","extra":"e2","kind":"like"}
3	NULL	NULL	NULL

# a shred predicate over many rows filters transparently (the rewrite turns it into
# a struct_extract the planner can push down)
query I
SELECT id FROM multi WHERE j ->> '$.kind' = 'like' ORDER BY id;
----
2

# A shred may be typed (not just VARCHAR): the writer can store a hot number as a
# native column so it compresses as a typed column and reconstructs faithfully.
# The ->> contract still returns text, so a typed shred is read via struct_extract
# then cast to VARCHAR. A typed sentinel desynced from the body proves the typed
# shred is the source, not the body.
statement ok
CREATE TABLE shred_typed AS
SELECT struct_pack(
    "jsono" := struct_pack(
        body := jsono('{"n":5,"s":"blob_s"}')."jsono".body,
        "$.n" := 999::BIGINT,
            "$.s" := 'shred_s')
) AS j;

# typed BIGINT shred read through the ->> text contract returns the shred value
query I
SELECT j ->> '$.n' FROM shred_typed;
----
999

# and stays castable, the way JSONBench casts time_us back to BIGINT
query I
SELECT CAST(j ->> '$.n' AS BIGINT) + 1 FROM shred_typed;
----
1000

# a VARCHAR shred alongside a typed one still reads directly
query I
SELECT j ->> '$.s' FROM shred_typed;
----
shred_s

# A typed shred only holds values of its type; a value that doesn't fit (here a
# string in a BIGINT-typed shred) is kept in the body and the shred is NULL. The
# ->> read must fall back to the body for those rows, not return NULL.
statement ok
CREATE TABLE typed_het AS
SELECT struct_pack(
    "jsono" := struct_pack(
        body := jsono('{"n":"hello"}')."jsono".body,
        "$.n" := NULL::BIGINT)
) AS j;

query I
SELECT j ->> '$.n' FROM typed_het;
----
hello
