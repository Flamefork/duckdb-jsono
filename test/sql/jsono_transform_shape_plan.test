# name: test/sql/jsono_transform_shape_plan.test
# description: jsono_transform shape-plan cache reads stay correct across interleaved shapes
# group: [sql]

require jsono

# The transform caches a per-shape field-resolution plan keyed by the row's slots AND
# key_heap bytes. These tests interleave shapes that stress the key: rows whose slots are
# byte-identical but whose keys differ in spelling, value-kind flips (bool/int/double/null),
# wildcard subtrees of varying lengths, and a shape cardinality past the cache capacity.

statement ok
CREATE TABLE shape_mix AS
SELECT i,
       jsono(CASE i % 3
           WHEN 0 THEN '{"a": "s' || i || '", "b": ' || i || ', "flag": true, "items": [{"name": "x' || i || '"}, {"name": "y' || i || '"}]}'
           WHEN 1 THEN '{"a": "t' || i || '", "b": ' || (i + 0.5) || ', "flag": false}'
           ELSE '{"b": null, "deep": {"c": ' || i || '}}'
       END) AS j
FROM range(3000) r(i);

# Scalar kinds, bool constants per shape, JSON null, nested path, list and join wildcards.
query II
SELECT i, jsono_transform(j, {
    a: 'VARCHAR',
    b: 'DOUBLE',
    flag: 'BOOLEAN',
    c: {type: 'BIGINT', path: '$.deep.c'},
    names: {type: ['VARCHAR'], path: '$.items[*].name'},
    joined: {type: 'VARCHAR', path: '$.items[*].name', join_separator: ','}
}) FROM shape_mix WHERE i < 6 ORDER BY i;
----
0	{'a': s0, 'b': 0.0, 'flag': true, 'c': NULL, 'names': [x0, y0], 'joined': 'x0,y0'}
1	{'a': t1, 'b': 1.5, 'flag': false, 'c': NULL, 'names': NULL, 'joined': NULL}
2	{'a': NULL, 'b': NULL, 'flag': NULL, 'c': 2, 'names': NULL, 'joined': NULL}
3	{'a': s3, 'b': 3.0, 'flag': true, 'c': NULL, 'names': [x3, y3], 'joined': 'x3,y3'}
4	{'a': t4, 'b': 4.5, 'flag': false, 'c': NULL, 'names': NULL, 'joined': NULL}
5	{'a': NULL, 'b': NULL, 'flag': NULL, 'c': 5, 'names': NULL, 'joined': NULL}

# Aggregates over all 3000 rows: every row went through the plan (or its rebuild).
query IIII
SELECT count(*), sum(s.b), sum(s.c), sum(CASE WHEN s.flag THEN 1 ELSE 0 END)
FROM (SELECT jsono_transform(j, {
    b: 'DOUBLE',
    flag: 'BOOLEAN',
    c: {type: 'BIGINT', path: '$.deep.c'}
}) s FROM shape_mix) q;
----
3000	2998500.0	1500500	1000

# Keys that differ in spelling but not in length produce byte-identical slots blobs (a KEY
# slot stores only its heap offset and length); the plan key must include the key_heap bytes
# or k1 rows would be read through the k0 plan. sum(k0) counts only i % 8 = 0 rows.
statement ok
CREATE TABLE same_len_keys AS
SELECT i, jsono('{"k' || (i % 8) || '": ' || i || ', "v": "s' || i || '"}') AS j
FROM range(4000) r(i);

query IIII
SELECT count(*), sum(s.k0), sum(s.k7), count(s.k0)
FROM (SELECT jsono_transform(j, {v: 'VARCHAR', k0: 'BIGINT', k7: 'BIGINT'}) s FROM same_len_keys) q;
----
4000	998000	1001500	500

# 100 interleaved key spellings fit the cache: every shape resolves through its own plan.
statement ok
CREATE TABLE many_shapes AS
SELECT i, jsono('{"k' || (i % 100) || '": ' || i || ', "v": "s' || i || '"}') AS j
FROM range(3000) r(i);

query III
SELECT count(*), sum(s.k0), count(s.k0)
FROM (SELECT jsono_transform(j, {v: 'VARCHAR', k0: 'BIGINT', k1: 'BIGINT'}) s FROM many_shapes) q;
----
3000	43500	30

# Shape cardinality past the cache capacity: 2000 cyclically interleaved shapes thrash the
# cache, the hit-rate window disables it mid-scan, and the fallback walk must agree with
# the plan rows that ran before the switch.
statement ok
CREATE TABLE shape_flood AS
SELECT i, jsono('{"k' || (i % 2000) || '": ' || i || ', "v": "s' || i || '"}') AS j
FROM range(8000) r(i);

query III
SELECT count(*), sum(s.k0), count(s.k0)
FROM (SELECT jsono_transform(j, {v: 'VARCHAR', k0: 'BIGINT', k1: 'BIGINT'}) s FROM shape_flood) q;
----
8000	12000	4

# Wildcard subtree entered from a plan-recorded cursor: every array length is its own
# shape, and the join/list outputs must follow the per-row arrays. The fixed-index scalar
# fields ride the same plan through the array's index edges.
query II
SELECT i, jsono_transform(j, {
    joined: {type: 'VARCHAR', path: '$.items[*].name', join_separator: '|'},
    names: {type: ['VARCHAR'], path: '$.items[*].name'},
    first: {type: 'VARCHAR', path: '$.items[0].name'},
    third: {type: 'VARCHAR', path: '$.items[2].name'},
    missing: 'VARCHAR'
}) FROM (
    SELECT i, jsono('{"items": [' ||
        (SELECT string_agg('{"name": "n' || i || '_' || e || '"}', ',' ORDER BY e) FROM range(1 + i % 3) q(e)) ||
        ']}') AS j
    FROM range(6) r(i)
) ORDER BY i;
----
0	{'joined': n0_0, 'names': [n0_0], 'first': n0_0, 'third': NULL, 'missing': NULL}
1	{'joined': n1_0|n1_1, 'names': [n1_0, n1_1], 'first': n1_0, 'third': NULL, 'missing': NULL}
2	{'joined': n2_0|n2_1|n2_2, 'names': [n2_0, n2_1, n2_2], 'first': n2_0, 'third': n2_2, 'missing': NULL}
3	{'joined': n3_0, 'names': [n3_0], 'first': n3_0, 'third': NULL, 'missing': NULL}
4	{'joined': n4_0|n4_1, 'names': [n4_0, n4_1], 'first': n4_0, 'third': NULL, 'missing': NULL}
5	{'joined': n5_0|n5_1|n5_2, 'names': [n5_0, n5_1, n5_2], 'first': n5_0, 'third': n5_2, 'missing': NULL}

# Shredded input: a shred-backed field resolves residual-first per shape — rows where the
# shred writer stripped the value (it matched the shred kind) read the shred column, rows
# where it stayed in the residual (kind mismatch) read the residual.
statement ok
CREATE TABLE shredded_mix AS
SELECT i, jsono(CASE i % 2
    WHEN 0 THEN '{"name": "u' || i || '", "extra": ' || i || '}'
    ELSE '{"name": ' || i || ', "extra": ' || i || '}'
END, shredding := {name: 'VARCHAR'}) AS j
FROM range(2000) r(i);

query III
SELECT count(*), count(s.name), sum(s.extra)
FROM (SELECT jsono_transform(j, {name: 'VARCHAR', extra: 'BIGINT', missing: 'VARCHAR'}) s FROM shredded_mix) q;
----
2000	1000	1999000

query II
SELECT i, jsono_transform(j, {name: 'VARCHAR', extra: 'BIGINT', missing: 'VARCHAR'})
FROM shredded_mix WHERE i < 2 ORDER BY i;
----
0	{'name': u0, 'extra': 0, 'missing': NULL}
1	{'name': NULL, 'extra': 1, 'missing': NULL}
