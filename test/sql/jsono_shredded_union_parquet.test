# name: test/sql/jsono_shredded_union_parquet.test
# description: a union of differently-shredded jsono values materializes as one merged shredded type and survives a Parquet round-trip — the "jsono" layout and shred field names persist in the Parquet schema, so the value reads back exactly, manifest included.
# group: [sql]

require jsono

require json

require parquet

statement ok
CREATE TABLE sa AS SELECT jsono('{"a":"AAA","b":"BBB"}', shredding := {'a':'VARCHAR'}) AS e;

statement ok
CREATE TABLE sb AS SELECT jsono('{"a":"XXX","b":"YYY"}', shredding := {'b':'VARCHAR'}) AS e;

statement ok
CREATE TABLE um AS SELECT e FROM sa UNION ALL SELECT e FROM sb;

statement ok
COPY um TO '__TEST_DIR__/jsono_union_merged.parquet' (FORMAT parquet);

# The stored type is the merged shredded struct; both shreds' field names round-tripped.
query I
SELECT typeof(e) = (SELECT typeof(e) FROM um LIMIT 1) FROM '__TEST_DIR__/jsono_union_merged.parquet' LIMIT 1;
----
true

# Reading back reproduces each branch's value exactly.
query II
SELECT to_json(e)::VARCHAR, e ->> 'a'
FROM '__TEST_DIR__/jsono_union_merged.parquet' ORDER BY 1;
----
{"a":"AAA","b":"BBB"}	AAA
{"a":"XXX","b":"YYY"}	XXX

# The shred manifest survives the round-trip too: narrow the Parquet data into a smaller shred
# set WITHOUT the optimizer (the raw by-name cast drops the 'a'/'b' shred), then verify the
# narrowed rows fail loud on read.
statement ok
CREATE TABLE narrowed AS SELECT jsono('{}', shredding := {'a':'VARCHAR'}) AS e WHERE false;

statement ok
SET disabled_optimizers='extension';

statement ok
INSERT INTO narrowed SELECT e FROM '__TEST_DIR__/jsono_union_merged.parquet';

statement ok
RESET disabled_optimizers;

# The sb row's 'b' shred was dropped by the raw cast; its manifest makes the read fail loud.
# Contract owner: jsono_shredded_cast_guard.test owns the "narrowed by a raw struct cast"
# manifest-guard contract. This site's distinct entry-mechanism: the narrowing arrives via a
# Parquet round-trip feeding an optimizer-disabled INSERT (the shred manifest survives the
# Parquet schema, then a raw by-name cast drops a shred on the way in).
statement error
SELECT to_json(e)::VARCHAR FROM narrowed ORDER BY 1;
----
narrowed by a raw struct cast
