# name: test/sql/jsono_shredded_stripped.test
# description: Stripped shredded JSONO — body omits the top-level hot paths; reads reconstruct
# group: [sql]

require jsono

require json

# A stripped shredded value drops the top-level hot paths from the body
# (here: kind, did) and keeps them only in the shreds; nested hot paths
# (commit.operation/collection) stay in the body as well as in shreds. The
# body is built by deleting the top-level paths with a null merge_patch.
statement ok
CREATE TABLE stripped AS
WITH src AS (
    SELECT jsono('{"did":"d1","kind":"commit","commit":{"operation":"create","collection":"c1"},"extra":"e1"}') AS orig
),
res AS (
    SELECT orig,
           jsono_merge_patch(orig, jsono('{"did":null,"kind":null}'))."jsono".body AS body
    FROM src
)
SELECT struct_pack(
    "jsono" := struct_pack(
        body := res.body,
        "$jsono$vc" := NULL::UBIGINT,
        "$.commit.collection" := orig ->> '$.commit.collection',
            "$.commit.operation"  := orig ->> '$.commit.operation',
            "$.did"               := orig ->> '$.did',
            "$.kind"              := orig ->> '$.kind')
) AS j
FROM res;

# Control: reading the body alone (wrapped as a plain jsono, bypassing the lossless
# reconstruct) shows the top-level hot paths really are gone from the body.
query I
SELECT to_json(struct_pack("jsono" := struct_pack(
    body := j."jsono".body))) FROM stripped;
----
{"commit":{"collection":"c1","operation":"create"},"extra":"e1"}

# to_json reconstructs the full value by merging the shreds back into the body.
query I
SELECT to_json(j) FROM stripped;
----
{"commit":{"collection":"c1","operation":"create"},"did":"d1","extra":"e1","kind":"commit"}

# a stripped top-level path resolves from its shred
query I
SELECT j ->> '$.kind' FROM stripped;
----
commit

query I
SELECT j ->> '$.did' FROM stripped;
----
d1

# a nested hot path resolves from its shred (and is also still in the body)
query I
SELECT j ->> '$.commit.operation' FROM stripped;
----
create

# a non-hot path resolves from the body
query I
SELECT j ->> '$.extra' FROM stripped;
----
e1

# extracting an ancestor of a nested shred reads the body subtree directly
# (nested hot paths were not stripped), so it stays complete
query I
SELECT j ->> '$.commit' FROM stripped;
----
{"collection":"c1","operation":"create"}

# Reconstruction is an overlay: the body is authoritative, shreds only fill the
# paths the body dropped. Here $.k is kept in the body with a real value and
# the shred is (artificially) desynced — to_json must reflect the body, while the
# ->> read still hits the shred. In a real shred the two never disagree.
statement ok
CREATE TABLE ov_conflict AS
SELECT struct_pack(
    "jsono" := struct_pack(
        body := jsono('{"k":"RESIDUAL","c":"z"}')."jsono".body,
        "$jsono$vc" := NULL::UBIGINT,
        "$.k" := 'SHRED')
) AS j;

query I
SELECT to_json(j) FROM ov_conflict;
----
{"c":"z","k":"RESIDUAL"}

query I
SELECT j ->> '$.k' FROM ov_conflict;
----
SHRED

# A string extract of an ancestor of a stripped shred serializes the container, so it
# must reconstruct rather than read the residual alone — the shred leaf is stripped
# there and the manifest makes a residual-only read fail loudly. Built via
# jsono(..., shredding :=) so the residual carries a real shred manifest.
statement ok
CREATE TABLE manifest_stripped AS
SELECT jsono('{"commit":{"operation":"create"},"x":1}',
             shredding := {'$.commit.operation': 'VARCHAR'}) AS j;

query I
SELECT j ->> '$.commit' FROM manifest_stripped;
----
{"operation":"create"}

query I
SELECT j ->> '$' FROM manifest_stripped;
----
{"commit":{"operation":"create"},"x":1}

# A kept explicit JSON null survives reconstruction: $.a was stripped (absent from
# the body, lives in its shred), $.b was kept as null in the body, $.c is
# non-hot. Overlay fills a from its shred and keeps b's null — a B-side null must not
# delete the body's key.
statement ok
CREATE TABLE ov_null AS
SELECT struct_pack(
    "jsono" := struct_pack(
        body := jsono('{"b":null,"c":"z"}')."jsono".body,
        "$jsono$vc" := NULL::UBIGINT,
        "$.a" := 'x',
            "$.b" := NULL::VARCHAR)
) AS j;

query I
SELECT to_json(j) FROM ov_null;
----
{"a":"x","b":null,"c":"z"}

# A read of an ancestor subtree ($.b) over a DISJOINT shred set where a non-matching
# shred ($.a) is visited BEFORE the descended shred ($.b.c): the ancestor read must
# reconstruct so the stripped $.b.c leaf is overlaid back, returning {"c":2}. If the
# residual fallback were a per-shred short-circuit instead of a for-all, the leading
# $.a non-match would emit a residual-only read and return {} (the V3 manifest guard
# does not catch this partial read).
query I
SELECT j ->> '$.b' FROM (
    SELECT jsono('{"a":1,"b":{"c":2}}', shredding := {'$.a':'BIGINT','$.b.c':'BIGINT'}) AS j
);
----
{"c":2}
