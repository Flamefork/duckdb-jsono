# name: test/sql/jsono_shredded_cast_guard.test
# description: casts between differently-shredded JSONO types are lossless with the extension optimizer (reconstruct + reshred); without it the raw by-name struct cast drops shreds, and the shred manifest stored in the residual turns every read of such a narrowed row into a loud error instead of silent data loss
# group: [sql]

require jsono

require json

statement ok
CREATE TABLE shred_ab AS SELECT jsono('{"a":"AAA","b":"BBB"}', shredding := {'a':'VARCHAR','b':'VARCHAR'}) AS e;

statement ok
INSERT INTO shred_ab SELECT jsono('{"a":"CCC","b":"DDD"}', shredding := {'a':'VARCHAR','b':'VARCHAR'});

# The same shred set in reverse spec order produces the same canonical type (specs are sorted),
# so it inserts directly.
statement ok
INSERT INTO shred_ab SELECT jsono('{"a":"EEE","b":"FFF"}', shredding := {'b':'VARCHAR','a':'VARCHAR'});

# An overlapping shred set is NOT an error: the optimizer rewrites the lossy by-name cast into
# reconstruct + reshred against the target spec, so the value lands losslessly — a path with no
# shred in the target falls back into the residual.
statement ok
INSERT INTO shred_ab SELECT jsono('{"a":"q"}', shredding := {'a':'VARCHAR'});

statement ok
INSERT INTO shred_ab SELECT jsono('{"a":"1","b":"x"}', shredding := {'a':'BIGINT','b':'VARCHAR'});

statement ok
INSERT INTO shred_ab SELECT jsono('{"a":"AAA","b":"BBB"}');

# A FULLY DISJOINT shred set works too: the shreds sit beside `body` inside the layout struct,
# so `body` is a field every two JSONO types share and the struct cast always binds — the
# optimizer then rewrites it into the same lossless reconstruct + reshred.
statement ok
INSERT INTO shred_ab SELECT jsono('{"x":"y"}', shredding := {'x':'VARCHAR'});

query I
SELECT to_json(e)::VARCHAR FROM shred_ab ORDER BY 1;
----
{"a":"1","b":"x"}
{"a":"AAA","b":"BBB"}
{"a":"AAA","b":"BBB"}
{"a":"CCC","b":"DDD"}
{"a":"EEE","b":"FFF"}
{"a":"q"}
{"x":"y"}

query II
SELECT e ->> 'a', e ->> 'x' FROM shred_ab ORDER BY 1 NULLS LAST, 2;
----
1	NULL
AAA	NULL
AAA	NULL
CCC	NULL
EEE	NULL
q	NULL
NULL	y

# Shredded -> plain JSON is the lossless reconstruction path; never blocked.
query I
SELECT to_json(jsono('{"a":"AAA","b":"BBB"}', shredding := {'a':'VARCHAR'}));
----
{"a":"AAA","b":"BBB"}

# --- Without the extension optimizer the raw by-name struct cast runs as core DuckDB binds it.
# A widening cast (target carries more shreds) merely NULL-fills the new shreds — readers fall back
# to the residual, so the value stays exact. A NARROWING cast drops a shred whose value was
# stripped out of the residual at write time; the shred manifest records that, and every read of
# such a row fails loud instead of silently losing the value. ---

statement ok
CREATE TABLE narrow_target AS SELECT jsono('{}', shredding := {'a':'VARCHAR'}) AS e WHERE false;

statement ok
SET disabled_optimizers='extension';

statement ok
INSERT INTO narrow_target SELECT jsono('{"a":"v1","b":"v2"}', shredding := {'a':'VARCHAR','b':'VARCHAR'});

statement ok
RESET disabled_optimizers;

# Reconstruction (to_json) of the narrowed row fails loud: the manifest lists shred 'b VARCHAR'
# but the column type no longer carries it.
statement error
SELECT to_json(e)::VARCHAR FROM narrow_target;
----
narrowed by a raw struct cast

# The dropped shred's path fails loud too (a silent NULL here would be the data loss).
statement error
SELECT e ->> 'b' FROM narrow_target;
----
narrowed by a raw struct cast

# The surviving shred still reads.
query I
SELECT e ->> 'a' FROM narrow_target;
----
v1

# Every other native reader of the narrowed row fails loud too (no silent partial output).
statement error
SELECT jsono_entries(e) FROM narrow_target;
----
narrowed by a raw struct cast

statement error
SELECT jsono_transform(e, {'b': 'VARCHAR'}) FROM narrow_target;
----
narrowed by a raw struct cast

statement error
SELECT jsono_keys(e) FROM narrow_target;
----
narrowed by a raw struct cast

statement error
SELECT to_json(jsono_merge_patch(e, jsono('{"z":"1"}'))) FROM narrow_target;
----
narrowed by a raw struct cast

statement error
SELECT jsono_group_merge(e) FROM narrow_target;
----
narrowed by a raw struct cast

# An honest row in the same narrow type reads fine alongside (the manifest check is per row).
statement ok
INSERT INTO narrow_target SELECT jsono('{"a":"ok","b":"kept"}', shredding := {'a':'VARCHAR'});

query I
SELECT e ->> 'a' FROM narrow_target ORDER BY 1;
----
ok
v1

# Shredded operations that the extension binds directly require the extension optimizer. Plain
# JSONO remains usable without it, but shredded values are unsafe because core DuckDB can
# otherwise route them through generic STRUCT casts.
statement ok
SET disabled_optimizers='extension';

statement error
SELECT jsono_extract(e, '$.a') FROM shred_ab;
----
requires the extension optimizer

statement error
SELECT jsono_storage_size(e) FROM shred_ab;
----
requires the extension optimizer

statement ok
RESET disabled_optimizers;

# The optimizer-injected expressions (__jsono_internal_checked_residual, the reshred rewrite)
# must survive plan (de)serialization — they are registered in the catalog and re-bind by name.
# Optimizer-injected functions that are not registered crash the DEBUG plan-serialize verifier.
statement ok
PRAGMA verify_serializer;

query I
SELECT e ->> 'b' FROM shred_ab WHERE e ->> 'a' = 'q';
----
NULL

statement ok
INSERT INTO narrow_target SELECT jsono('{"a":"ser","b":"ialized"}', shredding := {'a':'VARCHAR','b':'VARCHAR'});

query I
SELECT to_json(e)::VARCHAR FROM narrow_target WHERE e ->> 'a' = 'ser';
----
{"a":"ser","b":"ialized"}

statement ok
PRAGMA disable_verification;

# --- A narrowed PLAIN value: repacking the residual body alone through a raw struct_pack keeps
# the shred manifest in skips but drops the shreds AND the shredded type. Every reader must fail
# loud on it, and the merge family must throw BEFORE rebuilding — a rebuilt blob would drop the
# manifest and launder the loss into permanent undetectability. ---

statement ok
CREATE TABLE plain_narrowed AS
SELECT struct_pack("jsono" := struct_pack(body := j."jsono".body)) AS p
FROM (SELECT jsono('{"a":"v1","b":"v2"}', shredding := {'a':'VARCHAR'}) AS j);

statement error
SELECT to_json(p) FROM plain_narrowed;
----
narrowed by a raw struct cast

statement error
SELECT p::JSON FROM plain_narrowed;
----
narrowed by a raw struct cast

# The whole-keys form would silently lose the stripped key 'a'.
statement error
SELECT jsono_keys(p) FROM plain_narrowed;
----
narrowed by a raw struct cast

# A path the manifest covers reads as a silent NULL without the check.
statement error
SELECT jsono_type(p, '$.a') FROM plain_narrowed;
----
narrowed by a raw struct cast

# The root type is narrow-invariant (shred paths are object-key chains, so the root stays an
# object): the answer is complete and stays readable — same per-row granularity as extract.
query I
SELECT jsono_type(p) FROM plain_narrowed;
----
OBJECT

statement error
SELECT jsono_merge_patch(p, jsono('{}')) FROM plain_narrowed;
----
narrowed by a raw struct cast

statement error
SELECT jsono_group_merge(p) FROM plain_narrowed;
----
narrowed by a raw struct cast

# The all-shredded merge fast path must verify each input's manifest against that input's own
# shreds: the narrowed row's manifest lists 'b VARCHAR' which no input carries, so the merge
# throws instead of re-emitting a manifest without it (laundering the loss).
statement error
SELECT jsono_merge_patch(e, jsono('{"z":"1"}', shredding := {'z':'VARCHAR'})) FROM narrow_target;
----
narrowed by a raw struct cast

# --- jsono_validate must report narrowed rows as invalid: the manifest lists a shred the column
# no longer carries, the same per-row condition every reader throws on. ---

# narrow_target: the narrowed row (a=v1) is false, the honest rows in the same column stay true.
query I
SELECT jsono_validate(e) FROM narrow_target ORDER BY e ->> 'a';
----
true
true
false

# A narrowed PLAIN value (residual repacked alone): the manifest survives in skips while the type
# carries no shreds at all.
query I
SELECT jsono_validate(p) FROM plain_narrowed;
----
false

# --- The optimizer's fused matcher/projector and the writers that re-emit a residual verify the
# manifest too: a narrowed row must fail loud wherever its stripped value would silently change
# the result or where a rebuilt blob would drop the manifest (laundering the loss). ---

# Fused filter matcher (two predicates on one column): the stripped path 'a' must not read as a
# silent non-match.
statement error
SELECT count(*) FROM plain_narrowed WHERE (p ->> 'a' = 'v1') AND (p ->> 'b' = 'v2');
----
narrowed by a raw struct cast

# Fused projector above a passing filter: the stripped path 'a' must not project a silent NULL.
statement error
SELECT min(p ->> 'a') FROM plain_narrowed WHERE (p ->> 'b' = 'v2') AND (p ->> 'b' IN ['v2', 'zz']);
----
narrowed by a raw struct cast

# Shredding a narrowed plain value re-emits the residual with a fresh manifest; without the check
# the stripped 'a' would become permanently undetectable.
statement error
SELECT jsono(p, shredding := {'b': 'VARCHAR'}) FROM plain_narrowed;
----
narrowed by a raw struct cast

# Embedding a narrowed value inside a constructed document re-emits it without its manifest.
statement error
SELECT to_json(jsono({'wrap': p})) FROM plain_narrowed;
----
narrowed by a raw struct cast
