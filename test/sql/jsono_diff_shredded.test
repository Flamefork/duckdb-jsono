# name: test/sql/jsono_diff_shredded.test
# description: Direct shredded jsono_diff (typed lane pairs + residual walk) — parity with the plain diff
# group: [sql]

require jsono

require json

# Rich pair set exercising every direct-path case: changed/unchanged lanes of each primitive,
# nested lanes, lane-presence transitions (added/removed/diverted fields -> per-row reconstruct
# fallback), NULL rows, non-object roots, and identical rows. The shredded diff must be
# byte-identical to diffing the same documents as plain JSONO.
statement ok
CREATE TABLE pairs(id INTEGER, prev VARCHAR, cur VARCHAR);

statement ok
INSERT INTO pairs VALUES
  (1,  '{"k":"a","n":1,"d":1.5,"m":{"deep":10},"extra":[1,2]}', '{"k":"b","n":1,"d":2.5,"m":{"deep":11},"extra":[1,2]}'),
  (2,  '{"k":"same","n":7,"d":0.5,"m":{"deep":3}}',             '{"k":"same","n":7,"d":0.5,"m":{"deep":3}}'),
  (3,  '{"k":"x","n":1}',                                       '{"k":"x","n":1,"d":9.75}'),
  (4,  '{"k":"x","n":1,"d":9.75}',                              '{"k":"x","n":1}'),
  (5,  '{"n":"diverted"}',                                      '{"n":5}'),
  (6,  '{"n":5}',                                               '{"n":"diverted"}'),
  (7,  NULL,                                                    '{"k":"fresh","n":1}'),
  (8,  '{"k":"gone","n":1}',                                    NULL),
  (9,  '[1,2,3]',                                               '{"k":"obj","n":2}'),
  (10, '{"k":"obj","n":2}',                                     '"scalar"'),
  (11, '{"k":"a","m":{"deep":1,"kept":true}}',                  '{"k":"a","m":{"deep":2,"kept":true}}'),
  (12, '{"k":"a","m":{"deep":1}}',                              '{"k":"a","m":5}'),
  (13, '{"k":"a","extra":[1,2],"n":1}',                         '{"k":"a","extra":[9],"n":2}');

# Atomic mode parity across the whole set (jsono() must round-trip prev/cur through NULL rows).
query I
SELECT count(*)
FROM (
  SELECT id,
         to_json(jsono_diff(jsono(prev, shredding := {k:'VARCHAR', n:'BIGINT', d:'DOUBLE', '$.m.deep':'BIGINT'}),
                            jsono(cur,  shredding := {k:'VARCHAR', n:'BIGINT', d:'DOUBLE', '$.m.deep':'BIGINT'}))) AS shredded,
         to_json(jsono_diff(jsono(prev), jsono(cur))) AS plain
  FROM pairs
)
WHERE shredded IS DISTINCT FROM plain;
----
0

# The changed-lane fast path emits exactly the changed lanes merged with the residual diff.
query I
SELECT to_json(jsono_diff(jsono('{"k":"a","n":1,"m":{"deep":10},"other":true}', shredding := {k:'VARCHAR', n:'BIGINT', '$.m.deep':'BIGINT'}),
                          jsono('{"k":"b","n":1,"m":{"deep":11},"other":false}', shredding := {k:'VARCHAR', n:'BIGINT', '$.m.deep':'BIGINT'})));
----
{"k":"b","m":{"deep":11},"other":false}

# Atomic diffs stay applyable on the direct path: prev + diff == cur.
query I
SELECT count(*)
FROM (
  SELECT id, prev, cur,
         to_json(jsono_merge_patch(
             jsono(prev, shredding := {k:'VARCHAR', n:'BIGINT', d:'DOUBLE', '$.m.deep':'BIGINT'}),
             jsono_diff(jsono(prev, shredding := {k:'VARCHAR', n:'BIGINT', d:'DOUBLE', '$.m.deep':'BIGINT'}),
                        jsono(cur,  shredding := {k:'VARCHAR', n:'BIGINT', d:'DOUBLE', '$.m.deep':'BIGINT'})))) AS applied
  FROM pairs
  WHERE prev IS NOT NULL AND cur IS NOT NULL
)
WHERE applied IS DISTINCT FROM to_json(jsono(cur));
----
0

# counts / elements array modes on shredded input (arrays live in the residual on this spec).
query II
SELECT to_json(jsono_diff(jsono(prev, shredding := {k:'VARCHAR'}), jsono(cur, shredding := {k:'VARCHAR'}), arrays := 'counts')),
       to_json(jsono_diff(jsono(prev, shredding := {k:'VARCHAR'}), jsono(cur, shredding := {k:'VARCHAR'}), arrays := 'elements'))
FROM pairs WHERE id = 13;
----
{"extra":{"added":1,"removed":2},"n":2}	{"extra":{"added":[9],"removed":[1,2]},"n":2}

# An array-shred type declines the direct path at bind (reconstruct-cast) but stays correct.
query I
SELECT count(*)
FROM (
  SELECT id,
         to_json(jsono_diff(jsono(prev, shredding := {extra:'BIGINT[]'}), jsono(cur, shredding := {extra:'BIGINT[]'}))) AS shredded,
         to_json(jsono_diff(jsono(prev), jsono(cur))) AS plain
  FROM pairs WHERE prev IS NOT NULL AND cur IS NOT NULL
)
WHERE shredded IS DISTINCT FROM plain;
----
0

# Mismatched shred sets also decline the direct path (different types) and stay correct.
query I
SELECT to_json(jsono_diff(jsono('{"k":"a","n":1}', shredding := {k:'VARCHAR'}),
                          jsono('{"k":"b","n":2}', shredding := {n:'BIGINT'})));
----
{"k":"b","n":2}
