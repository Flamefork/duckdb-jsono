# name: test/sql/jsono_optimizer.test
# description: JSONO optimizer rewrite for repeated extract-string filters
# group: [sql]

require jsono

statement ok
CREATE TABLE jsono_optimizer_probe AS
SELECT jsono(payload) AS j
FROM (
  VALUES
    ('{"kind":"commit","commit":{"operation":"create","collection":"app.bsky.feed.post"},"did":"u1","time_us":1000,"o":{"a":1}}'),
    ('{"kind":"commit","commit":{"operation":"create","collection":"app.bsky.feed.like"},"did":"u2","time_us":2000,"o":{"a":1}}'),
    ('{"kind":"commit","commit":{"operation":"delete","collection":"app.bsky.feed.post"},"did":"u3","time_us":3000,"o":{"a":1}}'),
    ('{"kind":"identity","commit":{"operation":"create","collection":"app.bsky.feed.post"},"did":"u4","time_us":4000,"o":{"a":1}}'),
    ('{"kind":"commit","commit":{"operation":"create"},"did":"u5","time_us":5000,"o":{"a":2}}'),
    ('{"kind":null,"commit":{"operation":"create","collection":"app.bsky.feed.post"},"did":"u6","time_us":null,"o":{"a":1}}'),
    ('{"kind":"commit","commit":{"operation":"create","collection":"app.bsky.feed.post"},"did":"u1","time_us":7000,"o":{"a":2}}')
) AS rows(payload);

statement ok
SET disabled_optimizers='extension';

statement ok
CREATE TEMP TABLE jsono_optimizer_expected AS
SELECT j->>'$.did' AS did
FROM jsono_optimizer_probe
WHERE (j->>'$.kind' = 'commit')
  AND (j->>'$.commit.operation' = 'create')
  AND (j->>'$.commit.collection' IN ['app.bsky.feed.post', 'app.bsky.feed.like'])
ORDER BY did;

statement ok
RESET disabled_optimizers;

query I
SELECT count(*)
FROM (
  (SELECT * FROM jsono_optimizer_expected EXCEPT
   SELECT j->>'$.did' AS did
   FROM jsono_optimizer_probe
   WHERE (j->>'$.kind' = 'commit')
     AND (j->>'$.commit.operation' = 'create')
     AND (j->>'$.commit.collection' IN ['app.bsky.feed.post', 'app.bsky.feed.like']))
  UNION ALL
  (SELECT j->>'$.did' AS did
   FROM jsono_optimizer_probe
   WHERE (j->>'$.kind' = 'commit')
     AND (j->>'$.commit.operation' = 'create')
     AND (j->>'$.commit.collection' IN ['app.bsky.feed.post', 'app.bsky.feed.like'])
   EXCEPT SELECT * FROM jsono_optimizer_expected)
);
----
0

query I
SELECT count(*)
FROM jsono_optimizer_probe
WHERE ('commit' = (j->>'$.kind'))
  AND (j->>'$.o' = '{"a":1}');
----
3

query I
SELECT count(*)
FROM jsono_optimizer_probe
WHERE (j->>'$.kind' = 'commit')
  AND (j->>'$.missing' = 'x');
----
0

statement ok
SET disabled_optimizers='extension';

statement ok
CREATE TEMP TABLE jsono_optimizer_project_expected AS
SELECT j->>'$.did' AS user_id,
       MIN(CAST(j->>'$.time_us' AS BIGINT)) AS first_time,
       MAX(CAST(j->>'$.time_us' AS BIGINT)) AS last_time,
       MIN(j->>'$.o') AS first_object
FROM jsono_optimizer_probe
WHERE (j->>'$.kind' = 'commit')
  AND (j->>'$.commit.operation' = 'create')
  AND (j->>'$.commit.collection' = 'app.bsky.feed.post')
GROUP BY user_id
ORDER BY user_id;

statement ok
RESET disabled_optimizers;

statement ok
PRAGMA explain_output='physical_only';

query II
EXPLAIN SELECT j->>'$.did' AS user_id,
               MIN(CAST(j->>'$.time_us' AS BIGINT)) AS first_time,
               MAX(CAST(j->>'$.time_us' AS BIGINT)) AS last_time,
               MIN(j->>'$.o') AS first_object
FROM jsono_optimizer_probe
WHERE (j->>'$.kind' = 'commit')
  AND (j->>'$.commit.operation' = 'create')
  AND (j->>'$.commit.collection' = 'app.bsky.feed.post')
GROUP BY user_id;
----
physical_plan	<REGEX>:.*__jsono_internal_project.*

query I
SELECT count(*)
FROM (
  (SELECT * FROM jsono_optimizer_project_expected EXCEPT
   SELECT j->>'$.did' AS user_id,
          MIN(CAST(j->>'$.time_us' AS BIGINT)) AS first_time,
          MAX(CAST(j->>'$.time_us' AS BIGINT)) AS last_time,
          MIN(j->>'$.o') AS first_object
   FROM jsono_optimizer_probe
   WHERE (j->>'$.kind' = 'commit')
     AND (j->>'$.commit.operation' = 'create')
     AND (j->>'$.commit.collection' = 'app.bsky.feed.post')
   GROUP BY user_id)
  UNION ALL
  (SELECT j->>'$.did' AS user_id,
          MIN(CAST(j->>'$.time_us' AS BIGINT)) AS first_time,
          MAX(CAST(j->>'$.time_us' AS BIGINT)) AS last_time,
          MIN(j->>'$.o') AS first_object
   FROM jsono_optimizer_probe
   WHERE (j->>'$.kind' = 'commit')
     AND (j->>'$.commit.operation' = 'create')
     AND (j->>'$.commit.collection' = 'app.bsky.feed.post')
   GROUP BY user_id
   EXCEPT SELECT * FROM jsono_optimizer_project_expected)
);
----
0

statement ok
SET disabled_optimizers='extension';

statement ok
