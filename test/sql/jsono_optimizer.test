statement ok
PRAGMA disable_verify_serializer;

# --- jsono_extract / jsono_extract_string over a shredded value are shred/residual-rewritten,
#     matching the core-named ->> / json_extract rewrite (no per-row reconstruct cast). ---

statement ok
CREATE TABLE jsono_extract_shredded AS
SELECT jsono('{"kind":"commit","n":7,"o":{"x":1}}', shredding := {'$.kind':'VARCHAR','$.n':'BIGINT'}) AS j;

statement ok
PRAGMA explain_output='physical_only';

# A shred string extract reads the shred column directly: the scan projects only the shred field, not
# the whole shredded struct (the reconstruct path would project the entire value).
query II
EXPLAIN SELECT jsono_extract_string(j, '$.kind') AS r FROM jsono_extract_shredded;
----
physical_plan	<REGEX>:.*jsono\.shreds\.\$\.kind\.value.*

# A json-valued non-shred extract still avoids reconstruction, but the residual wrapper also checks
# the parent row validity so a NULL shredded value stays top-level NULL rather than
# struct_pack(NULL body).
query II
EXPLAIN SELECT to_json(jsono_extract(j, '$.o')) AS r FROM jsono_extract_shredded;
----
physical_plan	<REGEX>:.*Projections: j.*

statement ok
PRAGMA explain_output='all';

# Results match the same extracts over the plain-equivalent document (compared against plain rather
# than the core-named ->> because ->> over a shredded value is only correct with the optimizer; the
# jsono-named extracts are bind-correct and so survive the verifier's unoptimized re-run).
query IIIII
SELECT
  jsono_extract_string(j, '$.kind'),
  jsono_extract_string(j, '$.kind') = jsono_extract_string(jsono('{"kind":"commit","n":7,"o":{"x":1}}'), '$.kind'),
  jsono_extract_string(j, '$.n'),
  to_json(jsono_extract(j, '$.o')),
  to_json(jsono_extract(j, '$.o')) = to_json(jsono_extract(jsono('{"kind":"commit","n":7,"o":{"x":1}}'), '$.o'))
FROM jsono_extract_shredded;
----
commit	true	7	{"x":1}	true

# A CAST(jsono_extract_string(shred) AS T) where the shred's own type is T folds to a typed shred read
# (the COALESCE-with-residual-fallback shape), like the core ->> typed-shred fold.
query I
SELECT jsono_extract_string(j, '$.n')::BIGINT = 7 FROM jsono_extract_shredded;
----
true

# --- jsono_type / jsono_keys over a shredded value read the residual natively when the path touches
#     no shred (and jsono_type's whole-document form always does — the root type is shred-invariant),
#     instead of reconstructing the full value. ---

statement ok
CREATE TABLE jsono_introspect_shredded AS
SELECT jsono('{"a":1,"b":{"c":2},"name":"x"}', shredding := {'$.a':'BIGINT','name':'VARCHAR'}) AS j;

statement ok
PRAGMA explain_output='physical_only';

# A residual (non-shred) path carries parent row validity so NULL shredded values stay top-level NULL.
query II
EXPLAIN SELECT jsono_type(j, '$.b') AS r FROM jsono_introspect_shredded;
----
physical_plan	<REGEX>:.*Projections: j.*

# The whole-document type form uses the same parent-validity-preserving residual read.
query II
EXPLAIN SELECT jsono_type(j) AS r FROM jsono_introspect_shredded;
----
physical_plan	<REGEX>:.*Projections: j.*

# jsono_keys of a residual subtree uses the same parent-validity-preserving residual read.
query II
EXPLAIN SELECT jsono_keys(j, '$.b') AS r FROM jsono_introspect_shredded;
----
physical_plan	<REGEX>:.*Projections: j.*

statement ok
PRAGMA explain_output='all';

# Results match the plain-equivalent document — including the shred-path and whole-keys forms, which
# still reconstruct (a shred leaf is stripped from the residual).
query IIIII
SELECT
  jsono_type(j) = jsono_type(jsono('{"a":1,"b":{"c":2},"name":"x"}')),
  jsono_type(j, '$.b') = jsono_type(jsono('{"a":1,"b":{"c":2},"name":"x"}'), '$.b'),
  jsono_type(j, '$.a') = jsono_type(jsono('{"a":1,"b":{"c":2},"name":"x"}'), '$.a'),
  jsono_keys(j, '$.b') = jsono_keys(jsono('{"a":1,"b":{"c":2},"name":"x"}'), '$.b'),
  jsono_keys(j) = jsono_keys(jsono('{"a":1,"b":{"c":2},"name":"x"}'))
FROM jsono_introspect_shredded;
----
true	true	true	true	true

# --- O-2: matcher fuse over a shredded column. The shredded rewrite turns each non-shred extract
#     predicate into jsono_extract_string over a residual reinterpret (a CASE wrapping
#     __jsono_internal_checked_residual). The matcher groups predicates by that residual source
#     (Expression::Equals) so >=2 residual predicates over one shredded column fuse into a single
#     __jsono_internal_match reading the residual once with one manifest check, instead of K
#     independent residual reads. (Uses the jsono-named extract so the bind does not depend on core
#     json's STRUCT->JSON ->>, which the unittest binary does not autoload.) ---

statement ok
CREATE TABLE jsono_matcher_shredded AS
SELECT jsono(payload, shredding := {'$.kind':'VARCHAR'}) AS j
FROM (
  VALUES
    ('{"kind":"commit","city":"sea","os":"mac","browser":"ff"}'),
    ('{"kind":"identity","city":"nyc","os":"win","browser":"chrome"}'),
    ('{"kind":"commit","city":"sea","os":"mac","browser":"chrome"}')
) t(payload);

statement ok
PRAGMA explain_output='physical_only';

# Three residual (non-shred) equality predicates over one shredded column fuse into a single
# __jsono_internal_match: the residual is read once with one manifest check, so the plan carries
# exactly one checked_residual and no standalone jsono_extract_string.
query II
EXPLAIN SELECT count(*) FROM jsono_matcher_shredded
WHERE (jsono_extract_string(j, '$.city') = 'sea')
  AND (jsono_extract_string(j, '$.os') = 'mac')
  AND (jsono_extract_string(j, '$.browser') = 'chrome');
----
physical_plan	<REGEX>:.*__jsono_internal_match.*

query II
EXPLAIN SELECT count(*) FROM jsono_matcher_shredded
WHERE (jsono_extract_string(j, '$.city') = 'sea')
  AND (jsono_extract_string(j, '$.os') = 'mac')
  AND (jsono_extract_string(j, '$.browser') = 'chrome');
----
physical_plan	<!REGEX>:.*jsono_extract_string.*

# An IN predicate group fuses too.
query II
EXPLAIN SELECT count(*) FROM jsono_matcher_shredded
WHERE (jsono_extract_string(j, '$.city') IN ['sea', 'nyc'])
  AND (jsono_extract_string(j, '$.os') IN ['mac', 'win']);
----
physical_plan	<REGEX>:.*__jsono_internal_match.*

# Range comparisons fuse as well — the canonical analytics filter shape mixes one equality with a
# range, which alone would leave the group below the >=2 threshold. Also with the constant on the
# left (the comparison flips).
query II
EXPLAIN SELECT count(*) FROM jsono_matcher_shredded
WHERE (jsono_extract_string(j, '$.city') = 'sea')
  AND (jsono_extract_string(j, '$.browser') >= 'c');
----
physical_plan	<REGEX>:.*__jsono_internal_match.*

query II
EXPLAIN SELECT count(*) FROM jsono_matcher_shredded
WHERE (jsono_extract_string(j, '$.city') > 'a')
  AND ('n' > jsono_extract_string(j, '$.os'));
----
physical_plan	<REGEX>:.*__jsono_internal_match.*

statement ok
