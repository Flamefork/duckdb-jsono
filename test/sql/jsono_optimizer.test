# Shredded twin of the range parity above: a fused range over a RESIDUAL path of a SHREDDED column.
# A sibling ($.tag) is shredded so city/n stay in the residual; the two predicates over one residual
# path fuse into __jsono_internal_match. Its parity oracle is the plain jsono_matcher_range table
# (optimizer ON) rather than `disabled_optimizers='extension'`: jsono_extract_string over a shredded
# value is a hard Binder Error with the extension optimizer off (the unsafe STRUCT cast is refused),
# so a shredded column can only be checked against its plain equivalent, never re-run unoptimized.
# Identical residual bytes => identical rows, text-vs-numeric order ('10' < '9') included.
statement ok
CREATE TABLE jsono_matcher_shredded_range AS
SELECT jsono(payload, shredding := {'$.tag':'VARCHAR'}) AS j
FROM (
  VALUES
    ('{"tag":"t","city":"sea","n":10}'),
    ('{"tag":"t","city":"se","n":9}'),
    ('{"tag":"t","city":"nyc","n":100}'),
    ('{"tag":"t","n":5}'),
    ('{"tag":"t","city":"tokyo"}')
) t(payload);

statement ok
PRAGMA explain_output='physical_only';

# Two range predicates over one residual path fuse into a single __jsono_internal_match.
query II
EXPLAIN SELECT count(*) FROM jsono_matcher_shredded_range
WHERE (jsono_extract_string(j, '$.city') >= 'se') AND (jsono_extract_string(j, '$.city') < 'sea1');
----
physical_plan	<REGEX>:.*__jsono_internal_match.*

statement ok
PRAGMA explain_output='all';

# Prefix-order parity: the shredded residual range returns exactly the plain jsono_matcher_range rows
# (symmetric EXCEPT is empty), so 'se' < 'sea' and the inclusive/exclusive bounds match the plain run.
query I
SELECT count(*)
FROM (
  (SELECT jsono_extract_string(j, '$.city') AS city, jsono_extract_string(j, '$.n') AS n
   FROM jsono_matcher_shredded_range
   WHERE (jsono_extract_string(j, '$.city') >= 'se') AND (jsono_extract_string(j, '$.city') < 'sea1')
   EXCEPT ALL
   SELECT jsono_extract_string(j, '$.city') AS city, jsono_extract_string(j, '$.n') AS n
   FROM jsono_matcher_range
   WHERE (jsono_extract_string(j, '$.city') >= 'se') AND (jsono_extract_string(j, '$.city') < 'sea1'))
  UNION ALL
  (SELECT jsono_extract_string(j, '$.city') AS city, jsono_extract_string(j, '$.n') AS n
   FROM jsono_matcher_range
   WHERE (jsono_extract_string(j, '$.city') >= 'se') AND (jsono_extract_string(j, '$.city') < 'sea1')
   EXCEPT ALL
   SELECT jsono_extract_string(j, '$.city') AS city, jsono_extract_string(j, '$.n') AS n
   FROM jsono_matcher_shredded_range
   WHERE (jsono_extract_string(j, '$.city') >= 'se') AND (jsono_extract_string(j, '$.city') < 'sea1'))
);
----
0

# Text-vs-numeric order parity: numbers compare as their `->>` text, so ('$.n' > '10') AND
# ('$.n' <= '9') matches every present n on the shredded residual exactly as on the plain document.
query II
SELECT
  (SELECT count(*) FROM jsono_matcher_shredded_range
   WHERE (jsono_extract_string(j, '$.n') > '10') AND (jsono_extract_string(j, '$.n') <= '9')),
  (SELECT count(*) FROM jsono_matcher_range
   WHERE (jsono_extract_string(j, '$.n') > '10') AND (jsono_extract_string(j, '$.n') <= '9'));
----
3	3

# Correctness: the fused matcher returns the same rows as the plain-equivalent documents.
query III
SELECT
  jsono_extract_string(j, '$.city') AS city,
  jsono_extract_string(j, '$.browser') AS browser,
  jsono_extract_string(j, '$.kind') AS kind
FROM jsono_matcher_shredded
WHERE (jsono_extract_string(j, '$.city') = 'sea')
  AND (jsono_extract_string(j, '$.os') = 'mac')
  AND (jsono_extract_string(j, '$.browser') = 'chrome')
ORDER BY ALL;
----
sea	chrome	commit

# The fused matcher honours the shred manifest: a row narrowed by a raw struct cast (the dropped
# shred's value is gone from the residual) fails loud on the fused residual read, not a silent
# non-match. Build the narrowed row the same way the cast-guard test does.
statement ok
CREATE TABLE jsono_matcher_narrow AS SELECT jsono('{}', shredding := {'$.a':'VARCHAR'}) AS j WHERE false;

statement ok
SET disabled_optimizers='extension';

statement ok
INSERT INTO jsono_matcher_narrow SELECT jsono('{"a":"v1","b":"v2","c":"v3"}', shredding := {'$.a':'VARCHAR','$.b':'VARCHAR','$.c':'VARCHAR'});

statement ok
RESET disabled_optimizers;

statement error
SELECT count(*) FROM jsono_matcher_narrow
WHERE (jsono_extract_string(j, '$.b') = 'v2') AND (jsono_extract_string(j, '$.c') = 'v3');
----
narrowed by a raw struct cast

# --- P-trie: the fused projector walks one trie per row instead of N independent locate descents.
#     This pins "trie projector == locate oracle": for every shape the fuse admits (flat keys,
#     shared-prefix nesting, a forward array index, a missing key, a JSON-null value, a present
#     container), the fused __jsono_internal_project STRUCT must be byte-identical to the same paths
#     read one-by-one via jsono_extract_string (the single-path locate reader). The jsono-named
#     extract keeps the oracle off core json's STRUCT->JSON ->>, which the unittest binary does not
#     autoload.
statement ok
CREATE TABLE jsono_project_trie_probe AS
SELECT row_id, jsono(payload) AS j
FROM (
  VALUES
    (1, '{"kind":"commit","a":{"b":{"x":"bx1","y":"by1"}},"arr":["e0","e1"],"o":{"k":1},"n":null}'),
    (2, '{"kind":"identity","a":{"b":{"x":"bx2"}},"arr":["z0"],"o":{"k":2},"n":"present"}'),
    (3, '{"kind":"commit","a":{"b":{"y":"by3"}},"o":{"k":3}}'),
    (4, '{"kind":"commit","a":"scalar","arr":[],"n":null}'),
    (5, '{"kind":null,"a":{"b":{"x":"bx5","y":"by5"}},"arr":["q0","q1","q2"],"o":{"k":5},"n":7}')
) t(row_id, payload);

statement ok
PRAGMA explain_output='physical_only';

# The select-after projection fuses the six distinct ->> paths into one __jsono_internal_project.
query II
EXPLAIN SELECT row_id,
               jsono_extract_string(j, '$.kind') AS kind,
               jsono_extract_string(j, '$.a.b.x') AS abx,
               jsono_extract_string(j, '$.a.b.y') AS aby,
               jsono_extract_string(j, '$.arr[1]') AS arr1,
               jsono_extract_string(j, '$.o') AS obj,
               jsono_extract_string(j, '$.n') AS nval,
               jsono_extract_string(j, '$.missing') AS miss
FROM jsono_project_trie_probe;
----
physical_plan	<REGEX>:.*__jsono_internal_project.*

statement ok
PRAGMA explain_output='all';

# Locate oracle: the same paths read one-by-one with the extension optimizer disabled, so each
# extract is a standalone single-path locate descent (no trie fuse).
statement ok
SET disabled_optimizers='extension';

statement ok
CREATE TEMP TABLE jsono_project_trie_oracle AS
SELECT row_id,
       jsono_extract_string(j, '$.kind') AS kind,
       jsono_extract_string(j, '$.a.b.x') AS abx,
       jsono_extract_string(j, '$.a.b.y') AS aby,
       jsono_extract_string(j, '$.arr[1]') AS arr1,
       jsono_extract_string(j, '$.o') AS obj,
       jsono_extract_string(j, '$.n') AS nval,
       jsono_extract_string(j, '$.missing') AS miss
FROM jsono_project_trie_probe;

statement ok
RESET disabled_optimizers;

# The trie projector (optimizer on) must match the locate oracle on every row and column, NULLs
# included: symmetric EXCEPT over the full projected tuple is empty.
query I
SELECT count(*)
FROM (
  (SELECT * FROM jsono_project_trie_oracle EXCEPT
   SELECT row_id,
          jsono_extract_string(j, '$.kind') AS kind,
          jsono_extract_string(j, '$.a.b.x') AS abx,
          jsono_extract_string(j, '$.a.b.y') AS aby,
          jsono_extract_string(j, '$.arr[1]') AS arr1,
          jsono_extract_string(j, '$.o') AS obj,
          jsono_extract_string(j, '$.n') AS nval,
          jsono_extract_string(j, '$.missing') AS miss
   FROM jsono_project_trie_probe)
  UNION ALL
  (SELECT row_id,
          jsono_extract_string(j, '$.kind') AS kind,
          jsono_extract_string(j, '$.a.b.x') AS abx,
          jsono_extract_string(j, '$.a.b.y') AS aby,
          jsono_extract_string(j, '$.arr[1]') AS arr1,
          jsono_extract_string(j, '$.o') AS obj,
          jsono_extract_string(j, '$.n') AS nval,
          jsono_extract_string(j, '$.missing') AS miss
   FROM jsono_project_trie_probe
   EXCEPT SELECT * FROM jsono_project_trie_oracle)
);
----
0

# Explicit row-by-row values, so a divergence shows the offending shape (a present container
# serializes the whole subtree; a missing key and a JSON null both read NULL; a scalar at an
# object-key prefix nulls the subtree below it).
query IIIIIIII
SELECT row_id,
       jsono_extract_string(j, '$.kind') AS kind,
       jsono_extract_string(j, '$.a.b.x') AS abx,
       jsono_extract_string(j, '$.a.b.y') AS aby,
       jsono_extract_string(j, '$.arr[1]') AS arr1,
       jsono_extract_string(j, '$.o') AS obj,
       jsono_extract_string(j, '$.n') AS nval,
       jsono_extract_string(j, '$.missing') AS miss
FROM jsono_project_trie_probe
ORDER BY row_id;
----
1	commit	bx1	by1	e1	{"k":1}	NULL	NULL
2	identity	bx2	NULL	NULL	{"k":2}	present	NULL
3	commit	NULL	by3	NULL	{"k":3}	NULL	NULL
4	commit	NULL	NULL	NULL	NULL	NULL	NULL
5	NULL	bx5	by5	q1	{"k":5}	7	NULL

