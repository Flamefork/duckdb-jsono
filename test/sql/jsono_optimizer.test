    ('wide_numeric_to_string', '{"x":"9999999999999"}'),
    ('wide_numeric_to_string', '{"x":"abc"}'),
    ('wide_numeric_to_string', '{"x":null}'),
    ('wide_width_mismatch', '{"x":9999999999999}'),
    ('wide_width_mismatch', '{"x":123456789012345}')
) AS rows(group_id, payload);

statement ok
