# Fused range parity with the unfused comparison, on DuckDB's binary VARCHAR order: bounds are
# inclusive/exclusive exactly as written, a strict prefix sorts first ('se' < 'sea'), numbers
# compare as their `->>` text ('10' < '9'), and an absent path never matches. The fused rows must
# equal the same filter with the extension optimizer disabled.
statement ok
CREATE TABLE jsono_matcher_range AS
SELECT jsono(payload) AS j
FROM (
  VALUES
    ('{"city":"sea","n":10}'),
    ('{"city":"se","n":9}'),
    ('{"city":"nyc","n":100}'),
    ('{"n":5}'),
    ('{"city":"tokyo"}')
) t(payload);

query II
SELECT jsono_extract_string(j, '$.city'), jsono_extract_string(j, '$.n')
FROM jsono_matcher_range
WHERE (jsono_extract_string(j, '$.city') >= 'se')
  AND (jsono_extract_string(j, '$.city') < 'sea1')
ORDER BY ALL;
----
se	9
sea	10

query I
SELECT count(*) FROM jsono_matcher_range
WHERE (jsono_extract_string(j, '$.n') > '10') AND (jsono_extract_string(j, '$.n') <= '9');
----
3

# Constant-on-left ranges flip into the fused matcher; the flipped direction must hold BY VALUE
# for every operator (an EXPLAIN alone stays green under a wrong flip). Binary order here:
# nyc < se < sea < tokyo. 'se' <= city AND 'tokyo' > city keeps [se, tokyo) — the inclusive and
# exclusive bounds land on se/sea exactly as the right-side spelling.
statement ok
PRAGMA explain_output='physical_only';

query II
EXPLAIN SELECT count(*) FROM jsono_matcher_range
WHERE ('se' <= jsono_extract_string(j, '$.city'))
  AND ('tokyo' > jsono_extract_string(j, '$.city'));
