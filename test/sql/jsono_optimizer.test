# --- json_quote over a shredded value takes the SAME whole-value reconstruct rewrite as to_json
#     (the optimizer's to_json/json_quote branch), so json_quote(shredded) == to_json(shredded). Reuses
#     the jsono_extract_shredded fixture ({"kind":"commit","n":7,"o":{"x":1}} shredded on kind + n). ---

# Value parity on a shredded fixture: json_quote reconstructs the same document to_json does, and both
# equal the plain-equivalent to_json (compared against the plain literal, like the extract block above,
# because json_quote over a shredded value is only correct with the optimizer). Cast to VARCHAR so the
# comparison is over the rendered text.
query II
SELECT json_quote(j)::VARCHAR = to_json(j)::VARCHAR,
       json_quote(j)::VARCHAR = to_json(jsono('{"kind":"commit","n":7,"o":{"x":1}}'))::VARCHAR
FROM jsono_extract_shredded;
----
true	true

statement ok
PRAGMA explain_output='physical_only';

