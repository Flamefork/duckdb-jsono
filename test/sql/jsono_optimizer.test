  AND (j->>'$.commit.operation' = 'create')
  AND (j->>'$.commit.collection' IN ['app.bsky.feed.post', 'app.bsky.feed.like'])
GROUP BY event, time_bucket
ORDER BY event, time_bucket;

statement ok
