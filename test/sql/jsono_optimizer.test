# The other two flipped operators: 'se' < city AND 'sea' >= city keeps (se, sea].
query II
SELECT jsono_extract_string(j, '$.city'), jsono_extract_string(j, '$.n')
FROM jsono_matcher_range
WHERE ('se' < jsono_extract_string(j, '$.city'))
  AND ('sea' >= jsono_extract_string(j, '$.city'))
ORDER BY ALL;
