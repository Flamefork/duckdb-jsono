# The optimizer injects __jsono_internal_match / _project / _*_varchar_fast fully
# bound and unregistered in the catalog. Debug builds verify every optimized plan
# by round-tripping its expressions through (de)serialization, and verify_serializer
# forces the same round-trip here. Each helper must decline serialization instead of
# failing a catalog lookup for its (unregistered) name. The probes below keep simple,
# fully-serializable plans so verify_serializer actually exercises the round-trip.
statement ok
PRAGMA verify_serializer;

# __jsono_internal_min_varchar_fast / __jsono_internal_max_varchar_fast
query TTT
SELECT group_id,
       MIN(j->>'$.x') AS min_x,
       MAX(j->>'$.x') AS max_x
FROM jsono_optimizer_extrema_probe
GROUP BY group_id
ORDER BY group_id;
----
different_width	10	9
leading_zero_strings	001	010
negative	-1	2
null_missing	7	7
object_array	[2]	{"a":1}
same_width	100	200
wide_numeric_to_string	9999999999999	abc
wide_width_mismatch	123456789012345	9999999999999

# __jsono_internal_match
query T
SELECT j->>'$.did' AS user_id
FROM jsono_optimizer_probe
WHERE (j->>'$.kind' = 'commit')
  AND (j->>'$.commit.operation' = 'create')
  AND (j->>'$.commit.collection' = 'app.bsky.feed.post')
ORDER BY user_id;
----
u1
u1

# __jsono_internal_project
query TI
SELECT j->>'$.commit.collection' AS event,
       count() AS count
FROM jsono_optimizer_probe
WHERE (j->>'$.kind' = 'commit')
  AND (j->>'$.commit.operation' = 'create')
  AND (j->>'$.commit.collection' IN ['app.bsky.feed.post', 'app.bsky.feed.like'])
GROUP BY event
ORDER BY event;
----
app.bsky.feed.like	1
app.bsky.feed.post	2

# __jsono_internal_project inserted above a plain projection (select-after-filter)
query TT
SELECT j->>'$.did' AS did,
       j->>'$.commit.collection' AS event
FROM jsono_optimizer_probe
WHERE (j->>'$.kind' = 'commit')
  AND (j->>'$.commit.operation' = 'create')
ORDER BY ALL;
----
u1	app.bsky.feed.post
u1	app.bsky.feed.post
u2	app.bsky.feed.like
u5	NULL

# __jsono_internal_double_text: a typed DOUBLE shred read for its text renders through jsono's own
# double formatter (== to_json), not DuckDB's native cast. The helper is injected fully bound and
# must decline serialization like the others, so this round-trips under verify_serializer.
# (jsono_extract_string keeps this file free of a `require json` the bare `->>` over a shred needs.)
statement ok
CREATE TEMP TABLE jsono_double_shred_probe AS
SELECT jsono({'n': d}) AS j FROM (VALUES (1e16::DOUBLE), (1e-7::DOUBLE), (0.1::DOUBLE)) t(d);

query T
SELECT jsono_extract_string(j, '$.n') AS n FROM jsono_double_shred_probe ORDER BY n;
----
0.1
10000000000000000.0
1e-7

