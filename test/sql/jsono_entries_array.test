# name: test/sql/jsono_entries_array.test
# description: jsono_entries over a LIST<STRUCT> array shred — lifted element subfields expand to leaf entries, parity with a plain parse
# group: [sql]

require jsono

require json

# An array shred expands each element's lifted subfields into leaf entries keyed by element index,
# exactly as a plain parse flattens the same array of objects.
query II
SELECT e.key, e.value FROM (
  SELECT unnest(jsono_entries(jsono('{"products":[{"id":1,"name":"a"},{"id":2,"name":"b"}]}',
                                    shredding := {'$.products':'STRUCT(id UBIGINT, name VARCHAR)[]'}))) AS e
) ORDER BY ALL;
----
$.products[0].id	1
$.products[0].name	a
$.products[1].id	2
$.products[1].name	b

# Dotted key style indexes elements as a `.N` segment, again matching a plain parse.
query II
SELECT e.key, e.value FROM (
  SELECT unnest(jsono_entries(jsono('{"products":[{"id":1,"name":"a"}]}',
                                    shredding := {'$.products':'STRUCT(id UBIGINT, name VARCHAR)[]'}),
                              key_style := 'dotted')) AS e
) ORDER BY ALL;
----
products.0.id	1
products.0.name	a

# The lifted subfields (shred) and the element tail / explicit-null / type-mismatch / non-object
# elements (residual) combine into the full leaf set — shown explicitly here, sorted.
query II
SELECT e.key, e.value FROM (
  SELECT unnest(jsono_entries(jsono('{"products":[{"id":1,"name":"a","sku":"S1"},5,null,{"id":2},{"id":null,"name":"b"},{"id":"x","name":"c"}]}',
                                    shredding := {'$.products':'STRUCT(id UBIGINT, name VARCHAR)[]'}))) AS e
) ORDER BY ALL;
----
$.products[0].id	1
$.products[0].name	a
$.products[0].sku	S1
$.products[1]	5
$.products[2]	NULL
$.products[3].id	2
$.products[4].id	NULL
$.products[4].name	b
$.products[5].id	x
$.products[5].name	c

# Differential: entries(shredded) must equal entries(plain) as a multiset for the same complex shape.
query I
SELECT (SELECT count(*) FROM (
          SELECT unnest(jsono_entries(jsono('{"products":[{"id":1,"name":"a","sku":"S1"},5,null,{"id":2},{"id":null,"name":"b"},{"id":"x","name":"c"}]}',
                                            shredding := {'$.products':'STRUCT(id UBIGINT, name VARCHAR)[]'})))
          EXCEPT ALL
          SELECT unnest(jsono_entries(jsono('{"products":[{"id":1,"name":"a","sku":"S1"},5,null,{"id":2},{"id":null,"name":"b"},{"id":"x","name":"c"}]}'))))) +
       (SELECT count(*) FROM (
          SELECT unnest(jsono_entries(jsono('{"products":[{"id":1,"name":"a","sku":"S1"},5,null,{"id":2},{"id":null,"name":"b"},{"id":"x","name":"c"}]}')))
          EXCEPT ALL
          SELECT unnest(jsono_entries(jsono('{"products":[{"id":1,"name":"a","sku":"S1"},5,null,{"id":2},{"id":null,"name":"b"},{"id":"x","name":"c"}]}',
                                            shredding := {'$.products':'STRUCT(id UBIGINT, name VARCHAR)[]'})))));
----
0

# Mixed shred set: a top-level scalar shred (kind) and an array shred (products) both expand, with
# parity to the plain form.
query II
SELECT e.key, e.value FROM (
  SELECT unnest(jsono_entries(jsono('{"kind":"order","products":[{"id":1,"name":"a"}],"note":"x"}',
                                    shredding := {'$.kind':'VARCHAR','$.products':'STRUCT(id UBIGINT, name VARCHAR)[]'}))) AS e
) ORDER BY ALL;
----
$.kind	order
$.note	x
$.products[0].id	1
$.products[0].name	a

# Nested array path shreds and expands under its parent path.
query II
SELECT e.key, e.value FROM (
  SELECT unnest(jsono_entries(jsono('{"order":{"items":[{"sku":"s1","qty":2}]}}',
                                    shredding := {'$.order.items':'STRUCT(sku VARCHAR, qty UBIGINT)[]'}))) AS e
) ORDER BY ALL;
----
$.order.items[0].qty	2
$.order.items[0].sku	s1

# Empty array and absent array path expand to nothing (no element leaves), matching plain.
query II
SELECT e.key, e.value FROM (
  SELECT unnest(jsono_entries(jsono('{"products":[],"other":true}',
                                    shredding := {'$.products':'STRUCT(id UBIGINT)[]'}))) AS e
) ORDER BY ALL;
----
$.other	true

# A VARCHAR subfield only strips a real JSON string; a non-string (here a boolean) stays in the
# residual with a NULL slot, so it must be emitted once (by the residual). The stripped string
# subfield is emitted once by the overlay. No duplicate keys.
query II
SELECT e.key, e.value FROM (
  SELECT unnest(jsono_entries(jsono('{"products":[{"id":1,"name":false},{"id":2,"name":"real"}]}',
                                    shredding := {'$.products':'STRUCT(id UBIGINT, name VARCHAR)[]'}))) AS e
) ORDER BY ALL;
----
$.products[0].id	1
$.products[0].name	false
$.products[1].id	2
$.products[1].name	real

# Multi-row differential over a table, including empty array, missing path, and a NULL row: each
# row's shredded entries match its plain entries (row id keeps the comparison per-row).
statement ok
CREATE TABLE arr_entries AS
SELECT * FROM (VALUES
    (1, '{"products":[{"id":1,"name":"a"},{"id":2,"name":"bb","sku":"S"}]}'),
    (2, '{"products":[]}'),
    (3, '{"other":true}'),
    (4, NULL)
) AS v(id, doc);

query I
WITH s AS (SELECT id, unnest(jsono_entries(jsono(doc, shredding := {'$.products':'STRUCT(id UBIGINT, name VARCHAR)[]'}))) AS e FROM arr_entries),
     p AS (SELECT id, unnest(jsono_entries(jsono(doc))) AS e FROM arr_entries)
SELECT (SELECT count(*) FROM (SELECT * FROM s EXCEPT ALL SELECT * FROM p)) +
       (SELECT count(*) FROM (SELECT * FROM p EXCEPT ALL SELECT * FROM s));
----
0

# =====================================================================================
# array_style := 'whole_json' over shredded arrays (plan 031 §8): the shredded array renders
# as the SAME single whole-array JSON leaf as the equivalent residual array. Reconstruction
# goes through the validated read path (the plan-029 array-shred landmine), never a naive walker.
# =====================================================================================

# A scalar-array shred (goalsID — the events4 segfault shape) renders as one whole-JSON leaf.
query II
SELECT e.key, e.value FROM (
  SELECT unnest(jsono_entries(jsono('{"goalsID":[1,2]}', shredding := {'$.goalsID':'BIGINT[]'}),
                              array_style := 'whole_json')) AS e
) ORDER BY ALL;
----
$.goalsID	[1,2]

# An object-array shred (LIST<STRUCT>) renders as one whole-JSON leaf, all element fields in order.
query II
SELECT e.key, e.value FROM (
  SELECT unnest(jsono_entries(jsono('{"items":[{"sku":"a"}]}', shredding := {'$.items':'STRUCT(sku VARCHAR)[]'}),
                              array_style := 'whole_json')) AS e
) ORDER BY ALL;
----
$.items	[{"sku":"a"}]

# Mixed shred set, dotted: a scalar shred (kind) plus an object-array shred (products), each a
# whole-JSON leaf for the array; the residual scalar (note) stays bare text.
query II
SELECT e.key, e.value FROM (
  SELECT unnest(jsono_entries(jsono('{"kind":"order","products":[{"id":1,"name":"a"},{"id":2,"name":"b"}],"note":"x"}',
                                    shredding := {'$.kind':'VARCHAR','$.products':'STRUCT(id UBIGINT, name VARCHAR)[]'}),
                              key_style := 'dotted', array_style := 'whole_json')) AS e
) ORDER BY ALL;
----
kind	order
note	x
products	[{"id":1,"name":"a"},{"id":2,"name":"b"}]

# §8 parity law: whole_json over a shredded array == whole_json over the same plain doc, as a
# multiset, across a complex shape with residual tail (sku), non-object/null/type-mismatch elements.
query I
SELECT (SELECT count(*) FROM (
          SELECT unnest(jsono_entries(jsono('{"products":[{"id":1,"name":"a","sku":"S1"},5,null,{"id":2},{"id":"x"}]}',
                                            shredding := {'$.products':'STRUCT(id UBIGINT, name VARCHAR)[]'}),
                                      array_style := 'whole_json'))
          EXCEPT ALL
          SELECT unnest(jsono_entries(jsono('{"products":[{"id":1,"name":"a","sku":"S1"},5,null,{"id":2},{"id":"x"}]}'),
                                      array_style := 'whole_json')))) +
       (SELECT count(*) FROM (
          SELECT unnest(jsono_entries(jsono('{"products":[{"id":1,"name":"a","sku":"S1"},5,null,{"id":2},{"id":"x"}]}'),
                                      array_style := 'whole_json'))
          EXCEPT ALL
          SELECT unnest(jsono_entries(jsono('{"products":[{"id":1,"name":"a","sku":"S1"},5,null,{"id":2},{"id":"x"}]}',
                                            shredding := {'$.products':'STRUCT(id UBIGINT, name VARCHAR)[]'}),
                                      array_style := 'whole_json'))));
----
0

# Multi-row whole_json parity over a table (empty array, missing path, NULL row): shredded == plain.
query I
WITH s AS (SELECT id, unnest(jsono_entries(jsono(doc, shredding := {'$.products':'STRUCT(id UBIGINT, name VARCHAR)[]'}), array_style := 'whole_json')) AS e FROM arr_entries),
     p AS (SELECT id, unnest(jsono_entries(jsono(doc), array_style := 'whole_json')) AS e FROM arr_entries)
SELECT (SELECT count(*) FROM (SELECT * FROM s EXCEPT ALL SELECT * FROM p)) +
       (SELECT count(*) FROM (SELECT * FROM p EXCEPT ALL SELECT * FROM s));
----
0

# =====================================================================================
# plan 039: a scalar-array shred whose lane name needs quoting must derive its base key
# through ShredNamePath + the walk builders. A mismatched base key makes the placeholder-
# suppression set miss its walk-built paths, so each lifted element is emitted TWICE — the
# residual `null` placeholder AND the shred overlay value.
# =====================================================================================

# quoted spec spelling ($."tags.raw"): the dotted base key must not carry JSONPath quotes;
# a mismatch double-emits (residual null + shred value) under key_style := 'dotted'.
query II
SELECT e.key, e.value FROM (
  SELECT unnest(jsono_entries(jsono('{"tags.raw":["a","b"],"k":1}', shredding := {'$."tags.raw"':'VARCHAR[]'}),
                              key_style := 'dotted')) AS e
) ORDER BY ALL;
----
k	1
tags.raw.0	a
tags.raw.1	b

# bare-literal spec spelling (tags.raw): the jsonpath base key must quote the dotted key;
# a mismatch double-emits under the default jsonpath style.
query II
SELECT e.key, e.value FROM (
  SELECT unnest(jsono_entries(jsono('{"tags.raw":["a","b"],"k":1}', shredding := {'tags.raw':'VARCHAR[]'}))) AS e
) ORDER BY ALL;
----
$."tags.raw"[0]	a
$."tags.raw"[1]	b
$.k	1

# parity-with-plain oracle: each lifted element appears exactly once, every spelling × style.
query I
SELECT (SELECT count(*) FROM (
          SELECT unnest(jsono_entries(jsono('{"tags.raw":["a","b"],"k":1}', shredding := {'$."tags.raw"':'VARCHAR[]'}), key_style := 'dotted'))
          EXCEPT ALL
          SELECT unnest(jsono_entries(jsono('{"tags.raw":["a","b"],"k":1}'), key_style := 'dotted'))))
     + (SELECT count(*) FROM (
          SELECT unnest(jsono_entries(jsono('{"tags.raw":["a","b"],"k":1}'), key_style := 'dotted'))
          EXCEPT ALL
          SELECT unnest(jsono_entries(jsono('{"tags.raw":["a","b"],"k":1}', shredding := {'$."tags.raw"':'VARCHAR[]'}), key_style := 'dotted'))))
     + (SELECT count(*) FROM (
          SELECT unnest(jsono_entries(jsono('{"tags.raw":["a","b"],"k":1}', shredding := {'tags.raw':'VARCHAR[]'})))
          EXCEPT ALL
          SELECT unnest(jsono_entries(jsono('{"tags.raw":["a","b"],"k":1}')))))
     + (SELECT count(*) FROM (
          SELECT unnest(jsono_entries(jsono('{"tags.raw":["a","b"],"k":1}')))
          EXCEPT ALL
          SELECT unnest(jsono_entries(jsono('{"tags.raw":["a","b"],"k":1}', shredding := {'tags.raw':'VARCHAR[]'})))));
----
0

# =====================================================================================
# Parquet round-trip: an array-shredded value (the LIST<STRUCT> lane + residual skeleton) is written
# to Parquet and read back before jsono_entries. The lane and residual must reassemble byte-identical
# through the physical Parquet vectors, so entries expands the SAME leaf set as the in-memory cases.
# =====================================================================================

require parquet

statement ok
CREATE TABLE arr_entries_pq AS
SELECT jsono('{"products":[{"id":1,"name":"a"},{"id":2,"name":"b"}]}',
             shredding := {'$.products':'STRUCT(id UBIGINT, name VARCHAR)[]'}) AS j;

statement ok
COPY arr_entries_pq TO '__TEST_DIR__/jsono_entries_array.parquet' (FORMAT parquet);

# Leaf expansion (default jsonpath keys) over the Parquet-backed array shred.
query II
SELECT e.key, e.value FROM (
  SELECT unnest(jsono_entries(j)) AS e
  FROM read_parquet('__TEST_DIR__/jsono_entries_array.parquet')
) ORDER BY ALL;
----
$.products[0].id	1
$.products[0].name	a
$.products[1].id	2
$.products[1].name	b

# whole_json array_style over the Parquet-backed array shred renders the one whole-array leaf.
query II
SELECT e.key, e.value FROM (
  SELECT unnest(jsono_entries(j, array_style := 'whole_json')) AS e
  FROM read_parquet('__TEST_DIR__/jsono_entries_array.parquet')
) ORDER BY ALL;
----
$.products	[{"id":1,"name":"a"},{"id":2,"name":"b"}]
