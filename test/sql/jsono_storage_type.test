# name: test/sql/jsono_storage_type.test
# description: jsono_storage_type() exposes the physical STRUCT DDL backing JSONO
# group: [sql]

require jsono

require parquet

require json

# The DDL string is the physical STRUCT layout of a jsono value (no type alias exists).
# Changing it is a deliberate format change — update this expectation on purpose.
query I
SELECT jsono_storage_type();
----
STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB)))

# A column declared with that DDL is structurally a JSONO: jsono ops bind to it
# without an explicit cast, so the round-trip from storage form works.
statement ok
CREATE TABLE t (props STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB))));

statement ok
INSERT INTO t SELECT jsono('{"a":1}');

query I
SELECT jsono_extract_string(props, '$.a') FROM t;
----
1

# The function emits the *real* storage form, not a separately-maintained string:
# the column is already the physical STRUCT, so Parquet reads it back unchanged,
# and that type must print back to exactly jsono_storage_type().
statement ok
COPY (SELECT jsono('{"a":1}') AS props) TO '__TEST_DIR__/jsono_storage_type.parquet';

query I
SELECT typeof(props) = jsono_storage_type() FROM '__TEST_DIR__/jsono_storage_type.parquet';
----
true

# Boundary of the structural match: a STRUCT that is close but not the exact
# four jsono_* BLOB layout must NOT bind to jsono ops. Guards IsJsonoType against
# accidentally widening (it compares names AND types against JsonoRawStructType).
# The functions accept ANY arg0 (to reach shredded values), so a near-miss struct is
# now rejected in the bind with "argument must be JSONO" rather than at overload resolution.

# Wrong field name (jsono_slot, not jsono_slots).
statement error
SELECT jsono_extract_string({'jsono_slot': ''::BLOB, 'jsono_key_heap': ''::BLOB, 'jsono_string_heap': ''::BLOB, 'jsono_skips': ''::BLOB}, '$.a');
----
jsono_extract_string: argument must be JSONO

# Wrong field type (INTEGER where BLOB is required).
statement error
SELECT jsono_extract_string({'jsono_slots': 0, 'jsono_key_heap': ''::BLOB, 'jsono_string_heap': ''::BLOB, 'jsono_skips': ''::BLOB}, '$.a');
----
jsono_extract_string: argument must be JSONO

# Wrong field count (three BLOBs, not four).
statement error
SELECT jsono_extract_string({'jsono_slots': ''::BLOB, 'jsono_key_heap': ''::BLOB, 'jsono_string_heap': ''::BLOB}, '$.a');
----
jsono_extract_string: argument must be JSONO

# jsono_storage_type(shreds) emits the shredded storage DDL: the 6-blob residual plus one shred
# column per spec entry inside the `shreds` struct. The DDL is byte-identical to the type the
# constructor produces from the same shreds (asserted by equality rather than a hardcoded literal).
query I
SELECT jsono_storage_type('event_name VARCHAR, n BIGINT')
     = typeof(jsono('{}', shredding := {'event_name':'VARCHAR','n':'BIGINT'}));
----
true

# Shred order is canonicalized (sorted by name), so the shredded type is a pure function of the shred
# set: a reversed shred order in the DDL or the spec yields the exact same type, not just a compatible
# one. This keeps jsono_storage_type and CREATE TABLE AS SELECT in lockstep regardless of order.
query I
SELECT jsono_storage_type('n BIGINT, event_name VARCHAR')
     = jsono_storage_type('event_name VARCHAR, n BIGINT')
   AND jsono_storage_type('n BIGINT, event_name VARCHAR')
     = typeof(jsono('{}', shredding := {'event_name':'VARCHAR','n':'BIGINT'}));
----
true

# A column declared from that DDL is a valid storage column for a value shredded on the same
# shreds (CTAS infers the shredded type); the shred reads back transparently through ->>.
statement ok
CREATE TABLE probe_shred AS
SELECT jsono('{"event_name":"page_view","a":1}', shredding := {'event_name':'VARCHAR'}) AS e;

query I
SELECT e ->> 'event_name' FROM probe_shred;
----
page_view

# A value shredded on a different — even fully disjoint — shred set lands losslessly: the
# optimizer rewrites the struct cast into reconstruct + reshred against the column's shred set.
statement ok
INSERT INTO probe_shred SELECT jsono('{"x":"y"}', shredding := {'x':'VARCHAR'});

query I
SELECT to_json(e)::VARCHAR FROM probe_shred ORDER BY 1;
----
{"a":1,"event_name":"page_view"}
{"x":"y"}

# Reserved shred names are rejected by the same check the constructor uses (a single source of truth),
# so jsono_storage_type can only emit a type the constructor can actually produce. Without it, a shred
# named '$jsono$set' duplicated the marker field (an unusable type) and 'body' declared a column the
# value path rejects.
statement error
SELECT jsono_storage_type('"$jsono$set" VARCHAR');
----
reserved layout field name

statement error
SELECT jsono_storage_type('body BIGINT');
----
cannot be named 'body'

# Unsupported shred types are rejected here, not only later by the constructor.
statement error
SELECT jsono_storage_type('a INTEGER');
----
unsupported shred type

statement error
SELECT jsono_storage_type('a JSON');
----
unsupported shred type

# The path form '$.body' is a different field name and stays allowed (matches the constructor).
query I
SELECT jsono_storage_type('"$.body" BIGINT') = typeof(jsono('{"body":1}', shredding := {'$.body':'BIGINT'}));
----
true

# Array shreds must address the array by an object-key path, matching the constructor.
statement error
SELECT jsono_storage_type('"$.a[0]" STRUCT(id BIGINT)[]');
----
must address an array by an object-key path

query I
SELECT jsono_storage_type('"$.a" STRUCT(id BIGINT)[]')
     = typeof(jsono('{"a":[{"id":1}]}', shredding := {'$.a':'STRUCT(id BIGINT)[]'}));
----
true

query I
SELECT jsono_storage_type('"$.ids" UBIGINT[]')
     = typeof(jsono('{"ids":[1,2]}', shredding := {'$.ids':'UBIGINT[]'}));
----
true
