# name: test/sql/jsono_roundtrip.test
# description: JSONO writer/reader — round-trip text → JSONO → text
# group: [sql]

require jsono

# Trivial flat object
query I
SELECT to_json(jsono('{"a":1,"b":"hello"}'));
----
{"a":1,"b":"hello"}

# Keys sort alphabetically on the way through
query I
SELECT to_json(jsono('{"c":1,"a":2,"b":3}'));
----
{"a":2,"b":3,"c":1}

# Duplicate keys collapse to the last occurrence (last-wins), so the stored object
# keeps the unique sorted keys the readers' binary search assumes.
query I
SELECT to_json(jsono('{"b":1,"a":1,"b":2,"a":3,"c":9}'));
----
{"a":3,"b":2,"c":9}

# The surviving duplicate value can itself be a nested structure.
query I
SELECT to_json(jsono('{"x":1,"x":{"k":[1,2]}}'));
----
{"x":{"k":[1,2]}}

# Identity, navigation and merge all agree on last-wins for duplicate keys.
query IIII
SELECT
  to_json(jsono('{"a":1,"a":2}')),
  jsono_type(jsono('{"a":1,"a":2}'), '$.a'),
  (jsono_transform(jsono('{"a":1,"a":2}'), {'a':{'type':'BIGINT','path':'$.a'}})).a,
  to_json(jsono_merge_patch(jsono('{"a":1,"a":2}')));
----
{"a":2}	BIGINT	2	{"a":2}

# Nesting — sort applies recursively
query I
SELECT to_json(jsono('{"user":{"name":"alice","age":30}}'));
----
{"user":{"age":30,"name":"alice"}}

# Array order preserved (only object keys get sorted)
query I
SELECT to_json(jsono('[3,1,2,"hi",true,null]'));
----
[3,1,2,"hi",true,null]

# All primitive scalar types round-trip
query I
SELECT to_json(jsono('{"a":42,"b":3.14,"c":true,"d":null,"e":"x"}'));
----
{"a":42,"b":3.14,"c":true,"d":null,"e":"x"}

# Empty containers
query II
SELECT
  to_json(jsono('{}')),
  to_json(jsono('[]'));
----
{}	[]

# Top-level scalar
query I
SELECT to_json(jsono('42'));
----
42

query I
SELECT to_json(jsono('"just a string"'));
----
"just a string"

# Negative integer (exercises i60 sign extension)
query I
SELECT to_json(jsono('-9223372036854775000'));
----
-9223372036854775000

# Int that overflows i60 → INT64_EXT extension slot
query I
SELECT to_json(jsono('{"big":9223372036854775000}'));
----
{"big":9223372036854775000}

# Unsigned integers above BIGINT range round-trip via VAL_EXT/UINT64.
query I
SELECT to_json(jsono('{"u":18446744073709551615}'));
----
{"u":18446744073709551615}

# LIST of STRUCTs — element order matters, key order does not
query I
SELECT to_json(jsono('{"items":[{"id":2,"name":"b"},{"name":"a","id":1}]}'));
----
{"items":[{"id":2,"name":"b"},{"id":1,"name":"a"}]}

# String with escapes round-trips. SQL doesn't interpret backslashes inside
# single-quoted literals, so '{"x":"a\"b\\nc"}' is 16 bytes literally; the
# JSON value decodes to a"b\nc (6 bytes, with backslash+n verbatim, not a
# newline). Re-encoded JSON escapes both the embedded quote and backslash.
query I
SELECT to_json(jsono('{"x":"a\"b\\nc"}'));
----
{"x":"a\"b\\nc"}

# Actual control characters (newline, tab) round-trip via \n / \t escapes
query I
SELECT to_json(jsono('{"line":"a\nb\tc"}'));
----
{"line":"a\nb\tc"}

# NULL input — NULL output
query I
SELECT jsono(NULL);
----
NULL

query I
SELECT try_jsono(NULL);
----
NULL

query I
SELECT to_json(jsono(NULL));
----
NULL

# Invalid JSON — strict constructor errors, tolerant constructor returns NULL.
statement error
SELECT jsono('{not json');
----
jsono: invalid JSON

query I
SELECT try_jsono('{not json') IS NULL;
----
true

# Empty input — strict constructor errors, tolerant constructor returns NULL.
statement error
SELECT jsono('');
----
jsono: input is empty

query I
SELECT try_jsono('') IS NULL;
----
true

require json

# The strict and tolerant constructors share the parse path; the result is the jsono STRUCT.
query II
SELECT
  typeof(jsono('{"a":1}')),
  try_jsono('{bad') IS NULL;
----
STRUCT(jsono_slots BLOB, jsono_key_heap BLOB, jsono_string_heap BLOB, jsono_skips BLOB)	true

statement error
SELECT jsono('{bad');
----
jsono: invalid JSON

query II
SELECT
  CAST(jsono('{"a":1}') AS JSON),
  CAST(jsono('{"a":1}') AS VARCHAR);
----
{"a":1}	{"a":1}

# to_json on a STRUCT with wrong magic bytes - NULL
query I
SELECT to_json({'jsono_slots': 'not jsono'::BLOB, 'jsono_key_heap': ''::BLOB, 'jsono_string_heap': ''::BLOB, 'jsono_skips': ''::BLOB});
----
NULL

# to_json on a structurally valid header with missing container span should fail, not crash.
statement error
SELECT to_json({
  'jsono_slots': unhex('4A534E4F020100000000000000000000'),
  'jsono_key_heap': ''::BLOB,
  'jsono_string_heap': ''::BLOB,
  'jsono_skips': ''::BLOB
});
----
container span

# to_json on a structurally valid header with truncated slot data should fail, not crash.
statement error
SELECT to_json({
  'jsono_slots': unhex('4A534E4F020100000000000000000020'),
  'jsono_key_heap': ''::BLOB,
  'jsono_string_heap': ''::BLOB,
  'jsono_skips': unhex('01000000000000000000000001000000000000000000000000000000')
});
----
malformed JSONO

# Slots, heaps, and skips are non-empty for a valid document. jsono() yields the bare
# STRUCT, so the BLOB children are read directly (the cast below is a no-op shape annotation).
query IIII
SELECT
  octet_length((jsono('{"a":1,"b":"hi"}')::STRUCT(jsono_slots BLOB, jsono_key_heap BLOB, jsono_string_heap BLOB, jsono_skips BLOB)).jsono_slots) > 0,
  octet_length((jsono('{"a":1,"b":"hi"}')::STRUCT(jsono_slots BLOB, jsono_key_heap BLOB, jsono_string_heap BLOB, jsono_skips BLOB)).jsono_key_heap) > 0,
  octet_length((jsono('{"a":1,"b":"hi"}')::STRUCT(jsono_slots BLOB, jsono_key_heap BLOB, jsono_string_heap BLOB, jsono_skips BLOB)).jsono_string_heap) > 0,
  octet_length((jsono('{"a":1,"b":"hi"}')::STRUCT(jsono_slots BLOB, jsono_key_heap BLOB, jsono_string_heap BLOB, jsono_skips BLOB)).jsono_skips) > 0;
----
true	true	true	true

# The writer emits a metadata header (12 B) plus one 16-byte span per object/array container.
query I
SELECT octet_length((jsono('{"a":"x","b":["yy"]}')::STRUCT(jsono_slots BLOB, jsono_key_heap BLOB, jsono_string_heap BLOB, jsono_skips BLOB)).jsono_skips);
----
44

# One cursor checkpoint is added for an object with 17 keys.
query I
SELECT octet_length((jsono('{"k00":0,"k01":1,"k02":2,"k03":3,"k04":4,"k05":5,"k06":6,"k07":7,"k08":8,"k09":9,"k10":10,"k11":11,"k12":12,"k13":13,"k14":14,"k15":15,"k16":"x"}')::STRUCT(jsono_slots BLOB, jsono_key_heap BLOB, jsono_string_heap BLOB, jsono_skips BLOB)).jsono_skips);
----
48

# jsono() yields the documented STRUCT shape directly (no type alias).
query I
SELECT typeof(jsono('{"a":1}'));
----
STRUCT(jsono_slots BLOB, jsono_key_heap BLOB, jsono_string_heap BLOB, jsono_skips BLOB)

# jsono() is exactly this STRUCT, so a bare STRUCT (e.g. read from Parquet, which carries no
# alias) flows into to_json/transform unchanged — the cast here is a no-op shape annotation.
query I
SELECT to_json(jsono('{"a":1}')::STRUCT(jsono_slots BLOB, jsono_key_heap BLOB, jsono_string_heap BLOB, jsono_skips BLOB));
----
{"a":1}
