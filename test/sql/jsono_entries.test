# name: test/sql/jsono_entries.test
# description: jsono_entries flattens a JSONO document into leaf (key, value) structs
# group: [sql]

require jsono

# Return type is LIST(STRUCT(key VARCHAR, value VARCHAR)).
query I
SELECT typeof(jsono_entries(jsono('{"a":1}')));
----
STRUCT("key" VARCHAR, "value" VARCHAR)[]

# --- default key_style is 'jsonpath' ---
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"a":1,"b":{"c":"x"},"d":true}'))) u)
ORDER BY u.key;
----
$.a	1
$.b.c	x
$.d	true

# Same document, dotted keys.
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"a":1,"b":{"c":"x"},"d":true}'), key_style := 'dotted')) u)
ORDER BY u.key;
----
a	1
b.c	x
d	true

# --- arrays: index segments ([i] for jsonpath, .i for dotted) ---
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"arr":[10,20]}'))) u)
ORDER BY u.key;
----
$.arr[0]	10
$.arr[1]	20

query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"arr":[10,20]}'), key_style := 'dotted')) u)
ORDER BY u.key;
----
arr.0	10
arr.1	20

# --- root array ---
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('[1,2]'))) u)
ORDER BY u.key;
----
$[0]	1
$[1]	2

query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('[1,2]'), key_style := 'dotted')) u)
ORDER BY u.key;
----
0	1
1	2

# --- nested arrays of objects ---
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"a":[1,{"b":2},[3,4]]}'), key_style := 'dotted')) u)
ORDER BY u.key;
----
a.0	1
a.1.b	2
a.2.0	3
a.2.1	4

# --- key containing a dot: jsonpath quotes it, dotted collides (like json_flatten) ---
query I
SELECT u.key FROM (SELECT unnest(jsono_entries(jsono('{"a.b":1}'))) u);
----
$."a.b"

query I
SELECT u.key FROM (SELECT unnest(jsono_entries(jsono('{"a.b":1}'), key_style := 'dotted')) u);
----
a.b

# A literal dotted key and a nested path collapse to the same dotted key (duplicate preserved).
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"a":{"b":1},"a.b":2}'), key_style := 'dotted')) u)
ORDER BY u.value;
----
a.b	1
a.b	2

# --- empty containers contribute no leaves ---
query I
SELECT count(*) FROM (SELECT unnest(jsono_entries(jsono('{"a":{},"b":[],"c":1}'))) u);
----
1

# --- null leaf: key is kept, value is SQL NULL ---
query IT
SELECT u.key, coalesce(u.value, '<NULL>')
FROM (SELECT unnest(jsono_entries(jsono('{"keep":1,"n":null}'), key_style := 'dotted')) u)
ORDER BY u.key;
----
keep	1
n	<NULL>

# --- value stringification: ints, big ints, decimals, bool, string ---
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"i":42,"big":9223372036854775807,"f":3.14,"b":false,"s":"hi"}'), key_style := 'dotted')) u)
ORDER BY u.key;
----
b	false
big	9223372036854775807
f	3.14
i	42
s	hi

# --- NULL input yields NULL ---
query I
SELECT jsono_entries(jsono(NULL)) IS NULL;
----
true

# --- empty object yields an empty list (not NULL) ---
query I
SELECT len(jsono_entries(jsono('{}')));
----
0

# --- bind errors ---
statement error
SELECT jsono_entries(jsono('{}'), key_style := 'invalid');
----
key_style must be 'jsonpath' or 'dotted'

statement error
SELECT jsono_entries(jsono('{"a":1}'), key_style := key_style) FROM (VALUES ('dotted')) t(key_style);
----
key_style must be constant

# key_style is a named argument: a bare positional value is rejected.
statement error
SELECT jsono_entries(jsono('{}'), 'dotted');
----
unknown argument

# =====================================================================================
# array_style := 'whole_json' (plan 031): an array renders as ONE leaf whose value is the
# whole array as JSON text; the walk stops at the array boundary. Orthogonal to key_style.
# =====================================================================================

# --- mode contrast: same doc, both modes (indexed_elements default unchanged above) ---
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"arr":[10,20]}'), key_style := 'dotted', array_style := 'whole_json')) u)
ORDER BY u.key;
----
arr	[10,20]

query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"arr":[10,20]}'), array_style := 'whole_json')) u)
ORDER BY u.key;
----
$.arr	[10,20]

query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"items":[{"sku":"a"},{"sku":"b"}]}'), key_style := 'dotted', array_style := 'whole_json')) u)
ORDER BY u.key;
----
items	[{"sku":"a"},{"sku":"b"}]

# nested array of mixed scalar/object/array stays one whole-JSON leaf (no descent)
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"a":[1,{"b":2},[3,4]]}'), key_style := 'dotted', array_style := 'whole_json')) u)
ORDER BY u.key;
----
a	[1,{"b":2},[3,4]]

# --- whole_json structure & edges ---

# array nested under objects: key_style governs the object path down to the array
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"a":{"items":[1,2]}}'), key_style := 'dotted', array_style := 'whole_json')) u)
ORDER BY u.key;
----
a.items	[1,2]

query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"a":{"items":[1,2]}}'), array_style := 'whole_json')) u)
ORDER BY u.key;
----
$.a.items	[1,2]

# scalar leaf stays bare text; array leaf is a JSON literal — the §7 asymmetry, side by side
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"items":[1],"name":"x"}'), key_style := 'dotted', array_style := 'whole_json')) u)
ORDER BY u.key;
----
items	[1]
name	x

# empty array is a present `[]` value (deliberate divergence from indexed_elements)
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"a":[]}'), key_style := 'dotted', array_style := 'whole_json')) u)
ORDER BY u.key;
----
a	[]

# JSON null inside an array is part of the array text, not a separate null leaf
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"a":[null,1]}'), key_style := 'dotted', array_style := 'whole_json')) u)
ORDER BY u.key;
----
a	[null,1]

# no arrays: identical output to the default mode (nothing to stop at)
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"a":1,"b":true}'), key_style := 'dotted', array_style := 'whole_json')) u)
ORDER BY u.key;
----
a	1
b	true

# --- root-level array: fail loud at runtime, regardless of key_style ---
statement error
SELECT jsono_entries(jsono('[1,2]'), array_style := 'whole_json');
----
whole_json requires an object document

statement error
SELECT jsono_entries(jsono('[1,2]'), key_style := 'dotted', array_style := 'whole_json');
----
whole_json requires an object document

# indexed_elements is unaffected: a root array still flattens
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('[1,2]'), key_style := 'dotted', array_style := 'indexed_elements')) u)
ORDER BY u.key;
----
0	1
1	2

# --- named args are order-independent ---
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"arr":[1]}'), array_style := 'whole_json', key_style := 'dotted')) u)
ORDER BY u.key;
----
arr	[1]

# --- default identity: jsono_entries(x) == jsono_entries(x, array_style := 'indexed_elements') ---
query I
SELECT jsono_entries(jsono('{"arr":[10,20],"x":{"y":[1]},"s":"hi"}'))
     = jsono_entries(jsono('{"arr":[10,20],"x":{"y":[1]},"s":"hi"}'), array_style := 'indexed_elements');
----
true

# --- whole-array round-trip: the JSON leaf reconstructs the original array value ---
require json

query I
SELECT jsono(value) = jsono('[{"sku":"a"},{"sku":"b"}]')
FROM (SELECT u.value FROM (SELECT unnest(jsono_entries(jsono('{"items":[{"sku":"a"},{"sku":"b"}]}'), array_style := 'whole_json')) u) WHERE u.key = '$.items');
----
true

# --- key-set equality at depth: whole_json keys == indexed_elements keys truncated at first index ---
# {"a":{"b":[1,2]},"c":3} → whole keys {$.a.b, $.c}; indexed keys {$.a.b[0],$.a.b[1],$.c} → truncate → same set
query I
WITH w AS (SELECT u.key FROM (SELECT unnest(jsono_entries(jsono('{"a":{"b":[1,2]},"c":3}'), array_style := 'whole_json')) u)),
     i AS (SELECT DISTINCT regexp_replace(u.key, '\[\d+\].*$', '') AS key FROM (SELECT unnest(jsono_entries(jsono('{"a":{"b":[1,2]},"c":3}'))) u))
SELECT (SELECT count(*) FROM (SELECT * FROM w EXCEPT SELECT * FROM i)) +
       (SELECT count(*) FROM (SELECT * FROM i EXCEPT SELECT * FROM w));
----
0

# --- whole_json bind errors ---
statement error
SELECT jsono_entries(jsono('{}'), array_style := 'flat');
----
array_style must be 'indexed_elements' or 'whole_json'

statement error
SELECT jsono_entries(jsono('{}'), array_style := NULL);
----
array_style must not be NULL

# array_style is named-only: a bare positional triple is rejected
statement error
SELECT jsono_entries(jsono('{}'), 'dotted', 'whole_json');
----
unknown argument

# --- shred-aware: a shredded value flattens its residual tape AND its shred columns ---
query I
SELECT jsono_entries(
  jsono('{"a":1,"event_name":"page_view"}', shredding := {'event_name':'VARCHAR'}),
  key_style := 'dotted'
);
----
[{'key': a, 'value': 1}, {'key': event_name, 'value': page_view}]

# absent shred (NULL) contributes no entry
query I
SELECT jsono_entries(
  jsono('{"a":1}', shredding := {'event_name':'VARCHAR'}),
  key_style := 'dotted'
);
----
[{'key': a, 'value': 1}]

# A VARCHAR shred only strips a real JSON string; a non-string scalar (boolean, number) stays in the
# residual and the shred keeps a read-copy for fast typed reads. jsono_entries must emit each such
# leaf once (from the residual), not double it via the shred overlay.
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"x":false}', shredding := {'$.x':'VARCHAR'}))) u)
ORDER BY ALL;
----
$.x	false

query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono('{"x":42,"y":"s"}', shredding := {'$.x':'VARCHAR','$.y':'VARCHAR'}))) u)
ORDER BY ALL;
----
$.x	42
$.y	s

# --- DOUBLE shred leaf renders shortest round-trip text, identical to the residual path ---
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono(jsono({a: 1.5::DOUBLE}), shredding := {'a':'DOUBLE'}))) u);
----
$.a	1.5

# same stored double in the residual (array element, not shreddable)
query II
SELECT u.key, u.value
FROM (SELECT unnest(jsono_entries(jsono({a: [1.5::DOUBLE]}))) u);
----
$.a[0]	1.5

# the shred leaf text matches to_json of the same document
require json

query I
SELECT to_json(jsono(jsono({a: 1.5::DOUBLE}), shredding := {'a':'DOUBLE'}));
----
{"a":1.5}
