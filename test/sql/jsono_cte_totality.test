# name: test/sql/jsono_cte_totality.test
# description: Shred totality flows through a CTE (materialized on the pre-optimize plan, inlined later), so an extract over the CTE column reads its lane COALESCE-free instead of dragging the residual fallback.
# group: [sql]

require jsono

require json

statement ok
CREATE TABLE cte_total AS
SELECT i AS id, jsono('{"x": ' || i::VARCHAR || ', "k":"a"}', shredding := {'$.x':'BIGINT'}) AS j
FROM range(2000) tt(i);

statement ok
PRAGMA explain_output='physical_only';

# (a) the reported regression shape: a pass-through CTE between the scan and the extract. The CTE is
# planned as a materialized CTE and only inlined by the built-in pipeline AFTER our pre-optimize
# rewrite, so totality must flow through the CTE_SCAN binding or the read decays to
# COALESCE(lane, jsono_extract_string(residual)) — which drags all six residual blobs.
query II
EXPLAIN WITH windowed AS (SELECT * FROM cte_total) SELECT j ->> '$.x', count(*) FROM windowed GROUP BY 1;
----
physical_plan	<!REGEX>:.*(COALESCE|jsono_extract|reconstruct|overlay).*

# (b) explicit AS MATERIALIZED: the CTE survives into the physical plan, and the lane read over the
# CTE_SCAN output is still COALESCE-free.
query II
EXPLAIN WITH w AS MATERIALIZED (SELECT * FROM cte_total) SELECT MIN(CAST(j->>'$.x' AS BIGINT)) FROM w;
----
physical_plan	<!REGEX>:.*(COALESCE|jsono_extract|reconstruct|overlay).*

# (c) a filter inside the CTE keeps the scan bindings visible through the CTE side; totality still
# reaches the consumer.
query II
EXPLAIN WITH w AS (SELECT * FROM cte_total WHERE id % 2 = 0) SELECT MIN(CAST(j->>'$.x' AS BIGINT)) FROM w;
----
physical_plan	<!REGEX>:.*(COALESCE|jsono_extract|reconstruct|overlay).*

# (d) chained CTEs: totality is transitive across a CTE-of-a-CTE.
query II
EXPLAIN WITH a AS (SELECT * FROM cte_total), b AS (SELECT * FROM a) SELECT MIN(CAST(j->>'$.x' AS BIGINT)) FROM b;
----
physical_plan	<!REGEX>:.*(COALESCE|jsono_extract|reconstruct|overlay).*

statement ok
PRAGMA explain_output='all';

# Values stay correct under every CTE shape.
query II
WITH windowed AS (SELECT * FROM cte_total) SELECT j ->> '$.x' AS p, count(*) FROM windowed GROUP BY 1 ORDER BY p LIMIT 3;
----
0	1
1	1
10	1

query II
WITH w AS MATERIALIZED (SELECT * FROM cte_total) SELECT MIN(CAST(j->>'$.x' AS BIGINT)), MAX(CAST(j->>'$.x' AS BIGINT)) FROM w;
----
0	1999

query II
WITH w AS (SELECT * FROM cte_total WHERE id % 2 = 0) SELECT MIN(CAST(j->>'$.x' AS BIGINT)), MAX(CAST(j->>'$.x' AS BIGINT)) FROM w;
----
0	1998

# Multi-use CTE (materialized, read twice): both readers stay correct.
query II
WITH w AS (SELECT * FROM cte_total)
SELECT (SELECT MIN(CAST(j->>'$.x' AS BIGINT)) FROM w), (SELECT MAX(CAST(j->>'$.x' AS BIGINT)) FROM w);
----
0	1999

# Negative control: a diverted shred (a string at $.x spills to the residual) is NOT total, and the
# CTE must not launder that — the safe COALESCE fallback stays and recovers the residual values.
statement ok
CREATE TABLE cte_hetero AS
SELECT jsono(
  CASE WHEN i % 2 = 0 THEN '{"x": ' || i::VARCHAR || '}' ELSE '{"x": "str"}' END,
  shredding := {'$.x':'BIGINT'}) AS j
FROM range(1000) tt(i);

statement ok
PRAGMA explain_output='physical_only';

query II
EXPLAIN WITH w AS (SELECT * FROM cte_hetero) SELECT MIN(TRY_CAST(j->>'$.x' AS BIGINT)) FROM w;
----
physical_plan	<REGEX>:.*COALESCE.*

statement ok
PRAGMA explain_output='all';

query II
WITH w AS (SELECT * FROM cte_hetero) SELECT MIN(TRY_CAST(j->>'$.x' AS BIGINT)), MAX(TRY_CAST(j->>'$.x' AS BIGINT)) FROM w;
----
0	998
