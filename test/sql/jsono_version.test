# name: test/sql/jsono_version.test
# description: jsono_version() exposes the format version; a present-but-unreadable header (bad magic / version) fails loud, only an absent value reads NULL
# group: [sql]

require jsono

# The format version is SQL-visible so a schema epoch can fold it in: a format bump leaves
# the physical STRUCT type unchanged, so the type alone cannot signal that stored data is stale.
query I
SELECT jsono_version();
----
4

# A blob with the right magic ('JSNO', little-endian 4A 53 4E 4F) but a newer version byte
# (0x05) is data written by another build, not garbage. Reading it must FAIL LOUD rather than
# silently yield SQL NULL across every stored row (which a stripped/shredded residual makes
# undetectable downstream). The hand-built value uses the nested storage layout.
statement error
SELECT jsono_extract_string(
  {'jsono': {'body': {'slots': '\x4A\x53\x4E\x4F\x05\x00\x00\x00'::BLOB,
   'key_heap': ''::BLOB, 'string_heap': ''::BLOB, 'skips': ''::BLOB, 'lengths': ''::BLOB, 'nums': ''::BLOB}}}, '$.a');
----
JSONO format version mismatch

# A header-only blob (correct magic+version, zero slots) is a well-formed *empty* value, so it
# reads as SQL NULL. This is the only non-throwing case: the value is absent, not corrupt.
query I
SELECT jsono_extract_string(
  {'jsono': {'body': {'slots': '\x4A\x53\x4E\x4F\x04\x00\x00\x00'::BLOB,
   'key_heap': ''::BLOB, 'string_heap': ''::BLOB, 'skips': ''::BLOB, 'lengths': ''::BLOB, 'nums': ''::BLOB}}}, '$.a');
----
NULL

# Wrong magic on a present (header-sized) blob is non-JSONO bytes bound to a jsono op, not an
# absent value. It must FAIL LOUD, not silently read as SQL NULL — the same corruption class as
# a version drift. (Only a slots blob too short to hold a header reads as NULL: absent value.)
statement error
SELECT jsono_extract_string(
  {'jsono': {'body': {'slots': '\xDE\xAD\xBE\xEF\x04\x00\x00\x00'::BLOB,
   'key_heap': ''::BLOB, 'string_heap': ''::BLOB, 'skips': ''::BLOB, 'lengths': ''::BLOB, 'nums': ''::BLOB}}}, '$.a');
----
not a JSONO value

# jsono_validate recovers a boolean from these throws (try/catch), so it still reports validity
# rather than erroring: non-JSONO bytes -> false, not a raised error.
query I
SELECT jsono_validate(
  {'jsono': {'body': {'slots': '\xDE\xAD\xBE\xEF\x04\x00\x00\x00'::BLOB,
   'key_heap': ''::BLOB, 'string_heap': ''::BLOB, 'skips': ''::BLOB, 'lengths': ''::BLOB, 'nums': ''::BLOB}}});
----
false

# The absent case: a slots blob too short to even hold a header is an absent value, not corrupt,
# so it reads as SQL NULL (the only non-throwing path).
query I
SELECT jsono_extract_string(
  {'jsono': {'body': {'slots': '\x4A\x53'::BLOB,
   'key_heap': ''::BLOB, 'string_heap': ''::BLOB, 'skips': ''::BLOB, 'lengths': ''::BLOB, 'nums': ''::BLOB}}}, '$.a');
----
NULL

# A non-empty skips blob shorter than the container-metadata header (1..11 bytes) cannot come
# from the writer (it always emits the 12-byte header): it is corruption and must FAIL LOUD,
# not silently read as "no spans / no manifest". Only a fully empty skips blob stays readable.
statement error
WITH src AS (SELECT jsono('{"a":1}').jsono.body AS b)
SELECT jsono_extract_string({'jsono': {'body': {'slots': b.slots, 'key_heap': b.key_heap,
  'string_heap': b.string_heap, 'skips': '\x01'::BLOB, 'lengths': b.lengths, 'nums': b.nums}}}, '$.a')
FROM src;
----
malformed JSONO

# jsono_validate recovers false from the same corruption instead of erroring.
query I
WITH src AS (SELECT jsono('{"a":1}').jsono.body AS b)
SELECT jsono_validate({'jsono': {'body': {'slots': b.slots, 'key_heap': b.key_heap,
  'string_heap': b.string_heap, 'skips': '\x01'::BLOB, 'lengths': b.lengths, 'nums': b.nums}}})
FROM src;
----
false
