# name: test/sql/jsono_embedded_verbatim.test
# description: Constructor verbatim copy of an embedded jsono field round-trips every scalar encoding and empty containers
# group: [sql]

require jsono

require json

# The constructor's embedded-jsono path (StructValueStrategy::Jsono) copies an
# inner jsono value byte-for-byte via EmitValueVerbatim. Embed scalars that exercise
# every raw encoding kind — DEC60 (small decimal), UINT64 in the 2^63..2^64-1 range
# (ext INT64/UINT64 raw bits), and a bignum NumberText (length+heap) — plus empty
# object and empty array, and assert the outer construction equals constructing the
# same shape from raw JSON text.
query I
SELECT to_json(jsono({'z': 1, 'nested': jsono('{"dec":12345.12,"u":18446744073709551615,"big":123456789012345678901234567890123456789,"eo":{},"ea":[]}')}))
     = to_json(jsono('{"z":1,"nested":{"dec":12345.12,"u":18446744073709551615,"big":123456789012345678901234567890123456789,"eo":{},"ea":[]}}'));
----
true

# Direct render of the embedded value (sorted keys, scalars preserved verbatim).
query I
SELECT to_json(jsono({'z': 1, 'nested': jsono('{"dec":12345.12,"u":18446744073709551615,"big":123456789012345678901234567890123456789,"eo":{},"ea":[]}')}));
----
{"nested":{"big":123456789012345678901234567890123456789,"dec":12345.12,"ea":[],"eo":{},"u":18446744073709551615},"z":1}

# Embedded value that is itself an empty object / empty array round-trips.
query I
SELECT to_json(jsono({'eo': jsono('{}'), 'ea': jsono('[]')}));
----
{"ea":[],"eo":{}}

# An embedded jsono value is a subtree, not a SQL struct: auto-shred must not descend into its
# layout. The six body blobs are BLOB, which promotes to a VARCHAR lane, so descending would lift
# `$.nested.jsono.body.slots` and friends into shreds of a document that has no such paths.
query I
SELECT typeof(jsono({'z': 1, 'nested': jsono('{"a":1}')}));
----
STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB), shreds STRUCT("$jsono$set" BIGINT, "$jsono$spill$0" BIGINT, z BIGINT)))

# A shredded value embeds as its document at every position the constructor takes it: struct field,
# MAP value, LIST element, and the document root. Only the plain layout is recognized structurally,
# so a shredded input read as a bare struct would emit its six blobs as the document itself.
query IIII
SELECT to_json(jsono({'k': jsono({'a': 1, 'b': 'x'})}))::VARCHAR,
       to_json(jsono(MAP {'k': jsono({'a': 1, 'b': 'x'})}))::VARCHAR,
       to_json(jsono([jsono({'a': 1, 'b': 'x'})]))::VARCHAR,
       to_json(jsono(jsono({'a': 1, 'b': 'x'})))::VARCHAR;
----
{"k":{"a":1,"b":"x"}}	{"k":{"a":1,"b":"x"}}	[{"a":1,"b":"x"}]	{"a":1,"b":"x"}

# The embedded shreds are overlaid back onto the residual, so the document reads by path and the
# outer value carries no lane of the inner one.
query II
SELECT jsono({'k': jsono({'a': 1, 'b': 'x'})})->>'$.k.b',
       typeof(jsono({'k': jsono({'a': 1, 'b': 'x'})})) = jsono_storage_type();
----
x	true

# The same over a real column (the constructed value is shredded by default), not a folded constant.
statement ok
CREATE TABLE embedded_source AS SELECT jsono({'a': i, 'b': 'x'}) AS doc FROM range(3) t(i);

query I
SELECT to_json(jsono({'k': doc}))::VARCHAR FROM embedded_source ORDER BY 1;
----
{"k":{"a":0,"b":"x"}}
{"k":{"a":1,"b":"x"}}
{"k":{"a":2,"b":"x"}}
