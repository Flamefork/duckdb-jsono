# name: test/sql/jsono_constructor_input_types.test
# description: Constructor input-type coverage - string-rendered scalars (temporal/UUID/ENUM/INTERVAL/BLOB/BIT) and VARINT bignums
# group: [sql]

require jsono

require json

statement ok
CREATE TYPE mood AS ENUM ('sad', 'ok', 'happy');

# Types that JSON renders as strings go through the engine's VARCHAR cast, which is the same
# StringCast core to_json uses - so the rendering is byte-identical to core.
query I
SELECT to_json(jsono({'bl': '\xAA\xBB'::BLOB,
                      'bt': '101'::BIT,
                      'd': DATE '2024-01-01',
                      'e': 'happy'::mood,
                      'iv': INTERVAL '3 days 2 hours',
                      't': TIME '12:34:56.789',
                      'ts': TIMESTAMP '2024-01-01 12:34:56.789',
                      'ts_ms': TIMESTAMP_MS '2024-01-01 12:34:56.789',
                      'ts_ns': TIMESTAMP_NS '2024-01-01 12:34:56.123456789',
                      'ts_s': TIMESTAMP_S '2024-01-01 12:34:56',
                      'ttz': TIMETZ '12:34:56+02',
                      'u': UUID '4ac7a9e9-607c-4c8a-84f3-843f0191e3fd'}))::VARCHAR;
----
{"bl":"\\xAA\\xBB","bt":"101","d":"2024-01-01","e":"happy","iv":"3 days 02:00:00","t":"12:34:56.789","ts":"2024-01-01 12:34:56.789","ts_ms":"2024-01-01 12:34:56.789","ts_ns":"2024-01-01 12:34:56.123456789","ts_s":"2024-01-01 12:34:56","ttz":"12:34:56+02","u":"4ac7a9e9-607c-4c8a-84f3-843f0191e3fd"}

# TIMESTAMPTZ rendering depends on the session TimeZone, so assert parity with core to_json
# (both sides render through the same session-dependent cast) instead of a pinned literal.
query I
SELECT to_json(jsono({'tstz': TIMESTAMPTZ '2024-01-01 12:34:56+00'}))::VARCHAR
       = to_json({'tstz': TIMESTAMPTZ '2024-01-01 12:34:56+00'})::VARCHAR;
----
true

# The constructed document is byte-identical to the same document parsed from text.
query I
SELECT to_json(jsono({'d': DATE '2024-01-01', 'u': UUID '4ac7a9e9-607c-4c8a-84f3-843f0191e3fd'}))::VARCHAR
       = to_json(jsono('{"d":"2024-01-01","u":"4ac7a9e9-607c-4c8a-84f3-843f0191e3fd"}'))::VARCHAR;
----
true

# NULL fields of the new types stay lossless explicit JSON nulls.
query I
SELECT to_json(jsono({'bl': NULL::BLOB, 'd': NULL::DATE, 'u': NULL::UUID}))::VARCHAR;
----
{"bl":null,"d":null,"u":null}

# VARINT joins the NumberText group: the exact digits reach the number ladder, losslessly, past
# what HUGEINT can hold. Build it from text - a bare numeric literal would go through DOUBLE.
query I
SELECT to_json(jsono({'v': ('1' || repeat('0', 45))::VARINT}))::VARCHAR;
----
{"v":1000000000000000000000000000000000000000000000}

query I
SELECT to_json(jsono({'v': ('1' || repeat('0', 45))::VARINT}))::VARCHAR
       = to_json(jsono('{"v":' || ('1' || repeat('0', 45)) || '}'))::VARCHAR;
----
true

# String-rendered types auto-shred into VARCHAR lanes: the lane carries exactly the text the
# residual would have carried, so ->> reads it back and to_json reconstructs unchanged.
query I
SELECT typeof(jsono({'ts': TIMESTAMP '2024-01-01 12:34:56.789', 'u': UUID '4ac7a9e9-607c-4c8a-84f3-843f0191e3fd'}));
----
STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB), shreds STRUCT("$jsono$set" BIGINT, ts STRUCT("value" VARCHAR, complete TINYINT), u STRUCT("value" VARCHAR, complete TINYINT))))

query III
SELECT jsono({'ts': TIMESTAMP '2024-01-01 12:34:56.789', 'u': UUID '4ac7a9e9-607c-4c8a-84f3-843f0191e3fd'})->>'ts',
       jsono({'ts': TIMESTAMP '2024-01-01 12:34:56.789', 'u': UUID '4ac7a9e9-607c-4c8a-84f3-843f0191e3fd'})->>'u',
       to_json(jsono({'ts': TIMESTAMP '2024-01-01 12:34:56.789', 'u': UUID '4ac7a9e9-607c-4c8a-84f3-843f0191e3fd'}))::VARCHAR;
----
2024-01-01 12:34:56.789	4ac7a9e9-607c-4c8a-84f3-843f0191e3fd	{"ts":"2024-01-01 12:34:56.789","u":"4ac7a9e9-607c-4c8a-84f3-843f0191e3fd"}

# VARINT/HUGEINT stay in the residual (NumberText is not a lane type), so a struct mixing them
# with a shreddable field shreds only the field that has a lane.
query II
SELECT typeof(jsono({'v': ('1' || repeat('0', 45))::VARINT, 'ts': TIMESTAMP '2024-01-01 12:34:56.789'})),
       to_json(jsono({'v': ('1' || repeat('0', 45))::VARINT, 'ts': TIMESTAMP '2024-01-01 12:34:56.789'}))::VARCHAR;
----
STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB), shreds STRUCT("$jsono$set" BIGINT, ts STRUCT("value" VARCHAR, complete TINYINT))))	{"ts":"2024-01-01 12:34:56.789","v":1000000000000000000000000000000000000000000000}

# An explicit shredding spec over a constructed value re-shreds the string-rendered lane
# losslessly (the `shredding :=` overload takes JSON text or a jsono value, not a SQL STRUCT).
query II
SELECT typeof(jsono(jsono({'ts': TIMESTAMP '2024-01-01 12:34:56.789'}), shredding := {'$.ts': 'VARCHAR'})),
       to_json(jsono(jsono({'ts': TIMESTAMP '2024-01-01 12:34:56.789'}), shredding := {'$.ts': 'VARCHAR'}))::VARCHAR;
----
STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB), shreds STRUCT("$jsono$set" BIGINT, "$.ts" STRUCT("value" VARCHAR, complete TINYINT))))	{"ts":"2024-01-01 12:34:56.789"}

# UNION stays a loud bind error: core renders it as a tagged object, which the VARCHAR cast
# does not reproduce, so there is no parity to be had from a text rendering.
statement error
SELECT jsono({'u': union_value(num := 2)});
----
unsupported value type

# TIME_NS is a string type like the rest of the temporal row, and renders like core's.
query I
SELECT to_json(jsono({'t': TIME_NS '12:00:00.123456789'}))::VARCHAR
       = to_json({'t': TIME_NS '12:00:00.123456789'})::VARCHAR;
----
true

# The residual carries the same UTC text the lane does: a plain cast (no shredding) must render it
# identically, or a shredded column and a plain one would disagree on the same value.
query I
SELECT to_json(CAST({'ts': TIMESTAMPTZ '2024-01-01 12:00:00+00',
                     'd': DATE '2024-01-01',
                     'bl': '\xAA'::BLOB} AS STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB)))))::VARCHAR
       = to_json(jsono({'ts': TIMESTAMPTZ '2024-01-01 12:00:00+00',
                        'd': DATE '2024-01-01',
                        'bl': '\xAA'::BLOB}))::VARCHAR;
----
true

# An ARRAY field gets the same list lane a LIST field gets: the residual holds a plain JSON array
# either way, so the fixed size is a SQL-side detail, not a document one.
query III
SELECT typeof(jsono({'a': array_value(1, 2), 'n': 5})) = typeof(jsono({'a': [1, 2], 'n': 5})),
       to_json(jsono({'a': array_value(1, 2), 'n': 5}))::VARCHAR,
       jsono({'a': array_value(1, 2), 'n': 5})->>'$.a[1]';
----
true	{"a":[1,2],"n":5}	2

# MAP keys that collide only after rendering to text: DuckDB accepts the typed keys (distinct UNION
# tags), both render to "1", and one entry would silently overwrite the other. Fail loud instead.
statement error
SELECT jsono(MAP([union_value(a := 1)::UNION(a INT, b INT), union_value(b := 1)::UNION(a INT, b INT)], [10, 20]));
----
MAP keys collide after rendering to text

# The new inputs on a real (flat, multi-row, filtered) vector rather than a folded constant: NULL
# rows, maps of different widths, and per-row keys all index through the same child offsets.
statement ok
CREATE TABLE rows_source AS
SELECT i AS rid,
       CASE WHEN i % 4 = 0 THEN NULL
            ELSE map_from_entries([('k' || (9 - i % 3), i), ('a', i * 2)])
       END AS m,
       TIMESTAMP '2024-01-01 00:00:00' + INTERVAL (i) HOUR AS ts
FROM range(9) t(i);

query III
SELECT rid, to_json(jsono({'m': m, 'ts': ts}))::VARCHAR, jsono({'m': m, 'ts': ts})->>'ts'
FROM rows_source
WHERE rid % 3 = 0
ORDER BY rid;
----
0	{"m":null,"ts":"2024-01-01 00:00:00"}	2024-01-01 00:00:00
3	{"m":{"a":6,"k9":3},"ts":"2024-01-01 03:00:00"}	2024-01-01 03:00:00
6	{"m":{"a":12,"k9":6},"ts":"2024-01-01 06:00:00"}	2024-01-01 06:00:00

# A MAP builds a JSON object per row. Keys sort (the format's unique-sorted-key invariant),
# which diverges from core to_json's insertion order - the pairs are the same.
query I
SELECT to_json(jsono(MAP {'b': 2, 'a': 1}))::VARCHAR;
----
{"a":1,"b":2}

# Nested MAP fields sit next to ordinary fields; MAP values recurse into any supported type.
query IIII
SELECT to_json(jsono({'m': MAP {'k': 1}, 'z': 2}))::VARCHAR,
       to_json(jsono(MAP {'k': {'b': 2, 'a': 1}}))::VARCHAR,
       to_json(jsono(MAP {'k': [1, 2]}))::VARCHAR,
       to_json(jsono(MAP {'o': MAP {'i': 1}}))::VARCHAR;
----
{"m":{"k":1},"z":2}	{"k":{"a":1,"b":2}}	{"k":[1,2]}	{"o":{"i":1}}

# Non-VARCHAR keys render as their text (as in core), and sort as text: "1" < "10" < "2".
query I
SELECT to_json(jsono(MAP {1: 'x', 10: 'y', 2: 'z'}))::VARCHAR;
----
{"1":"x","10":"y","2":"z"}

# Empty map, empty-string key, NULL map value, NULL map field, NULL map root.
query IIIII
SELECT to_json(jsono(MAP {}::MAP(VARCHAR, INTEGER)))::VARCHAR,
       to_json(jsono(MAP {'': 1}))::VARCHAR,
       to_json(jsono(MAP {'k': NULL::INTEGER}))::VARCHAR,
       to_json(jsono({'m': NULL::MAP(VARCHAR, INTEGER), 'z': 1}))::VARCHAR,
       jsono(NULL::MAP(VARCHAR, INTEGER)) IS NULL;
----
{}	{"":1}	{"k":null}	{"m":null,"z":1}	true

# A map-built document is byte-identical to the same document parsed from text.
query I
SELECT to_json(jsono(MAP {'b': 2, 'a': 1}))::VARCHAR = to_json(jsono('{"a":1,"b":2}'))::VARCHAR;
----
true

# A MAP field is not shred-eligible and stays in the residual; the other fields still shred,
# and the map content reads back out of the residual by path.
query III
SELECT typeof(jsono({'m': MAP {'k': 'v'}, 'n': 5})),
       jsono({'m': MAP {'k': 'v'}, 'n': 5})->>'$.m.k',
       jsono({'m': MAP {'k': 'v'}, 'n': 5})->>'n';
----
STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB), shreds STRUCT("$jsono$set" BIGINT, n STRUCT("value" BIGINT, complete TINYINT))))	v	5

# A MAP casts to jsono storage, so INSERT of a MAP into a jsono column works.
statement ok
CREATE TABLE map_docs(j STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB))));

statement ok
INSERT INTO map_docs SELECT MAP {'b': 2, 'a': 1};

query I
SELECT to_json(j)::VARCHAR FROM map_docs;
----
{"a":1,"b":2}

query I
SELECT to_json(CAST(MAP {'x': 1} AS STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB)))))::VARCHAR;
----
{"x":1}

# A LIST or ARRAY root builds an array document (a JSON document need not be an object).
query IIIII
SELECT to_json(jsono([1, 2, 3]))::VARCHAR,
       to_json(jsono(array_value(1, 2, 3)))::VARCHAR,
       to_json(jsono([]::INTEGER[]))::VARCHAR,
       to_json(jsono([{'b': 2, 'a': 1}, NULL]))::VARCHAR,
       to_json(jsono([MAP {'k': 'v'}]))::VARCHAR;
----
[1,2,3]	[1,2,3]	[]	[{"a":1,"b":2},null]	[{"k":"v"}]

# Shredding lifts top-level object fields, so an array root constructs plain jsono - even when
# its elements are objects with shreddable fields.
query II
SELECT typeof(jsono([{'a': 1}])), typeof(jsono([{'a': 1}])) = jsono_storage_type();
----
STRUCT(jsono STRUCT(body STRUCT(slots BLOB, key_heap BLOB, string_heap BLOB, skips BLOB, lengths BLOB, nums BLOB)))	true

query I
SELECT jsono(NULL::INTEGER[]) IS NULL;
----
true

query I
SELECT to_json(jsono([1, 2, 3]))::VARCHAR = to_json(jsono('[1,2,3]'))::VARCHAR;
----
true

# A LIST casts to jsono storage, so INSERT of a list into a jsono column works.
statement ok
INSERT INTO map_docs SELECT [1, 2];

query I
SELECT to_json(j)::VARCHAR FROM map_docs ORDER BY 1;
----
[1,2]
{"a":1,"b":2}
